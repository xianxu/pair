#!/usr/bin/env bash
# pair-notify — emit a notification escape to the outer terminal/wrapper
# from inside a pair (zellij) pane.
#
# Why: zellij filters most OSC escapes (parses them for its own virtual
# screen and drops anything it doesn't have semantics for), so OSC 9/777
# emitted from a pane never reach an outer wrapper like cmux that watches
# the PTY stream for attention markers. bin/pair records its controlling
# TTY (the outer PTY's path) at every attach into a per-tag file; this
# script reads that file and writes the OSC sequence directly to it,
# bypassing zellij entirely. #000011
#
# Usage:
#   pair-notify "Claude needs input"
#   pair-notify --osc 777 "Claude needs input"
#
# Intended for Claude Code Notification/Stop hooks. Designed to never
# fail loudly — if the outer-tty file is missing or stale, exits 0 with
# a stderr warning so a misconfigured hook doesn't break the agent.

set -uo pipefail

osc=9
case "${1:-}" in
    --osc)
        osc="${2:-9}"
        shift 2 || true
        ;;
    --osc=*)
        osc="${1#--osc=}"
        shift
        ;;
esac

case "$osc" in
    9|777) ;;
    *)
        echo "pair-notify: unsupported --osc value '$osc' (use 9 or 777)" >&2
        exit 2
        ;;
esac

msg="${1:-}"
if [ -z "$msg" ]; then
    echo "pair-notify: missing message argument" >&2
    echo "usage: pair-notify [--osc 9|777] \"message\"" >&2
    exit 2
fi

# Strip control bytes so a stray BEL/ESC in the message can't terminate or
# inject into the OSC sequence we're about to emit.
clean="$(printf '%s' "$msg" | LC_ALL=C tr -d '\000-\037\177')"

tag="${PAIR_TAG:-}"
if [ -z "$tag" ]; then
    echo "pair-notify: PAIR_TAG not set — not running inside a pair session" >&2
    exit 0
fi

data_dir="${PAIR_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/pair}"
tty_file="$data_dir/outer-tty-$tag"

if [ ! -r "$tty_file" ]; then
    echo "pair-notify: $tty_file missing; outer TTY not recorded" >&2
    exit 0
fi

outer_tty="$(head -n1 "$tty_file" 2>/dev/null || true)"
if [ -z "$outer_tty" ] || [ ! -w "$outer_tty" ]; then
    echo "pair-notify: outer TTY '$outer_tty' not writable (likely stale)" >&2
    exit 0
fi

case "$osc" in
    9)   printf '\033]9;%s\007' "$clean" > "$outer_tty" 2>/dev/null || true ;;
    777) printf '\033]777;notify;pair;%s\007' "$clean" > "$outer_tty" 2>/dev/null || true ;;
esac
