#!/usr/bin/env bash
# pair — launch a zellij session split between a TUI coding agent (top pane)
# and an nvim drafting pane (bottom). See README.md.
#
# Usage:
#   pair                       claude in default session
#   pair <agent>               claude / codex / gemini
#   pair <agent> <variant>     independent session, e.g. pair claude work
#   pair -h, --help            show help
#
# When detached pair-* sessions exist, an fzf picker is shown so the user
# explicitly chooses what to do — no silent auto-attach. The picker shows
# ALL detached pair-* sessions regardless of agent argument; the agent
# argument only matters for the create path (sentinel label, default name,
# binary to exec).

set -euo pipefail

# --- help -------------------------------------------------------------------
case "${1:-}" in
    -h|--help|help)
        cat <<'EOF'
pair — Neovim-backed input field for any TUI coding agent.

USAGE
  pair                          claude in default session
  pair <agent>                  e.g. pair codex / pair gemini
  pair <agent> <variant>        independent session, e.g. pair claude work
  pair -h, --help               this message

BEHAVIOR
  Picker shows ALL detached pair-* sessions, regardless of the agent
  argument. The agent argument only controls what gets created if you
  pick the "+ new" sentinel: it labels the sentinel, drives the auto-
  suggested name, and is the binary that gets exec'd.

    0 detached → create a new session (prompts for name; default is
                 auto-generated like pair-claude-2)
    ≥1 detached → fzf picker over every detached pair-* session, plus a
                  "+ new <agent> session" sentinel. Picking attaches;
                  picking the sentinel falls through to the create flow.

  No silent attach. Every reattach is explicit.

KEYBINDINGS (inside a pair session)
  Alt+Return    send nvim buffer to agent + Enter, log, clear, insert mode
  Alt+u         toggle nvim pane fullscreen (works from either pane)
  Alt+d         detach from session
  Alt+n         pull clipboard into nvim cursor (reflowed, ">" -prefixed)
  Alt+i         attach clipboard image to agent + insert [Image #N];
                if cursor is on an existing [Image #N], sync counter to N
  <leader>cs    send only current section (between --- markers)
  <leader>cp    paste-and-reflow at cursor (raw, no quoting)

FILES
  ~/scratch/pair-draft-<tag>.md   persistent draft per session
  ~/scratch/pair-log-<tag>.md     append-only prompt log per session

See README.md for image-paste recipes and other details.
EOF
        exit 0
        ;;
esac

# Resolve this script's real path portably (macOS lacks `readlink -f`).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
PAIR_HOME="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
export PAIR_HOME

# Put pair's bin/ on PATH so zellij can resolve our helper scripts by bare
# name (clipboard-to-pane.sh, copy-on-select.sh) without sh-c env-var hacks
# in zellij/config.kdl. Avoid double-prepending across re-launches.
case ":$PATH:" in
    *":$PAIR_HOME/bin:"*) ;;
    *) export PATH="$PAIR_HOME/bin:$PATH" ;;
esac

AGENT="${1:-claude}"
VARIANT="${2:-}"

# PAIR_AGENT is the command to exec in the agent pane on create.
# PAIR_TAG is the namespace identifier — used to name the zellij session and
# the per-instance draft/log files. Without a variant, tag == agent.
export PAIR_AGENT="$AGENT"
if [ -n "$VARIANT" ]; then
    export PAIR_TAG="${AGENT}-${VARIANT}"
else
    export PAIR_TAG="$AGENT"
fi

if ! command -v zellij >/dev/null 2>&1; then
    echo "pair: zellij not found on PATH." >&2
    echo "      brew install zellij  (or your package manager equivalent)" >&2
    exit 1
fi

# Refuse to launch from inside an existing zellij session. Nested sessions
# don't compose — `--session NAME` from inside zellij triggers attach, not
# create, which fails confusingly when the named session doesn't exist yet.
if [ -n "${ZELLIJ:-}" ]; then
    echo "pair: already running inside a zellij session." >&2
    echo "      detach first (Alt+d) or run pair from a fresh terminal." >&2
    exit 1
fi

mkdir -p "$HOME/scratch"

BASE_TAG="$PAIR_TAG"

# Find ALL detached pair-* sessions, regardless of agent. The agent argument
# (and BASE_TAG) is only used for the create path's defaults; the picker
# itself shows everything you might want to reattach to, including custom-
# named sessions like pair-blogging that don't follow any agent prefix.
# `zellij list-sessions` exits 1 when there are no sessions, and with
# `set -euo pipefail` that would silently kill the whole script. Wrap the
# zellij call in `|| true` and use awk (returns 0 even on no matches)
# instead of grep (returns 1 on no matches).
all_pair=$( { zellij list-sessions --short 2>/dev/null || true; } \
            | awk '/^pair-/' \
            | sort )

detached_list=()
while IFS= read -r sess; do
    [ -z "$sess" ] && continue
    if zellij list-sessions --no-formatting 2>/dev/null \
        | grep -E "^${sess}[[:space:]].*EXITED" >/dev/null 2>&1; then
        continue   # exited, skip
    fi
    clients=$(zellij --session "$sess" action list-clients 2>/dev/null \
              | tail -n +2 | wc -l | tr -d ' ')
    if [ "${clients:-0}" -eq 0 ]; then
        detached_list+=("$sess")
    fi
done <<< "$all_pair"

# Compute the next-free numeric slot in the agent's family — pair-<base>,
# then pair-<base>-2, ... — used as the prompt's default name on create. This
# checks against ALL existing sessions (not just family) to avoid clobbering
# anything that happens to share the slot's name.
free_slot_tag=""
i=1
while [ "$i" -le 100 ]; do
    if [ "$i" -eq 1 ]; then
        cand="pair-${BASE_TAG}"
    else
        cand="pair-${BASE_TAG}-${i}"
    fi
    if ! zellij list-sessions --short 2>/dev/null | grep -qx "$cand"; then
        free_slot_tag="${cand#pair-}"
        break
    fi
    i=$((i + 1))
done

# Decide. Picker for any ≥1 detached; create directly only when none exist.
chosen_session=""
chosen_tag=""
action=""   # "attach" | "create"

if [ ${#detached_list[@]} -eq 0 ]; then
    chosen_tag="$free_slot_tag"
    action=create
else
    new_label="+ new ${BASE_TAG} session"
    options=$(printf '%s\n' "${detached_list[@]}"; printf '%s\n' "$new_label")
    if command -v fzf >/dev/null 2>&1; then
        picked=$(printf '%s' "$options" | fzf --prompt='pair> ' --height=10 --reverse) || exit 0
    else
        echo "Detached pair sessions:"
        printf '%s' "$options" | nl
        printf 'Pick: '
        read -r idx
        picked=$(printf '%s' "$options" | sed -n "${idx}p")
    fi
    [ -z "$picked" ] && exit 0

    if [ "$picked" = "$new_label" ]; then
        chosen_tag="$free_slot_tag"
        action=create
    else
        chosen_session="$picked"
        chosen_tag="${chosen_session#pair-}"
        action=attach
    fi
fi

if [ -z "$chosen_tag" ]; then
    echo "pair: couldn't determine a session to use; bailing." >&2
    exit 1
fi

# Helper: after zellij returns, check for the Alt+x marker. If present, the
# user asked for a full quit — delete the session entry from the resurrect
# list. Plain Ctrl+q leaves no marker, so the session lingers as a resurrect
# candidate (zellij default behavior).
cleanup_quit_marker() {
    local marker="$HOME/.cache/pair/quit-$SESSION"
    if [ -f "$marker" ]; then
        rm -f "$marker"
        zellij delete-session "$SESSION" --force >/dev/null 2>&1 || true
    fi
}

if [ "$action" = "attach" ]; then
    export PAIR_TAG="$chosen_tag"
    SESSION="pair-${PAIR_TAG}"
    DRAFT="$HOME/scratch/pair-draft-${PAIR_TAG}.md"
    [ -f "$DRAFT" ] || : > "$DRAFT"
    # Set terminal title — zellij sets this on new-session creation but not
    # on attach, so without this the title stays as whatever the shell's
    # preexec hook set (typically "bin/pair").
    printf '\033]0;%s\007' "$SESSION"
    zellij --config-dir "$PAIR_HOME/zellij" attach "$SESSION"
    cleanup_quit_marker
    exit $?
fi

# Create branch. Validate the agent here (deferred past the picker so attach
# paths work even when AGENT isn't a real binary on PATH — e.g. attaching
# to a custom-named session whose tag happens to match a non-command).
if ! command -v "$AGENT" >/dev/null 2>&1; then
    echo "pair: agent '$AGENT' not found on PATH." >&2
    echo "      install it first, then re-run." >&2
    exit 1
fi

# Prompt for a session name. Default = auto-suggested next-free name. Empty
# input keeps the default; a typed value (with any leading `pair-` stripped)
# becomes the new tag. Reads from /dev/tty so the prompt works even when
# stdin is redirected.
default_session="pair-${chosen_tag}"
printf 'Session name [%s]: ' "$default_session" >/dev/tty
if read -r user_input </dev/tty; then
    if [ -n "$user_input" ]; then
        case "$user_input" in
            pair-*) typed_tag="${user_input#pair-}" ;;
            *)      typed_tag="$user_input" ;;
        esac
        case "$typed_tag" in
            ""|*[!A-Za-z0-9_-]*)
                echo "pair: invalid name '$user_input'." >&2
                echo "      allowed: letters, digits, dash, underscore." >&2
                exit 1
                ;;
        esac
        if zellij list-sessions --short 2>/dev/null | grep -qx "pair-${typed_tag}"; then
            echo "pair: session 'pair-${typed_tag}' already exists." >&2
            exit 1
        fi
        chosen_tag="$typed_tag"
    fi
else
    # EOF (Ctrl+D) — bail cleanly
    echo >/dev/tty
    exit 0
fi

export PAIR_TAG="$chosen_tag"
SESSION="pair-${PAIR_TAG}"
DRAFT="$HOME/scratch/pair-draft-${PAIR_TAG}.md"
[ -f "$DRAFT" ] || : > "$DRAFT"

# Set terminal title — harmless duplicate for new sessions (zellij sets it
# itself), useful as a uniform path for both create and attach branches.
printf '\033]0;%s\007' "$SESSION"

# Note on the create invocation: zellij's `--layout PATH --session NAME` does
# NOT create-with-layout; per its help text, when --session is set, --layout
# is treated as "add a tab to the session named NAME" and errors if the
# session doesn't exist. The right flag is --new-session-with-layout (-n).
zellij \
    --config-dir              "$PAIR_HOME/zellij" \
    --new-session-with-layout "$PAIR_HOME/zellij/layouts/main.kdl" \
    --session                 "$SESSION"
cleanup_quit_marker
