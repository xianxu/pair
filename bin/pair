#!/usr/bin/env bash
# pair — launch a zellij session split between a TUI coding agent (top pane)
# and an nvim drafting pane (bottom). See README.md.
#
# Usage:
#   pair                       claude in default session
#   pair <agent>               claude / codex / gemini
#   pair [<agent>] -- <args>   forward args to agent on create,
#                              e.g. pair claude -- --resume
#                                   pair -- --dangerously-skip-permissions
#                                   pair codex -- -p "say hi"
#   pair -h, --help            show help
#
# When detached pair-* sessions exist, an fzf picker is shown so the user
# explicitly chooses what to do — no silent auto-attach. The picker shows
# ALL detached pair-* sessions regardless of agent argument; the agent
# argument only matters for the create path (sentinel label, default name,
# binary to exec).

set -euo pipefail

# Wrap zellij with a hard timeout for read-only IPC. The daemon socket can
# wedge if an earlier client got stuck (seen 2026-05-06: a `list-sessions`
# from hours prior held the socket and every new pair launch piled up behind
# it). pair makes several of these per launch, so one wedge cascades into
# unkillable bash trees. 5s is generous — healthy responses are <100ms; if
# it doesn't return by then, something's wrong and falling through is better
# than hanging. Long-running zellij invocations (attach, new-session) are
# intentionally NOT wrapped — they're meant to block.
zj() {
    local secs=5
    if command -v gtimeout >/dev/null 2>&1; then
        gtimeout "$secs" zellij "$@"
    elif command -v timeout >/dev/null 2>&1; then
        timeout "$secs" zellij "$@"
    else
        # Pure-bash fallback for systems without coreutils' timeout (default
        # macOS). Run zellij in the background, arm a watchdog, wait.
        #
        # The watchdog's stdio is redirected to /dev/null. Otherwise, in a
        # pipeline like `zj list-sessions | awk ...`, the watchdog subshell
        # inherits stdout = pipe-to-awk; when we SIGTERM it after zellij
        # exits, bash dies but the orphan `sleep` child keeps the pipe FD
        # open, so awk waits for EOF until the full $secs elapses. With N
        # piped zj calls in pair's startup, that compounds (we saw N×5s).
        zellij "$@" &
        local pid=$!
        ( sleep "$secs"; kill -9 "$pid" 2>/dev/null ) </dev/null >/dev/null 2>&1 &
        local watchdog=$!
        local rc=0
        wait "$pid" 2>/dev/null || rc=$?
        kill "$watchdog" 2>/dev/null || true
        wait "$watchdog" 2>/dev/null || true
        return $rc
    fi
}

# --- help -------------------------------------------------------------------
case "${1:-}" in
    -h|--help|help)
        cat <<'EOF'
pair — Neovim-backed input field for any TUI coding agent.

USAGE
  pair                          claude in default session
  pair <agent>                  e.g. pair codex / pair gemini
  pair resume <tag>             attach pair-<tag> if it exists, else create
                                with that tag and the saved config; agent
                                is inferred from saved state
  pair [<agent>] -- <args>      forward args to the agent on create
                                e.g. pair claude -- --resume
                                     pair -- --dangerously-skip-permissions
                                     pair codex -- -p "say hi"
  pair list                     list pair-* sessions and their attach state
  pair -h, --help               this message

  Use `--` to separate pair's args from the agent's args. Without `--`,
  pair only accepts `<agent>` as a positional (or `resume <tag>`).

  When creating a new session you'll be prompted for a name; type any
  custom name (e.g. "bugfix") to make it independent of other sessions.
  `resume <tag>` skips that prompt — use it to restart a saved tag with
  its captured args (and the agent's session if still on disk).

  Agent args (after `--`) only apply on CREATE. Reattaching to an
  existing session uses whatever args the agent was originally started
  with — the picker doesn't re-launch the agent.

BEHAVIOR
  Picker shows ALL detached pair-* sessions, regardless of the agent
  argument. The agent argument only controls what gets created if you
  pick the "+ new" sentinel: it labels the sentinel, drives the auto-
  suggested name, and is the binary that gets exec'd.

    0 detached → create a new session (prompts for name; default is
                 auto-generated like pair-claude-2)
    ≥1 detached → fzf picker over every detached pair-* session, plus a
                  "+ new <agent> session" sentinel. Picking attaches;
                  picking the sentinel falls through to the create flow.

  No silent attach. Every reattach is explicit.

KEYBINDINGS (inside a pair session)
  Alt+Return    send nvim buffer to agent + Enter, log, clear, insert mode
  Alt+← / Alt+→ walk through prompt history (-N) ↔ draft (*) ↔ queue (+N)
  Shift+Alt+← / Shift+Alt+→
                jump to next region boundary (oldest-history / newest-history /
                * / front-of-queue / back-of-queue)
  Alt+q         push current buffer to queue front (+1)
                from *: parks the draft. from -N: forks. from +N: move-to-front
  Alt+BS        (at +N) delete the current queued prompt; items shift down,
                so tap-tap deletes a run
  Shift+Alt+BS  erase history + draft + queue ("start anew"); confirms first
  Alt+↑ / Alt+↓ step nvim pane along minimized ↔ 12 lines ↔ 1/2 ladder
                (works from either pane). minimized = statusline only;
                Alt+↑ from there grows the pane back. Confirm-requiring
                keys (Alt+x/d/n/N) auto-grow out of minimized first so
                the prompt is visible.
  Alt+d         detach from session (re-attach later via `pair`)
  Alt+x         full quit — kill session and remove from resurrect list
                (Ctrl+q is unbound; Alt+x is the only quit path)
  Alt+n         reload pair — kill the session and re-launch in place
                with the same tag, agent, args, AND agent session.
                The conversation resumes; pair itself is the only
                thing that restarts (useful after a config or binary
                rebuild)
  Shift+Alt+N   restart with a fresh agent conversation — same tag,
                agent, and args, but the saved per-(tag,agent) config
                is dropped so the agent starts a brand-new session
  Alt+h         pop up this help in a floating pane (press `q` to dismiss)
  Alt+i         attach clipboard image to agent + insert whatever marker
                the agent renders (e.g. claude `[Image #N]`, gemini
                `[Image N-M]`). Captured from pair-wrap's PTY stream so
                no per-agent format knowledge is baked in. Flashes
                "[no image in clipboard]" at cursor for 1s if the OS
                clipboard has no image data.
  Alt+/         open agent pane scrollback in a read-only ANSI-colored
                nvim viewer; line numbers match zellij's frame indicator,
                so e.g. `:880` jumps to the line you saw scrolled to 880.
                Inside the viewer, Alt+q drops a 🤖[comment] marker —
                bare in normal mode (the line is the context) or
                🤖<selection>[comment] in visual mode. On :q, all
                markers are formatted (`> <quote>\n<comment>`) and
                appended to the draft for review + send

  Status line shows `H < pos > Q` — history count, current slot, queue
  count. A dirty `-N*` mark on history means a pending fork; navigating
  away prompts: (S)end, (Q)ueue, (D)iscard, [S]tay.

DRAFT SYNTAX
  ===  comment  Whole lines starting with `===` are stripped at send time
                but kept in draft/queue/log. Use them to annotate why a
                queued prompt exists. Mid-line `===` is unaffected.

FILES
  ${XDG_DATA_HOME:-~/.local/share}/pair/draft-<tag>.md     persistent draft (*)
  ${XDG_DATA_HOME:-~/.local/share}/pair/log-<tag>.md       prompt history (-N)
  ${XDG_DATA_HOME:-~/.local/share}/pair/queue-<tag>/*.md   queued prompts (+N)

See README.md for image-paste recipes and other details.
EOF
        exit 0
        ;;
    list|ls)
        if ! command -v zellij >/dev/null 2>&1; then
            echo "pair: zellij not found on PATH." >&2
            exit 1
        fi
        # Snapshot session state once. --no-formatting carries the EXITED
        # annotation; --short gives clean newline-separated names.
        raw=$( { zj list-sessions --no-formatting 2>/dev/null || true; } )
        sessions=$( { zj list-sessions --short 2>/dev/null || true; } \
                    | awk '/^pair-/' \
                    | sort )
        if [ -z "$sessions" ]; then
            echo "no pair sessions"
            exit 0
        fi
        list_data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/pair"
        mkdir -p "$list_data_dir"

        # Backfill agent-<tag> for any running pair-wrap process whose tag
        # we don't yet have on disk — covers sessions created before the
        # agent-tracking feature shipped. Read PAIR_TAG from each process's
        # environ (macOS: `ps -E`; Linux: /proc/<pid>/environ) and the
        # agent name from argv (the token after `pair-wrap`).
        pw_pids=$(pgrep -f 'pair-wrap' 2>/dev/null || true)
        for pid in $pw_pids; do
            argv=$(ps -p "$pid" -o command= 2>/dev/null || true)
            [ -z "$argv" ] && continue
            agent=$(printf '%s\n' "$argv" | awk '
                { for (i=1; i<=NF; i++) if ($i ~ /pair-wrap$/) { print $(i+1); exit } }')
            [ -z "$agent" ] && continue
            if [ -r "/proc/$pid/environ" ]; then
                env_blob=$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null || true)
            else
                env_blob=$( { ps -wwEp "$pid" -o command= 2>/dev/null \
                              || ps eww -p "$pid" 2>/dev/null \
                              || true; } )
            fi
            tag=$(printf '%s' "$env_blob" \
                  | tr ' \0' '\n\n' \
                  | awk -F= '$1=="PAIR_TAG"{print $2; exit}')
            [ -z "$tag" ] && continue
            if [ ! -f "$list_data_dir/agent-${tag}" ]; then
                printf '%s\n' "$agent" > "$list_data_dir/agent-${tag}"
            fi
        done

        printf '%-30s %-10s %s\n' "SESSION" "AGENT" "STATUS"
        while IFS= read -r sess; do
            [ -z "$sess" ] && continue
            tag="${sess#pair-}"
            agent_file="$list_data_dir/agent-${tag}"
            if [ -f "$agent_file" ]; then
                agent=$(head -n1 "$agent_file" | tr -d '\r\n[:space:]')
                [ -z "$agent" ] && agent="?"
            else
                agent="?"
            fi
            if printf '%s\n' "$raw" \
                 | grep -E "^${sess}[[:space:]].*EXITED" >/dev/null 2>&1; then
                status="exited"
            else
                # `|| true` so pipefail+errexit doesn't abort when zellij
                # can't reach the session (e.g. running outside any zellij
                # client); empty input through tail/wc yields 0.
                clients=$( { zj --session "$sess" action list-clients 2>/dev/null || true; } \
                          | tail -n +2 | wc -l | tr -d ' ')
                clients=${clients:-0}
                if [ "$clients" -eq 0 ]; then
                    status="detached"
                elif [ "$clients" -eq 1 ]; then
                    status="attached (1 client)"
                else
                    status="attached ($clients clients)"
                fi
            fi
            printf '%-30s %-10s %s\n' "$sess" "$agent" "$status"
        done <<< "$sessions"
        exit 0
        ;;
esac

# Resolve this script's real path portably (macOS lacks `readlink -f`).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
PAIR_HOME="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
export PAIR_HOME

# Put pair's bin/ on PATH so zellij can resolve our helper scripts by bare
# name (clipboard-to-pane.sh, copy-on-select.sh) without sh-c env-var hacks
# in zellij/config.kdl. Avoid double-prepending across re-launches.
case ":$PATH:" in
    *":$PAIR_HOME/bin:"*) ;;
    *) export PATH="$PAIR_HOME/bin:$PATH" ;;
esac

# Parse argv. First positional is the agent name (default `claude`).
# Anything after `--` is forwarded to the agent on create. The `--`
# separator is required to disambiguate "agent name" from "flag for the
# agent" — without it, `pair --dangerously-skip-permissions` is ambiguous
# (is `--dangerously-skip-permissions` the agent or a flag?).
#
#   pair                                  → claude
#   pair claude                           → claude
#   pair claude -- --resume               → claude --resume
#   pair -- --resume                      → claude --resume
#   pair codex -- -p "hi"                 → codex -p hi   (word-split caveat)
AGENT=""
agent_extra=""
forced_tag=""
agent_explicit=false  # true if AGENT was set from a positional CLI arg

# `pair resume <tag>` is the documented restart path: skip both the picker
# and the name prompt, attach if pair-<tag> exists, otherwise create with
# that tag. We claim `resume` as a subcommand verb — it can't be a real
# agent binary (too generic a name), and we already special-case `list`
# and `help` similarly above.
if [ "${1:-}" = "resume" ]; then
    if [ -z "${2:-}" ]; then
        echo "pair: 'resume' requires a tag (e.g. pair resume bugfix)" >&2
        exit 1
    fi
    forced_tag="$2"
    case "$forced_tag" in
        pair-*) forced_tag="${forced_tag#pair-}" ;;
    esac
    case "$forced_tag" in
        ""|*[!A-Za-z0-9_-]*)
            echo "pair: invalid tag '$2'." >&2
            echo "      allowed: letters, digits, dash, underscore." >&2
            exit 1
            ;;
    esac
    shift 2
fi

seen_dd=false
for arg in "$@"; do
    if $seen_dd; then
        if [ -z "$agent_extra" ]; then
            agent_extra="$arg"
        else
            agent_extra="$agent_extra $arg"
        fi
    elif [ "$arg" = "--" ]; then
        seen_dd=true
    elif [ -z "$AGENT" ] && [ -z "$forced_tag" ]; then
        AGENT="$arg"
        agent_explicit=true
    else
        echo "pair: unexpected positional arg '$arg' (use '--' to forward args to the agent)" >&2
        echo "      e.g. pair claude -- --resume" >&2
        exit 1
    fi
done

# PAIR_FORCE_TAG is set by the Alt+n / Shift+Alt+N restart flow
# (handle_restart_marker below): it pins the new run to the same tag as
# the killed session, skipping both the picker and the name prompt.
# Treated as forced_tag from here on; unset so a child process doesn't
# inherit it.
if [ -z "$forced_tag" ] && [ -n "${PAIR_FORCE_TAG:-}" ]; then
    forced_tag="$PAIR_FORCE_TAG"
fi
unset PAIR_FORCE_TAG
# Defer the [-z AGENT] default to after DATA_DIR is set: when `resume <tag>`
# is used we infer the agent from saved state on disk so a single tag is
# enough to fully restart, regardless of which agent was originally paired
# with it.

# default_tag drives the auto-suggestion in the create-flow name prompt
# and the picker's "+ new <tag> session" sentinel. The interactive prompt
# and `resume <tag>` both override this.
#
# When the user explicitly named an agent on the CLI (`pair gemini`,
# `pair codex`, ...), use the agent name — that's the most likely
# intent ("a gemini session here"). When agent was implicit (just
# `pair`, defaults to claude), use the cwd basename so multiple repos
# don't collapse onto the same default.
if $agent_explicit; then
    default_tag="$AGENT"
else
    default_tag="$(basename "$PWD")"
fi
default_tag="${default_tag//[^A-Za-z0-9_-]/_}"
[ -z "$default_tag" ] && default_tag="pair"

if ! command -v zellij >/dev/null 2>&1; then
    echo "pair: zellij not found on PATH." >&2
    echo "      brew install zellij  (or your package manager equivalent)" >&2
    exit 1
fi

# Refuse to launch from inside an existing zellij session. Nested sessions
# don't compose — `--session NAME` from inside zellij triggers attach, not
# create, which fails confusingly when the named session doesn't exist yet.
#
# Detection via process-ancestry walk, NOT env vars. cmux propagates the
# focused pane's env (including ZELLIJ / ZELLIJ_SESSION_NAME / ZELLIJ_PANE_ID)
# to every other pane it spawns, so a standalone ghostty pane next to a
# pair pane inherits stale ZELLIJ_SESSION_NAME and used to trigger this
# check as a false positive. Walking the PPID chain looking for a
# `zellij` ancestor is the ground truth: it's true iff this shell is
# actually a descendant of a zellij process.
in_zellij_pane() {
    local pid=$$
    local cmd parent
    while [ "$pid" -gt 1 ]; do
        cmd=$(ps -o comm= -p "$pid" 2>/dev/null | tr -d ' ')
        case "${cmd##*/}" in
            zellij) return 0 ;;
        esac
        parent=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
        [ -z "$parent" ] && return 1
        [ "$parent" = "$pid" ] && return 1
        pid="$parent"
    done
    return 1
}
if in_zellij_pane; then
    echo "pair: already running inside a zellij session." >&2
    echo "      detach first (Alt+d) or run pair from a fresh terminal." >&2
    exit 1
fi

# Resolve XDG data dir for pair's drafts and per-tag prompt logs.
# Honors $XDG_DATA_HOME with the spec-defined fallback.
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/pair"
mkdir -p "$DATA_DIR"
export PAIR_DATA_DIR="$DATA_DIR"

# --- nvim --embed orphan reaping --------------------------------------------
#
# `nvim FILE` is internally a TUI parent + `nvim --embed` server child wired
# by an RPC stdio pipe. When the parent dies, the embed sometimes survives
# the pipe EOF and gets reparented to launchd. Each orphan keeps its full
# buffer + lua state (~30 MB resident); at 100+ orphans the host hits
# memory pressure that makes plain shell prompts lag for seconds.
#
# Two callers reap, both via reap_nvim_for_tag:
#   - cleanup_quit_marker (Alt+x path) — reaps the just-quit tag.
#   - sweep_orphan_nvim (this file, called once at startup) — reaps any
#     tag whose pair-<tag> session is no longer alive. Covers external
#     terminations (`zellij kill-session`, host reboot, pair upgrade
#     mid-session) that left no quit marker, so cleanup_quit_marker
#     never ran for them.

reap_nvim_for_tag() {
    local tag="$1" kind pf pid
    # Primary path is deterministic. nvim/init.lua + nvim/scrollback.lua
    # register a VimEnter autocmd that writes getpid() (the embed pid;
    # lua runs inside the embed) to $PAIR_NVIM_PID_FILE; launch sites
    # (zellij/layouts/main.kdl, bin/pair-scrollback-open) point that env
    # var at $DATA_DIR/nvim-pid-<tag>-<kind>.
    for kind in draft scrollback; do
        pf="$DATA_DIR/nvim-pid-${tag}-${kind}"
        if [ -f "$pf" ]; then
            pid=$(tr -d '[:space:]' < "$pf" 2>/dev/null || true)
            [ -n "$pid" ] && kill -9 "$pid" >/dev/null 2>&1 || true
            rm -f "$pf"
        fi
    done
    # Belt-and-suspenders for the missing-pidfile case (autocmd errored
    # before VimEnter, or pair upgraded mid-session and the older pane
    # wrote no pidfile — this is how the 4 orphans on the host that
    # prompted this change had to be found). Scoped to this tag's
    # DATA_DIR file so unrelated nvim --embed instances are untouched.
    # Two calls because macOS pkill -f uses BRE; (a|b) isn't portable.
    pkill -9 -f "nvim --embed.*${DATA_DIR}/draft-${tag}\.md\$" >/dev/null 2>&1 || true
    pkill -9 -f "nvim --embed.*${DATA_DIR}/scrollback-${tag}-" >/dev/null 2>&1 || true
}

# Reap nvim --embed processes whose pair-<tag> session is no longer alive.
# Reads $all_pair (set just before this is called in the main flow) for
# the live set. Cheap when nothing to do (~one ps + a few stat calls).
sweep_orphan_nvim() {
    local live tag pf fname argv
    live=$(printf '%s\n' "${all_pair:-}" | sed -n 's/^pair-//p')
    {
        for pf in "$DATA_DIR"/nvim-pid-*-draft "$DATA_DIR"/nvim-pid-*-scrollback; do
            [ -e "$pf" ] || continue
            fname=$(basename "$pf")
            tag=${fname#nvim-pid-}
            tag=${tag%-draft}
            tag=${tag%-scrollback}
            printf '%s\n' "$tag"
        done
        # `ps -ww -A -o args=` prints full untruncated argv, one line per
        # process. Catches orphans with no pidfile — without this the
        # sweep misses any embed launched before f95f71c (commit that
        # added the autocmd) or whose autocmd errored before VimEnter.
        while IFS= read -r argv; do
            case "$argv" in
                *nvim*--embed*"$DATA_DIR/draft-"*)
                    tag=${argv##*"$DATA_DIR/draft-"}
                    tag=${tag%% *}
                    tag=${tag%.md}
                    printf '%s\n' "$tag"
                    ;;
                *nvim*--embed*"$DATA_DIR/scrollback-"*)
                    tag=${argv##*"$DATA_DIR/scrollback-"}
                    tag=${tag%% *}
                    tag=${tag%.ansi}
                    # Filename shape: scrollback-<tag>-<agent>.ansi —
                    # strip trailing -<agent> to recover <tag>.
                    tag=${tag%-*}
                    printf '%s\n' "$tag"
                    ;;
            esac
        done < <(ps -ww -A -o args= 2>/dev/null || true)
    } | sort -u | while IFS= read -r tag; do
        [ -z "$tag" ] && continue
        if ! printf '%s\n' "$live" | grep -qx "$tag"; then
            reap_nvim_for_tag "$tag"
        fi
    done
}

# Agent inference for `pair resume <tag>`: look up what was paired with
# this tag last time. agent-<tag> covers live (or recently detached)
# sessions — written at create-flow start, cleared on Alt+x.
# config-<tag>-<agent>.json (issue #000016) covers the case where the
# session was Alt+x'd: that file persists across quit and the filename
# encodes the agent. Either source is authoritative.
if [ -n "$forced_tag" ] && [ -z "$AGENT" ]; then
    if [ -f "$DATA_DIR/agent-${forced_tag}" ]; then
        AGENT=$(cat "$DATA_DIR/agent-${forced_tag}")
    else
        for cfg in "$DATA_DIR"/config-"${forced_tag}"-*.json; do
            [ -f "$cfg" ] || continue
            inferred=$(jq -r '.agent // empty' "$cfg" 2>/dev/null)
            if [ -n "$inferred" ]; then
                AGENT="$inferred"
                break
            fi
        done
    fi
fi
[ -z "$AGENT" ] && AGENT="claude"

# PAIR_AGENT is the command to exec in the agent pane on create.
# PAIR_AGENT_ARGS is appended on the agent pane's command line at create.
#   It applies only on create; reattaching to an existing session uses
#   whatever args the agent was originally launched with.
export PAIR_AGENT="$AGENT"
export PAIR_AGENT_ARGS="$agent_extra"

# PAIR_PANE_TITLE drives the agent pane's frame title in zellij. The
# layout's `pane name="agent"` is just a matching anchor; the layout's
# args block calls `zellij action rename-pane "$PAIR_PANE_TITLE"`
# before exec'ing pair-wrap, so the frame shows the agent's capitalized
# name (Claude / Codex / Gemini) instead of a generic "agent".
case "$AGENT" in
    claude) export PAIR_PANE_TITLE="Claude" ;;
    codex)  export PAIR_PANE_TITLE="Codex" ;;
    gemini) export PAIR_PANE_TITLE="Gemini" ;;
    *)      export PAIR_PANE_TITLE="$AGENT" ;;
esac

# PAIR_TAG is the namespace identifier — used to name the zellij session
# and the per-instance draft/log files. The create flow's interactive
# prompt and `resume <tag>` override this.
export PAIR_TAG="$default_tag"

# One-time migration: if old ~/scratch/pair-{draft,log}-*.md files exist,
# move them to the new XDG location with the redundant `pair-` prefix
# stripped (since they're already inside the pair/ dir). Idempotent.
if [ -d "$HOME/scratch" ]; then
    moved=0
    for old in "$HOME/scratch"/pair-draft-*.md "$HOME/scratch"/pair-log-*.md; do
        [ -e "$old" ] || continue
        base="$(basename "$old")"
        new="$DATA_DIR/${base#pair-}"
        if [ ! -e "$new" ]; then
            mv "$old" "$new" && moved=$((moved + 1))
        fi
    done
    if [ "$moved" -gt 0 ]; then
        echo "pair: migrated $moved file(s) from ~/scratch/ to $DATA_DIR" >&2
    fi
fi

BASE_TAG="$PAIR_TAG"

# Find ALL detached pair-* sessions, regardless of agent. The agent argument
# (and BASE_TAG) is only used for the create path's defaults; the picker
# itself shows everything you might want to reattach to, including custom-
# named sessions like pair-blogging that don't follow any agent prefix.
# `zellij list-sessions` exits 1 when there are no sessions, and with
# `set -euo pipefail` that would silently kill the whole script. Wrap the
# zellij call in `|| true` and use awk (returns 0 even on no matches)
# instead of grep (returns 1 on no matches).
all_pair=$( { zj list-sessions --short 2>/dev/null || true; } \
            | awk '/^pair-/' \
            | sort )

# With the live-session set in hand, reap any nvim --embed left behind by
# a tag whose pair-<tag> session is gone — external `zellij kill-session`,
# host reboot, or pair upgrade leave no Alt+x marker, so cleanup_quit_marker
# never runs and these embeds accumulate. Definition near $DATA_DIR setup.
sweep_orphan_nvim

detached_list=()
while IFS= read -r sess; do
    [ -z "$sess" ] && continue
    if zj list-sessions --no-formatting 2>/dev/null \
        | grep -E "^${sess}[[:space:]].*EXITED" >/dev/null 2>&1; then
        continue   # exited, skip
    fi
    clients=$(zj --session "$sess" action list-clients 2>/dev/null \
              | tail -n +2 | wc -l | tr -d ' ')
    if [ "${clients:-0}" -eq 0 ]; then
        detached_list+=("$sess")
    fi
done <<< "$all_pair"

# Compute the next-free numeric slot in the agent's family — pair-<base>,
# then pair-<base>-2, ... — used as the prompt's default name on create. This
# checks against ALL existing sessions (not just family) to avoid clobbering
# anything that happens to share the slot's name.
free_slot_tag=""
i=1
while [ "$i" -le 100 ]; do
    if [ "$i" -eq 1 ]; then
        cand="pair-${BASE_TAG}"
    else
        cand="pair-${BASE_TAG}-${i}"
    fi
    if ! zj list-sessions --short 2>/dev/null | grep -qx "$cand"; then
        free_slot_tag="${cand#pair-}"
        break
    fi
    i=$((i + 1))
done

# Decide. Picker for any ≥1 detached; create directly only when none exist.
chosen_session=""
chosen_tag=""
action=""   # "attach" | "create"

# `pair resume <tag>` short-circuits both the picker and the name prompt:
# attach if pair-<tag> already exists in any state, otherwise create with
# that tag. This is the "resume by name" path — pair off the hint printed
# at Alt+x.
if [ -n "$forced_tag" ]; then
    if zj list-sessions --short 2>/dev/null | grep -qx "pair-${forced_tag}"; then
        chosen_session="pair-${forced_tag}"
        chosen_tag="$forced_tag"
        action=attach
    else
        chosen_tag="$forced_tag"
        action=create
    fi
elif [ ${#detached_list[@]} -eq 0 ]; then
    chosen_tag="$free_slot_tag"
    action=create
else
    new_label="+ new ${BASE_TAG} session"
    options=$(printf '%s\n' "${detached_list[@]}"; printf '%s\n' "$new_label")
    if command -v fzf >/dev/null 2>&1; then
        picked=$(printf '%s' "$options" | fzf --prompt='pair> ' --height=10 --reverse) || exit 0
    else
        echo "Detached pair sessions:"
        printf '%s' "$options" | nl
        printf 'Pick: '
        read -r idx
        picked=$(printf '%s' "$options" | sed -n "${idx}p")
    fi
    [ -z "$picked" ] && exit 0

    if [ "$picked" = "$new_label" ]; then
        chosen_tag="$free_slot_tag"
        action=create
    else
        chosen_session="$picked"
        chosen_tag="${chosen_session#pair-}"
        action=attach
    fi
fi

if [ -z "$chosen_tag" ]; then
    echo "pair: couldn't determine a session to use; bailing." >&2
    exit 1
fi

# Helper: after zellij returns, check for the Alt+x marker. If present, the
# user asked for a full quit — delete the session entry from the resurrect
# list. (Ctrl+q is unbound in pair, so Alt+x is the only quit path; Alt+d
# is detach, which keeps the session alive and leaves no marker.)
cleanup_quit_marker() {
    local marker="$HOME/.cache/pair/quit-$SESSION"
    if [ -f "$marker" ]; then
        rm -f "$marker"
        # Capture the agent BEFORE the file is cleared below, so the resume
        # hint can name the right binary.
        local quit_agent
        quit_agent=$(cat "$DATA_DIR/agent-${PAIR_TAG}" 2>/dev/null || echo "$AGENT")
        zj delete-session "$SESSION" --force >/dev/null 2>&1 || true
        # Defensive belt-and-suspenders: if a zellij --server process for this
        # session is still alive after delete-session (rare but seen — e.g.
        # the server lingered in a no-clients state and re-registered the
        # session record on its next heartbeat), SIGKILL it. Pattern matches
        # the socket path component, scoped to this session only.
        pkill -9 -f "zellij --server .*/${SESSION}\$" >/dev/null 2>&1 || true
        # Reap this tag's nvim --embed children. See reap_nvim_for_tag and
        # the orphan-reaping block near $DATA_DIR setup for the full story
        # on why these survive pane death and need explicit cleanup.
        reap_nvim_for_tag "$PAIR_TAG"
        rm -f "$DATA_DIR/outer-tty-${PAIR_TAG}" "$DATA_DIR/agent-${PAIR_TAG}" \
              "$DATA_DIR/agent-output-${PAIR_TAG}" \
              "$DATA_DIR/scrollback-${PAIR_TAG}-${quit_agent}.raw" \
              "$DATA_DIR/scrollback-${PAIR_TAG}-${quit_agent}.events.jsonl" \
              "$DATA_DIR/scrollback-${PAIR_TAG}-${quit_agent}.ansi" \
              "$DATA_DIR/pair-wrap-pid-${PAIR_TAG}" \
              "$DATA_DIR/image-capture-${PAIR_TAG}" \
              "$DATA_DIR/image-capture-${PAIR_TAG}.done"

        # If the watcher captured a session config for this (tag, agent),
        # show the user the one-liner that resumes it. config-<tag>-<agent>
        # is what the create-flow prompt reads — its presence here is the
        # signal that the resume path will work next time.
        #
        # Display SESSION (e.g. pair-2) rather than PAIR_TAG ("2") to match
        # what the user saw in the UI tab; the `resume` subcommand accepts
        # both forms (it strips a leading `pair-`). Agent is omitted from
        # the resume command — pair infers it from the saved state.
        if [ -f "$DATA_DIR/config-${PAIR_TAG}-${quit_agent}.json" ]; then
            local saved_sid=""
            saved_sid=$(jq -r '.session_id // empty' \
                "$DATA_DIR/config-${PAIR_TAG}-${quit_agent}.json" 2>/dev/null || true)
            printf 'pair: saved session config for tag "%s" (%s).\n' \
                "$SESSION" "$quit_agent"
            printf '      resume with: pair resume %s\n' "$SESSION"
            # Surface the agent session id too: useful when the user
            # wants to drive the agent directly (`claude --resume <id>`,
            # `codex resume <id>`) without going back through pair.
            if [ -n "$saved_sid" ]; then
                printf '      session id:  %s\n' "$saved_sid"
            fi
        fi

        # Kill the cmux activity-prefix poller for this tag (if running)
        # so its next 60s tick doesn't race with the cwd-rename below.
        local poller_pid_file="$DATA_DIR/cmux-title-pid-${PAIR_TAG}"
        if [ -f "$poller_pid_file" ]; then
            local poller_pid
            poller_pid=$(cat "$poller_pid_file" 2>/dev/null)
            [ -n "$poller_pid" ] && kill "$poller_pid" 2>/dev/null || true
            rm -f "$poller_pid_file"
        fi

        # Reset the cmux workspace title to the shell's cwd basename —
        # this pair session is dead and the user is back at a plain
        # shell prompt; the workspace label should reflect that instead
        # of the just-killed pair-<tag>. On Alt+n / Shift+Alt+N the
        # follow-up re-exec immediately re-renames to the new SESSION,
        # so the cwd flash here is invisible.
        local reset_title
        reset_title=$(basename "$PWD" 2>/dev/null)
        [ -n "$reset_title" ] || reset_title="shell"
        cmux_rename_workspace "$reset_title"
    fi
}

# After cleanup_quit_marker, check for the restart marker written by
# pair-restart.sh. Two flavors:
#
#   Alt+n         — pure pair reload. Same tag + agent + args + agent
#                   session. The saved config is kept and the new run
#                   resumes the prior conversation via --resume <id>
#                   (claude/gemini) or `resume <id>` (codex).
#   Shift+Alt+N   — same tag + agent + args, fresh agent conversation:
#                   we drop the saved per-(tag,agent) config so the new
#                   run starts a brand-new session.
#
# Both flavors pin the same tag via PAIR_FORCE_TAG. The agent name comes
# from the marker (captured before cleanup_quit_marker wiped agent-<tag>);
# agent args + session id come from the saved config.
handle_restart_marker() {
    local marker="$HOME/.cache/pair/restart-$SESSION"
    [ -f "$marker" ] || return 0

    local r_tag r_agent r_new_session
    r_tag=$(awk -F= '$1=="tag"{print $2; exit}' "$marker")
    r_agent=$(awk -F= '$1=="agent"{print $2; exit}' "$marker")
    r_new_session=$(awk -F= '$1=="new_session"{print $2; exit}' "$marker")
    rm -f "$marker"

    [ -z "$r_tag" ] && r_tag="$PAIR_TAG"
    [ -z "$r_agent" ] && r_agent="$AGENT"

    local r_args="" r_sid=""
    local cfg="$DATA_DIR/config-${r_tag}-${r_agent}.json"
    if [ -f "$cfg" ] && command -v jq >/dev/null 2>&1; then
        r_args=$(jq -r '(.args // []) | join(" ")' "$cfg" 2>/dev/null || true)
        r_sid=$(jq -r '.session_id // empty' "$cfg" 2>/dev/null || true)
    fi

    export PAIR_FORCE_TAG="$r_tag"

    if [ "$r_new_session" = "1" ]; then
        # Fresh conversation: drop the config so the next launch doesn't
        # offer (or auto-pick) the prior session id.
        rm -f "$cfg"
        if [ -n "$r_args" ]; then
            # shellcheck disable=SC2086
            exec "$0" "$r_agent" -- $r_args
        else
            exec "$0" "$r_agent"
        fi
    fi

    # Default Alt+n: keep config, append the resume token so the new
    # launch picks up exactly where we left off without going through
    # the picker. Surface differs per agent — claude/gemini use the
    # `--resume <id>` flag, codex uses the `resume <id>` subcommand.
    local resume_extra=""
    if [ -n "$r_sid" ]; then
        case "$r_agent" in
            claude|gemini) resume_extra="--resume $r_sid" ;;
            codex)         resume_extra="resume $r_sid" ;;
        esac
    fi
    local combined="${r_args}${r_args:+${resume_extra:+ }}${resume_extra}"
    if [ -n "$combined" ]; then
        # shellcheck disable=SC2086
        exec "$0" "$r_agent" -- $combined
    else
        exec "$0" "$r_agent"
    fi
}

# Capture pair's controlling TTY before zellij takes over — this IS the path
# of the outer terminal/wrapper's PTY. Writing OSC sequences to it bypasses
# zellij's escape filtering, letting outer wrappers (e.g. cmux, which watches
# OSC 9/777 to surface attention indicators) see notifications emitted from
# inside a pane. Refreshed on every attach because the outer PTY changes
# across detach/reattach; pane-shell env doesn't (env is frozen at zellij
# session-creation time). #000011
record_outer_tty() {
    local outer
    outer="$(tty 2>/dev/null || true)"
    case "$outer" in
        /dev/*) printf '%s\n' "$outer" > "$DATA_DIR/outer-tty-${PAIR_TAG}" ;;
        *)      rm -f "$DATA_DIR/outer-tty-${PAIR_TAG}" ;;
    esac
}

# Convention: one pair session per cmux workspace, with the cmux
# workspace title mirroring pair's tag. CMUX_WORKSPACE_ID is set by
# cmux inside every pane, so its presence is the "we're inside cmux"
# probe. Best-effort — silent no-op outside cmux or if the rename
# round-trips an error.
cmux_rename_workspace() {
    [ -n "${CMUX_WORKSPACE_ID:-}" ] || return 0
    command -v cmux >/dev/null 2>&1 || return 0
    # Personal display convention: 'brain' → 🧠 anywhere in the title.
    # Applied to every cmux rename (launch + the cwd-reset on quit) so
    # the substitution is uniform regardless of who's calling.
    local title="${1//brain/🧠}"
    cmux rename-workspace "$title" >/dev/null 2>&1 || true
}

if [ "$action" = "attach" ]; then
    export PAIR_TAG="$chosen_tag"
    SESSION="pair-${PAIR_TAG}"
    DRAFT="$DATA_DIR/draft-${PAIR_TAG}.md"
    [ -f "$DRAFT" ] || : > "$DRAFT"
    # Set terminal title — zellij sets this on new-session creation but not
    # on attach, so without this the title stays as whatever the shell's
    # preexec hook set (typically "bin/pair").
    printf '\033]0;%s\007' "$SESSION"
    record_outer_tty
    cmux_rename_workspace "$SESSION"
    # Real agent for this tag may differ from the CLI default — prefer
    # the on-disk record so the activity poller looks at the right
    # session file. Falls back to $AGENT if the record's missing.
    title_agent=$(cat "$DATA_DIR/agent-$PAIR_TAG" 2>/dev/null | tr -d '\r\n[:space:]')
    [ -n "$title_agent" ] || title_agent="$AGENT"
    "$PAIR_HOME/bin/pair-cmux-title.sh" "$PAIR_TAG" "$title_agent" \
        </dev/null >/dev/null 2>&1 &
    # disown so cleanup_quit_marker's `kill <pid>` later doesn't spawn
    # a "[1] Terminated:" line into the user's shell on session exit.
    disown $! 2>/dev/null || true
    zellij --config-dir "$PAIR_HOME/zellij" attach "$SESSION"
    rc=$?
    cleanup_quit_marker
    handle_restart_marker
    exit $rc
fi

# Create branch. Validate the agent here (deferred past the picker so attach
# paths work even when AGENT isn't a real binary on PATH — e.g. attaching
# to a custom-named session whose tag happens to match a non-command).
if ! command -v "$AGENT" >/dev/null 2>&1; then
    echo "pair: agent '$AGENT' not found on PATH." >&2
    echo "      install it first, then re-run." >&2
    exit 1
fi

# Surface any existing sessions in this tag's family (pair-<base> and
# pair-<base>-*) before prompting, so the user can see what's already
# there — and why the auto-suggested prefill may include a numeric
# suffix.
family_prefix="pair-${BASE_TAG}"
family_existing=$( { zj list-sessions --no-formatting 2>/dev/null || true; } \
    | awk -v p="$family_prefix" '$1 == p || index($1, p "-") == 1' )
if [ -n "$family_existing" ]; then
    {
        printf 'Existing %s* sessions:\n' "$family_prefix"
        printf '%s\n' "$family_existing" | sed 's/^/  /'
    } >/dev/tty
fi

# Prompt for a session name. The input line is pre-filled with the auto-
# suggested next-free tag (the `pair-` prefix is implicit and added back
# below) so the user can edit/extend it inline — e.g. with the default
# pre-filled as "pair", typing "1" yields "pair1". Empty input falls back
# to the suggested default.
#
# bash 3.2 (system bash on macOS) lacks `read -i`, so we delegate the
# editable prompt to zsh's `vared`, which is universally available on
# macOS and Linux. The vared editor UI runs on /dev/tty; the captured
# stdout is just the final value.
#
# Skipped when `resume <tag>` is given: forced_tag has already been
# validated and the picker landed us in `create` straight from there.
if [ -z "$forced_tag" ]; then
    if command -v zsh >/dev/null 2>&1; then
        # `zsh -c` boots without sourcing .zshrc, so the line editor's
        # keymap defaults to a raw state where Ctrl-A through Ctrl-F are
        # all `self-insert` — meaning the user couldn't navigate left to
        # edit the prefix of the prefilled tag (only append). `bindkey
        # -e` selects the emacs keymap explicitly, giving the expected
        # arrows / backspace / Ctrl-A / Ctrl-E bindings inside vared.
        if user_input=$(
            zsh -c '
                bindkey -e
                v=$1
                vared -p "Session name: " v
                print -r -- "$v"
            ' _ "$chosen_tag" </dev/tty 2>/dev/tty
        ); then :; else
            echo >/dev/tty
            exit 0
        fi
    else
        # No zsh — fall back to a non-editable [default]-style prompt.
        printf 'Session name [%s]: ' "$chosen_tag" >/dev/tty
        if ! read -r user_input </dev/tty; then
            echo >/dev/tty
            exit 0
        fi
    fi
    user_input="${user_input:-$chosen_tag}"
    case "$user_input" in
        pair-*) typed_tag="${user_input#pair-}" ;;
        *)      typed_tag="$user_input" ;;
    esac
    case "$typed_tag" in
        ""|*[!A-Za-z0-9_-]*)
            echo "pair: invalid name '$user_input'." >&2
            echo "      allowed: letters, digits, dash, underscore." >&2
            exit 1
            ;;
    esac
    if zj list-sessions --short 2>/dev/null | grep -qx "pair-${typed_tag}"; then
        echo "pair: session 'pair-${typed_tag}' already exists." >&2
        exit 1
    fi
    chosen_tag="$typed_tag"
fi

# ---------------------------------------------------------------------------
# Tag-restart prompt (issue #000016)
# ---------------------------------------------------------------------------
# If we have a saved config for (tag, agent) from a prior launch, ask the
# user whether to reuse the saved args (and resume the agent's session if
# the agent's transcript is still on disk). This is the place: the tag has
# just been committed; agent + agent_extra are known; the watcher and
# zellij launch happen below.
#
# fzf is already a hard dep (used for the session picker). Each option line
# spells out the values it will apply so the user can pick without flipping
# context. ESC aborts the create flow — same posture as the name prompt.
# If the user (or Alt+n's restart loop) explicitly passed a resume token
# on argv, the picker has nothing to offer — the choice is already made.
# Same per-agent surface as the explicit_resume detection further below;
# kept inline here to gate the picker without restructuring the flow.
_argv_has_resume=0
case "$AGENT" in
    claude|gemini)
        prev=""
        for tok in $agent_extra; do
            if [ "$prev" = "--resume" ]; then _argv_has_resume=1; break; fi
            prev="$tok"
        done
        ;;
    codex)
        read -r first second _rest <<< "$agent_extra"
        [ "$first" = "resume" ] && [ -n "$second" ] && _argv_has_resume=1
        ;;
esac

config_file="$DATA_DIR/config-${chosen_tag}-${AGENT}.json"
if [ -f "$config_file" ] && [ $_argv_has_resume -eq 0 ]; then
    # Read saved args as a properly-delimited stream; mapfile would be
    # cleaner but is bash 4+ and macOS still ships 3.2.
    saved_args=()
    while IFS= read -r line; do saved_args+=("$line"); done \
        < <(jq -r '.args[]?' "$config_file" 2>/dev/null)
    saved_session=$(jq -r '.session_id // empty' "$config_file" 2>/dev/null)

    # Defensive strip: pair-session-watch.sh and the inline explicit_resume
    # capture both now scrub --resume <id> (and codex's `resume <id>`)
    # before persisting, so freshly-written configs already have clean
    # args. This pass exists for migration — older configs on disk may
    # still carry the resume token and we don't want the picker to
    # display "args=[... --resume <id>] / resume=<id>" with the same id
    # duplicated, nor have the "saved (fresh)" option silently resume.
    # Keep the loop shape in sync with the two writers.
    saved_args_clean=()
    n=${#saved_args[@]}
    i=0
    if [ "$AGENT" = "codex" ] && [ $n -ge 2 ] \
        && [ "${saved_args[0]}" = "resume" ]; then
        i=2
    fi
    while [ $i -lt $n ]; do
        if [ "${saved_args[$i]}" = "--resume" ]; then
            i=$((i+2))
        else
            saved_args_clean+=("${saved_args[$i]}")
            i=$((i+1))
        fi
    done

    # Stale-id check: only offer "resume" if the agent's transcript file
    # for this session id still exists. Per-agent surface:
    #   claude — direct path lookup (filename = session id)
    #   codex  — recursive scan; id is in the filename
    #   gemini — recursive scan; id is in the JSON body, not the filename
    has_resumable=false
    if [ -n "$saved_session" ]; then
        case "$AGENT" in
            claude)
                encoded_cwd=$(printf '%s' "$PWD" | tr ./ -)
                [ -f "$HOME/.claude/projects/$encoded_cwd/$saved_session.jsonl" ] && has_resumable=true
                ;;
            codex)
                if [ -d "$HOME/.codex/sessions" ] && \
                   find "$HOME/.codex/sessions" -type f -name "*${saved_session}*" 2>/dev/null \
                       | head -1 | grep -q .; then
                    has_resumable=true
                fi
                ;;
            gemini)
                if [ -d "$HOME/.gemini/tmp" ] && \
                   grep -rl "\"sessionId\"[[:space:]]*:[[:space:]]*\"${saved_session}\"" \
                        "$HOME/.gemini/tmp" 2>/dev/null \
                       | head -1 | grep -q .; then
                    has_resumable=true
                fi
                ;;
        esac
    fi

    saved_display="${saved_args_clean[*]:-<none>}"
    current_display="${agent_extra:-<none>}"
    # When saved == current, "saved" and "new" variants are byte-identical
    # launches — collapse them so the picker doesn't show two rows the
    # user can't tell apart. The "saved" branch is preferred since it
    # ALSO covers the case where the user typed nothing this time.
    args_match=false
    if [ "$saved_display" = "$current_display" ]; then
        args_match=true
    fi

    # Multi-line options so long args / full session ids are visible without
    # truncation. NUL-separated items + `--read0` is fzf's multi-line-render
    # mode (added in 0.46, broadly available in homebrew fzf). Each item
    # spans three lines: label, indented args, indented resume/freshness.
    # Four cells in the (args × session) matrix; only some are reachable on
    # any given launch. Build options + a parallel `actions[]` so the case
    # statement keys off intent rather than the visible row number, since
    # numbering renumbers on the fly when rows are hidden.
    options=()
    actions=()
    n=1

    if $has_resumable; then
        options+=("$(printf '%d) use saved params + session\n     args=[%s]\n     resume=%s' \
                          "$n" "$saved_display" "$saved_session")")
        actions+=("saved+resume")
        n=$((n+1))
    fi

    options+=("$(printf '%d) use saved params\n     args=[%s]\n     fresh session' \
                      "$n" "$saved_display")")
    actions+=("saved")
    n=$((n+1))

    # New params + resumed session is only meaningful when there *are* new
    # params AND they differ from what's saved; otherwise it collapses
    # into "saved params + session" (already shown above).
    if $has_resumable && [ -n "$agent_extra" ] && ! $args_match; then
        options+=("$(printf '%d) use new params + session\n     args=[%s]\n     resume=%s' \
                          "$n" "$current_display" "$saved_session")")
        actions+=("new+resume")
        n=$((n+1))
    fi

    # Same dedup for the fresh-session row: when args match, "use new"
    # is byte-identical to "use saved" already in the list.
    if ! $args_match; then
        options+=("$(printf '%d) use new params passed in\n     args=[%s]\n     fresh session' \
                          "$n" "$current_display")")
        actions+=("new")
    fi

    # Height: roughly 3 lines per option + 2 for header/status/border.
    fzf_height=$(( ${#options[@]} * 3 + 4 ))

    sel=$(
        for opt in "${options[@]}"; do
            printf '%s\0' "$opt"
        done | fzf --read0 \
                   --header "saved config for tag '$chosen_tag' ($AGENT)" \
                   --height "$fzf_height" \
                   --no-info --layout reverse --no-multi \
        || true
    )
    [ -z "$sel" ] && { echo "pair: aborted." >&2; exit 1; }

    # Map fzf's selection back to the action key. Comparing full multi-line
    # entries works because each option string is unique by construction.
    action=""
    for i in "${!options[@]}"; do
        if [ "${options[$i]}" = "$sel" ]; then
            action="${actions[$i]}"
            break
        fi
    done

    case "$action" in
        saved+resume|new+resume)
            # Compose: (base args stripped of any resume tokens) + the
            # canonical resume binding from saved_session. saved+resume's
            # base is saved_args_clean (already stripped above). new+resume's
            # base is the user-typed agent_extra, which may carry --resume
            # if the user typed one — strip those too so we don't end up
            # with duplicate resume tokens in the composed argv.
            stripped=()
            if [ "$action" = "saved+resume" ]; then
                # bash 3.2 + set -u: empty arrays read as "unset" without
                # the `${arr[@]+...}` guard.
                stripped=( ${saved_args_clean[@]+"${saved_args_clean[@]}"} )
            else
                read -ra _new_base <<< "$agent_extra"
                n=${#_new_base[@]}
                i=0
                if [ "$AGENT" = "codex" ] && [ $n -ge 2 ] \
                    && [ "${_new_base[0]}" = "resume" ]; then
                    i=2
                fi
                while [ $i -lt $n ]; do
                    if [ "${_new_base[$i]}" = "--resume" ]; then
                        i=$((i+2))
                    else
                        stripped+=("${_new_base[$i]}")
                        i=$((i+1))
                    fi
                done
            fi

            case "$AGENT" in
                codex)
                    # Codex resume is `codex resume <id> [other args]` —
                    # subcommand first, then any flags.
                    agent_extra="resume $saved_session${stripped[*]:+ ${stripped[*]}}"
                    ;;
                *)
                    # Flag-style: claude, gemini, anything else with a
                    # `--resume <id>` style.
                    agent_extra="${stripped[*]:+${stripped[*]} }--resume $saved_session"
                    ;;
            esac
            ;;
        saved)
            # Use the cleaned args: option 2 is "fresh session", so any
            # --resume baked into the on-disk config must NOT come along
            # for the ride. `:-` guards bash 3.2's `set -u` when empty.
            agent_extra="${saved_args_clean[*]:-}"
            ;;
        new)
            # Clean overwrite — drop the stale config; the watcher we
            # spawn below will write a fresh one once the new session
            # boots. agent_extra stays as whatever was passed on this
            # command line.
            rm -f "$config_file"
            ;;
    esac
    export PAIR_AGENT_ARGS="$agent_extra"
fi

export PAIR_TAG="$chosen_tag"
SESSION="pair-${PAIR_TAG}"
DRAFT="$DATA_DIR/draft-${PAIR_TAG}.md"
[ -f "$DRAFT" ] || : > "$DRAFT"

# Record the agent that's about to be launched in this session, so `pair list`
# can show which binary is paired with each session. The agent is otherwise not
# recoverable post-create — env vars are frozen in pane shells, and the session
# name (e.g. `pair-bugfix`) doesn't always carry the agent. Persists across
# detach/reattach; cleared on Alt+x quit alongside outer-tty.
printf '%s\n' "$AGENT" > "$DATA_DIR/agent-${PAIR_TAG}"

# Pre-capture the session id when --resume <id> is explicit on the
# command line. The watcher only catches NEW jsonl files the agent
# creates; an explicit --resume makes the agent APPEND to an existing
# file, so the watcher's snapshot-diff times out without writing a
# config. Pre-writing here means config-<tag>-<agent>.json is right from
# the start, so a future `pair resume` picker shows the resumed session
# and Alt+x's saved-config display reports the right id.
#
# Per-agent surface:
#   claude / gemini — flag style: `--resume <id>` anywhere in argv.
#   codex           — subcommand: `resume <id>` at args[0..1].
explicit_resume=""
case "$AGENT" in
    claude|gemini)
        prev=""
        for tok in $agent_extra; do
            if [ "$prev" = "--resume" ]; then
                explicit_resume="$tok"
                break
            fi
            prev="$tok"
        done
        ;;
    codex)
        read -r first second _rest <<< "$agent_extra"
        if [ "$first" = "resume" ] && [ -n "$second" ]; then
            explicit_resume="$second"
        fi
        ;;
esac
if [ -n "$explicit_resume" ]; then
    # Strip the --resume <id> (or codex's `resume <id>`) we just detected
    # from the args we're about to persist — session_id below is the
    # canonical storage for the resume binding. Without this, every
    # --resume launch writes a config whose `args` contains the resume
    # token, the picker then re-appends it on the next launch, and the
    # value gets duplicated indefinitely. Same loop shape as
    # bin/pair-session-watch.sh; keep them in sync.
    read -ra _eargs <<< "$agent_extra"
    _estripped=()
    n=${#_eargs[@]}
    i=0
    if [ "$AGENT" = "codex" ] && [ $n -ge 2 ] && [ "${_eargs[0]}" = "resume" ]; then
        i=2
    fi
    while [ $i -lt $n ]; do
        if [ "${_eargs[$i]}" = "--resume" ]; then
            i=$((i+2))
        else
            _estripped+=("${_eargs[$i]}")
            i=$((i+1))
        fi
    done
    config_path="$DATA_DIR/config-${PAIR_TAG}-${AGENT}.json"
    tmp=$(mktemp "$config_path.XXXXXX") && \
        jq -n \
            --arg agent "$AGENT" \
            --arg sid "$explicit_resume" \
            '{ agent: $agent, args: $ARGS.positional, session_id: $sid }' \
            --args -- ${_estripped[@]+"${_estripped[@]}"} > "$tmp" \
        && mv "$tmp" "$config_path" \
        || rm -f "$tmp"
fi

# Claude supports `--session-id <uuid>`, so on the new-session path we
# pin the id deterministically rather than fishing for it via the
# watcher. Two tags in the same cwd previously raced for the next new
# `~/.claude/projects/<encoded-cwd>/*.jsonl` and could capture each
# other's id (issue #000020). Pre-injecting the flag — and writing the
# config synchronously here — eliminates the race entirely for claude.
#
# Skip when:
#   - explicit_resume already pinned a session above;
#   - the user passed --session-id explicitly (their UUID wins);
#   - the user passed --fork-session (claude allocates a new id internally).
#
# Codex and gemini have no equivalent flag; they still need the watcher.
if [ "$AGENT" = "claude" ] && [ -z "$explicit_resume" ]; then
    _has_sid=0
    _has_fork=0
    for tok in $agent_extra; do
        case "$tok" in
            --session-id)   _has_sid=1 ;;
            --fork-session) _has_fork=1 ;;
        esac
    done
    if [ $_has_sid -eq 0 ] && [ $_has_fork -eq 0 ]; then
        # Claude refuses --session-id <uuid> if a session file with that id
        # already exists (observed). Collisions are astronomically rare
        # for v4, but check the project dir anyway and retry — cheap.
        _enc=$(printf '%s' "$PWD" | tr ./ -)
        _cdir="$HOME/.claude/projects/$_enc"
        new_sid=""
        for _ in 1 2 3 4 5; do
            cand=$(uuidgen | tr 'A-Z' 'a-z')
            if [ ! -e "$_cdir/$cand.jsonl" ]; then
                new_sid="$cand"
                break
            fi
        done
        if [ -n "$new_sid" ]; then
            agent_extra="${agent_extra:+$agent_extra }--session-id $new_sid"
            export PAIR_AGENT_ARGS="$agent_extra"
            config_path="$DATA_DIR/config-${PAIR_TAG}-${AGENT}.json"
            # Persist args WITHOUT the --session-id we just added: session_id
            # is the canonical storage for the resume binding, and leaving
            # the flag in args would compound on every relaunch through the
            # picker (same logic as the explicit_resume strip above).
            read -ra _sargs <<< "$agent_extra"
            _sstripped=()
            n=${#_sargs[@]}
            i=0
            while [ $i -lt $n ]; do
                if [ "${_sargs[$i]}" = "--session-id" ]; then
                    i=$((i+2))
                else
                    _sstripped+=("${_sargs[$i]}")
                    i=$((i+1))
                fi
            done
            tmp=$(mktemp "$config_path.XXXXXX") && \
                jq -n \
                    --arg agent "$AGENT" \
                    --arg sid "$new_sid" \
                    '{ agent: $agent, args: $ARGS.positional, session_id: $sid }' \
                    --args -- ${_sstripped[@]+"${_sstripped[@]}"} > "$tmp" \
                && mv "$tmp" "$config_path" \
                || rm -f "$tmp"
        fi
    fi
fi

# Spawn the session-id watcher (issue #000016, fixed in #000020). For
# codex/gemini it binds to the agent's PID via lsof, so concurrent pair
# sessions in the same cwd no longer race for each other's session file.
# For claude the watcher is a no-op (the deterministic --session-id path
# above writes the config synchronously). Backgrounded; self-times-out
# after 60s if the agent never opens a session file. agent_extra is
# intentionally word-split, matching the existing PAIR_AGENT_ARGS rule.
"$PAIR_HOME/bin/pair-session-watch.sh" "$AGENT" "$PAIR_TAG" "$PWD" $agent_extra \
    </dev/null >/dev/null 2>&1 &
disown $! 2>/dev/null || true

# Set terminal title — harmless duplicate for new sessions (zellij sets it
# itself), useful as a uniform path for both create and attach branches.
printf '\033]0;%s\007' "$SESSION"
record_outer_tty
cmux_rename_workspace "$SESSION"
"$PAIR_HOME/bin/pair-cmux-title.sh" "$PAIR_TAG" "$AGENT" \
    </dev/null >/dev/null 2>&1 &
disown $! 2>/dev/null || true

# Note on the create invocation: zellij's `--layout PATH --session NAME` does
# NOT create-with-layout; per its help text, when --session is set, --layout
# is treated as "add a tab to the session named NAME" and errors if the
# session doesn't exist. The right flag is --new-session-with-layout (-n).
zellij \
    --config-dir              "$PAIR_HOME/zellij" \
    --new-session-with-layout "$PAIR_HOME/zellij/layouts/main.kdl" \
    --session                 "$SESSION"
cleanup_quit_marker
handle_restart_marker
