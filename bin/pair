#!/usr/bin/env bash
# pair — launch a zellij session split between a TUI coding agent (top pane)
# and an nvim drafting pane (bottom). See README.md.
#
# Usage:
#   pair                       # claude, default session
#   pair claude
#   pair codex
#   pair gemini
#   pair claude work           # claude, "work" variant — independent session
#   pair claude scratch        # claude, "scratch" variant — another one
#   pair pick                  # interactive picker over existing pair-* sessions
#
# Each (agent, variant) tuple gets its own zellij session, draft file, and
# log file, so any number of independent sessions can run side by side.

set -euo pipefail

# --- help -------------------------------------------------------------------
case "${1:-}" in
    -h|--help|help)
        cat <<'EOF'
pair — Neovim-backed input field for any TUI coding agent.

USAGE
  pair                          claude in default session
  pair <agent>                  e.g. pair codex / pair gemini
  pair <agent> <variant>        independent session, e.g. pair claude work
  pair pick [<agent>]           interactive session picker; filters to agent
                                if given (pair pick codex shows only codex)
  pair -h, --help               this message

BEHAVIOR
  When pair would create a new session it prompts for a session name
  (default = auto-generated like pair-claude-2). Enter to accept, or type
  a custom name (allowed chars: A-Z a-z 0-9 - _).

  When pair would attach:
    0 detached sessions in family   → create new (with prompt)
    1 detached                      → attach silently
    2+ detached                     → fzf picker

KEYBINDINGS (inside a pair session)
  Alt+Return    send nvim buffer to agent + Enter, log, clear, insert mode
  Alt+u         toggle nvim pane fullscreen (works from either pane)
  Alt+d         detach from session
  Alt+n         pull clipboard into nvim cursor (reflowed, ">" -prefixed)
  Alt+i         attach clipboard image to agent + insert [Image #N];
                if cursor is on an existing [Image #N], sync counter to N
  <leader>cs    send only current section (between --- markers)
  <leader>cp    paste-and-reflow at cursor (raw, no quoting)

FILES
  ~/scratch/pair-draft-<tag>.md   persistent draft per session
  ~/scratch/pair-log-<tag>.md     append-only prompt log per session

See README.md for image-paste recipes and other details.
EOF
        exit 0
        ;;
esac

# Resolve this script's real path portably (macOS lacks `readlink -f`).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
PAIR_HOME="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
export PAIR_HOME

# Picker mode: smarter "what do you want to do" entry point.
#   pair pick                  — picker over all pair-* sessions; new = claude
#   pair pick <agent>          — picker filtered to that agent; new = <agent>
#                                e.g. `pair pick codex` only shows pair-codex
#                                and pair-codex-* sessions, and the sentinel
#                                becomes "+ new codex session".
#
# In both cases:
#   - No matching sessions: silently fall through to a new launch.
#   - One or more match: show fzf with the sessions plus a "+ new <agent>"
#     sentinel. Picking a session attaches; picking the sentinel falls
#     through to a new launch.
if [ "${1:-}" = "pick" ] || [ "${1:-}" = "--pick" ]; then
    if ! command -v zellij >/dev/null 2>&1; then
        echo "pair: zellij not found on PATH." >&2; exit 1
    fi

    pick_agent="${2:-}"  # optional filter

    if [ -n "$pick_agent" ]; then
        # Match `pair-<agent>` exactly or `pair-<agent>-<variant>`. The (-|$)
        # boundary prevents `pair pick claude` from matching `pair-claudex`.
        sessions=$(zellij list-sessions --short --no-formatting 2>/dev/null \
                   | grep -E "^pair-${pick_agent}(-|$)" || true)
        new_agent="$pick_agent"
    else
        sessions=$(zellij list-sessions --short --no-formatting 2>/dev/null | grep '^pair-' || true)
        new_agent="claude"
    fi
    new_label="+ new ${new_agent} session"

    if [ -z "$sessions" ]; then
        # No matching sessions — fall through to a new launch with the right agent.
        set -- "$new_agent"
    else
        options=$(printf '%s\n%s\n' "$sessions" "$new_label")
        if command -v fzf >/dev/null 2>&1; then
            chosen=$(printf '%s' "$options" | fzf --prompt='attach> ' --height=10 --reverse) || exit 0
        else
            echo "Active pair sessions:"
            printf '%s' "$options" | nl
            printf 'Pick number: '
            read -r n
            chosen=$(printf '%s' "$options" | sed -n "${n}p")
        fi
        [ -z "$chosen" ] && exit 0

        if [ "$chosen" = "$new_label" ]; then
            set -- "$new_agent"
        else
            # Resolve PAIR_HOME for the attach exec.
            SOURCE="${BASH_SOURCE[0]}"
            while [ -L "$SOURCE" ]; do
                DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
                SOURCE="$(readlink "$SOURCE")"
                [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
            done
            PAIR_HOME="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
            exec zellij --config-dir "$PAIR_HOME/zellij" attach "$chosen"
        fi
    fi
fi

AGENT="${1:-claude}"
VARIANT="${2:-}"

# PAIR_AGENT is the command to exec in the agent pane.
# PAIR_TAG is the namespace identifier — used to name the zellij session and
# the per-instance draft/log files. Without a variant, tag == agent.
export PAIR_AGENT="$AGENT"
if [ -n "$VARIANT" ]; then
    export PAIR_TAG="${AGENT}-${VARIANT}"
else
    export PAIR_TAG="$AGENT"
fi

if ! command -v "$AGENT" >/dev/null 2>&1; then
    echo "pair: agent '$AGENT' not found on PATH." >&2
    echo "      install it first, then re-run." >&2
    exit 1
fi

if ! command -v zellij >/dev/null 2>&1; then
    echo "pair: zellij not found on PATH." >&2
    echo "      brew install zellij  (or your package manager equivalent)" >&2
    exit 1
fi

# Refuse to launch from inside an existing zellij session. Nested sessions
# don't compose — `--session NAME` from inside zellij triggers attach, not
# create, which fails confusingly when the named session doesn't exist yet.
if [ -n "${ZELLIJ:-}" ]; then
    echo "pair: already running inside a zellij session." >&2
    echo "      detach first (Ctrl+p d) or run pair from a fresh terminal." >&2
    exit 1
fi

mkdir -p "$HOME/scratch"

# Collect every session in the current family — pair-<tag> exact, plus
# pair-<tag>-N for any N — and classify each into detached / attached /
# exited. Then branch on how many *detached* candidates we found:
#
#   0 detached  → create fresh at the next-free slot in the family.
#   1 detached  → attach to it directly. This is the "I had paused this,
#                 resume" case.
#   2+ detached → show fzf so the user picks which one to attach to (with
#                 a "+ new" sentinel for "actually I want a fresh one").
#
# A "family" for `pair claude` is anything matching pair-claude(-N)?. For
# `pair claude work` the family is pair-claude-work(-N)?. So variants don't
# leak into each other, and N=2,3,... are auto-rename suffixes.
#
# Detection: `zellij --session NAME action list-clients` prints a header
# plus one row per connected client. Zero rows = detached. Only works on
# running sessions; EXITED ones are spotted via list-sessions first.
BASE_TAG="$PAIR_TAG"

family=$(zellij list-sessions --short 2>/dev/null \
         | grep -E "^pair-${BASE_TAG}(-[0-9]+)?\$" \
         | sort)

detached_list=()
while IFS= read -r sess; do
    [ -z "$sess" ] && continue
    if zellij list-sessions --no-formatting 2>/dev/null \
        | grep -E "^${sess}[[:space:]].*EXITED" >/dev/null 2>&1; then
        continue   # exited, not a candidate
    fi
    clients=$(zellij --session "$sess" action list-clients 2>/dev/null \
              | tail -n +2 | wc -l | tr -d ' ')
    if [ "${clients:-0}" -eq 0 ]; then
        detached_list+=("$sess")
    fi
done <<< "$family"

# Compute the next-free slot in this family (used by both 0-detached and the
# "+ new" sentinel in the picker).
free_slot_tag=""
i=1
while [ "$i" -le 100 ]; do
    if [ "$i" -eq 1 ]; then
        cand="pair-${BASE_TAG}"
    else
        cand="pair-${BASE_TAG}-${i}"
    fi
    if ! grep -qx "$cand" <<< "$family"; then
        free_slot_tag="${cand#pair-}"
        break
    fi
    i=$((i + 1))
done

# Decide.
chosen_session=""
chosen_tag=""
action=""   # "attach" | "create"

case "${#detached_list[@]}" in
    0)
        chosen_tag="$free_slot_tag"
        action=create
        ;;
    1)
        chosen_session="${detached_list[0]}"
        chosen_tag="${chosen_session#pair-}"
        action=attach
        ;;
    *)
        new_label="+ new ${BASE_TAG} session"
        options=$(printf '%s\n' "${detached_list[@]}"; printf '%s\n' "$new_label")
        if command -v fzf >/dev/null 2>&1; then
            picked=$(printf '%s' "$options" | fzf --prompt="${BASE_TAG}> " --height=10 --reverse) || exit 0
        else
            echo "Detached '${BASE_TAG}' sessions:"
            printf '%s' "$options" | nl
            printf 'Pick: '
            read -r idx
            picked=$(printf '%s' "$options" | sed -n "${idx}p")
        fi
        [ -z "$picked" ] && exit 0
        if [ "$picked" = "$new_label" ]; then
            chosen_tag="$free_slot_tag"
            action=create
        else
            chosen_session="$picked"
            chosen_tag="${chosen_session#pair-}"
            action=attach
        fi
        ;;
esac

if [ -z "$chosen_tag" ]; then
    echo "pair: couldn't determine a session to use; bailing." >&2
    exit 1
fi

if [ "$action" = "attach" ]; then
    export PAIR_TAG="$chosen_tag"
    SESSION="pair-${PAIR_TAG}"
    DRAFT="$HOME/scratch/pair-draft-${PAIR_TAG}.md"
    [ -f "$DRAFT" ] || : > "$DRAFT"
    if [ "$PAIR_TAG" != "$BASE_TAG" ]; then
        echo "pair: reattaching detached $SESSION." >&2
    fi
    # Set terminal title — zellij sets this on new-session creation but not
    # on attach, so without this the title stays as whatever the shell's
    # preexec hook set (typically "bin/pair").
    printf '\033]0;%s\007' "$SESSION"
    exec zellij --config-dir "$PAIR_HOME/zellij" attach "$SESSION"
fi

# Create branch — prompt for a session name with the auto-suggested name as
# the default. Empty input keeps the default; a typed value (with any leading
# `pair-` stripped) becomes the new tag. Reads from /dev/tty so the prompt
# works even when stdin is redirected.
default_session="pair-${chosen_tag}"
printf 'Session name [%s]: ' "$default_session" >/dev/tty
if read -r user_input </dev/tty; then
    if [ -n "$user_input" ]; then
        case "$user_input" in
            pair-*) typed_tag="${user_input#pair-}" ;;
            *)      typed_tag="$user_input" ;;
        esac
        case "$typed_tag" in
            ""|*[!A-Za-z0-9_-]*)
                echo "pair: invalid name '$user_input'." >&2
                echo "      allowed: letters, digits, dash, underscore." >&2
                exit 1
                ;;
        esac
        if zellij list-sessions --short 2>/dev/null | grep -qx "pair-${typed_tag}"; then
            echo "pair: session 'pair-${typed_tag}' already exists." >&2
            exit 1
        fi
        chosen_tag="$typed_tag"
    fi
else
    # EOF (Ctrl+D) — bail cleanly
    echo >/dev/tty
    exit 0
fi

export PAIR_TAG="$chosen_tag"
SESSION="pair-${PAIR_TAG}"
DRAFT="$HOME/scratch/pair-draft-${PAIR_TAG}.md"
[ -f "$DRAFT" ] || : > "$DRAFT"

if [ "$PAIR_TAG" != "$BASE_TAG" ]; then
    echo "pair: spawning $SESSION." >&2
fi
# Set terminal title — harmless duplicate for new sessions (zellij sets it
# itself), useful for picker-driven attach branches that fall through here.
printf '\033]0;%s\007' "$SESSION"

# Note on the create invocation: zellij's `--layout PATH --session NAME` does
# NOT create-with-layout; per its help text, when --session is set, --layout
# is treated as "add a tab to the session named NAME" and errors if the
# session doesn't exist. The right flag is --new-session-with-layout (-n).
exec zellij \
    --config-dir              "$PAIR_HOME/zellij" \
    --new-session-with-layout "$PAIR_HOME/zellij/layouts/main.kdl" \
    --session                 "$SESSION"
