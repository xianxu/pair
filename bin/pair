#!/usr/bin/env bash
# pair — launch a zellij session split between a TUI coding agent (top pane)
# and an nvim drafting pane (bottom). See README.md.
#
# Usage:
#   pair                       claude in default session
#   pair <agent>               claude / codex / gemini
#   pair [<agent>] -- <args>   forward args to agent on create,
#                              e.g. pair claude -- --resume
#                                   pair -- --dangerously-skip-permissions
#                                   pair codex -- -p "say hi"
#   pair -h, --help            show help
#
# When detached pair-* sessions exist, an fzf picker is shown so the user
# explicitly chooses what to do — no silent auto-attach. The picker shows
# ALL detached pair-* sessions regardless of agent argument; the agent
# argument only matters for the create path (sentinel label, default name,
# binary to exec).

set -euo pipefail

# --- help -------------------------------------------------------------------
case "${1:-}" in
    -h|--help|help)
        cat <<'EOF'
pair — Neovim-backed input field for any TUI coding agent.

USAGE
  pair                          claude in default session
  pair <agent>                  e.g. pair codex / pair gemini
  pair resume <tag>             attach pair-<tag> if it exists, else create
                                with that tag and the saved config; agent
                                is inferred from saved state
  pair [<agent>] -- <args>      forward args to the agent on create
                                e.g. pair claude -- --resume
                                     pair -- --dangerously-skip-permissions
                                     pair codex -- -p "say hi"
  pair list                     list pair-* sessions and their attach state
  pair -h, --help               this message

  Use `--` to separate pair's args from the agent's args. Without `--`,
  pair only accepts `<agent>` as a positional (or `resume <tag>`).

  When creating a new session you'll be prompted for a name; type any
  custom name (e.g. "bugfix") to make it independent of other sessions.
  `resume <tag>` skips that prompt — use it to restart a saved tag with
  its captured args (and the agent's session if still on disk).

  Agent args (after `--`) only apply on CREATE. Reattaching to an
  existing session uses whatever args the agent was originally started
  with — the picker doesn't re-launch the agent.

BEHAVIOR
  Picker shows ALL detached pair-* sessions, regardless of the agent
  argument. The agent argument only controls what gets created if you
  pick the "+ new" sentinel: it labels the sentinel, drives the auto-
  suggested name, and is the binary that gets exec'd.

    0 detached → create a new session (prompts for name; default is
                 auto-generated like pair-claude-2)
    ≥1 detached → fzf picker over every detached pair-* session, plus a
                  "+ new <agent> session" sentinel. Picking attaches;
                  picking the sentinel falls through to the create flow.

  No silent attach. Every reattach is explicit.

KEYBINDINGS (inside a pair session)
  Alt+Return    send nvim buffer to agent + Enter, log, clear, insert mode
  Alt+← / Alt+→ walk through prompt history (-N) ↔ draft (*) ↔ queue (+N)
  Shift+Alt+← / Shift+Alt+→
                jump to next region boundary (oldest-history / newest-history /
                * / front-of-queue / back-of-queue)
  Alt+q         push current buffer to queue front (+1)
                from *: parks the draft. from -N: forks. from +N: move-to-front
  Alt+BS        (at +N) delete the current queued prompt; items shift down,
                so tap-tap deletes a run
  Shift+Alt+BS  erase history + draft + queue ("start anew"); confirms first
  Alt+↑ / Alt+↓ step nvim pane along small ↔ half ↔ full ladder
                (works from either pane)
  Alt+d         detach from session (re-attach later via `pair`)
  Alt+x         full quit — kill session and remove from resurrect list
                (Ctrl+q is unbound; Alt+x is the only quit path)
  Alt+h         pop up this help in a floating pane (press `q` to dismiss)
  Alt+i         attach clipboard image to agent + insert [Image #N];
                if cursor is on an existing [Image #N], sync counter to N

  Status line shows `H < pos > Q` — history count, current slot, queue
  count. A dirty `-N*` mark on history means a pending fork; navigating
  away prompts: (S)end, (Q)ueue, (D)iscard, [S]tay.

DRAFT SYNTAX
  ===  comment  Whole lines starting with `===` are stripped at send time
                but kept in draft/queue/log. Use them to annotate why a
                queued prompt exists. Mid-line `===` is unaffected.

FILES
  ${XDG_DATA_HOME:-~/.local/share}/pair/draft-<tag>.md     persistent draft (*)
  ${XDG_DATA_HOME:-~/.local/share}/pair/log-<tag>.md       prompt history (-N)
  ${XDG_DATA_HOME:-~/.local/share}/pair/queue-<tag>/*.md   queued prompts (+N)

See README.md for image-paste recipes and other details.
EOF
        exit 0
        ;;
    list|ls)
        if ! command -v zellij >/dev/null 2>&1; then
            echo "pair: zellij not found on PATH." >&2
            exit 1
        fi
        # Snapshot session state once. --no-formatting carries the EXITED
        # annotation; --short gives clean newline-separated names.
        raw=$( { zellij list-sessions --no-formatting 2>/dev/null || true; } )
        sessions=$( { zellij list-sessions --short 2>/dev/null || true; } \
                    | awk '/^pair-/' \
                    | sort )
        if [ -z "$sessions" ]; then
            echo "no pair sessions"
            exit 0
        fi
        list_data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/pair"
        mkdir -p "$list_data_dir"

        # Backfill agent-<tag> for any running pair-wrap process whose tag
        # we don't yet have on disk — covers sessions created before the
        # agent-tracking feature shipped. Read PAIR_TAG from each process's
        # environ (macOS: `ps -E`; Linux: /proc/<pid>/environ) and the
        # agent name from argv (the token after `pair-wrap`).
        pw_pids=$(pgrep -f 'pair-wrap' 2>/dev/null || true)
        for pid in $pw_pids; do
            argv=$(ps -p "$pid" -o command= 2>/dev/null || true)
            [ -z "$argv" ] && continue
            agent=$(printf '%s\n' "$argv" | awk '
                { for (i=1; i<=NF; i++) if ($i ~ /pair-wrap$/) { print $(i+1); exit } }')
            [ -z "$agent" ] && continue
            if [ -r "/proc/$pid/environ" ]; then
                env_blob=$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null || true)
            else
                env_blob=$( { ps -wwEp "$pid" -o command= 2>/dev/null \
                              || ps eww -p "$pid" 2>/dev/null \
                              || true; } )
            fi
            tag=$(printf '%s' "$env_blob" \
                  | tr ' \0' '\n\n' \
                  | awk -F= '$1=="PAIR_TAG"{print $2; exit}')
            [ -z "$tag" ] && continue
            if [ ! -f "$list_data_dir/agent-${tag}" ]; then
                printf '%s\n' "$agent" > "$list_data_dir/agent-${tag}"
            fi
        done

        printf '%-30s %-10s %s\n' "SESSION" "AGENT" "STATUS"
        while IFS= read -r sess; do
            [ -z "$sess" ] && continue
            tag="${sess#pair-}"
            agent_file="$list_data_dir/agent-${tag}"
            if [ -f "$agent_file" ]; then
                agent=$(head -n1 "$agent_file" | tr -d '\r\n[:space:]')
                [ -z "$agent" ] && agent="?"
            else
                agent="?"
            fi
            if printf '%s\n' "$raw" \
                 | grep -E "^${sess}[[:space:]].*EXITED" >/dev/null 2>&1; then
                status="exited"
            else
                # `|| true` so pipefail+errexit doesn't abort when zellij
                # can't reach the session (e.g. running outside any zellij
                # client); empty input through tail/wc yields 0.
                clients=$( { zellij --session "$sess" action list-clients 2>/dev/null || true; } \
                          | tail -n +2 | wc -l | tr -d ' ')
                clients=${clients:-0}
                if [ "$clients" -eq 0 ]; then
                    status="detached"
                elif [ "$clients" -eq 1 ]; then
                    status="attached (1 client)"
                else
                    status="attached ($clients clients)"
                fi
            fi
            printf '%-30s %-10s %s\n' "$sess" "$agent" "$status"
        done <<< "$sessions"
        exit 0
        ;;
esac

# Resolve this script's real path portably (macOS lacks `readlink -f`).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
PAIR_HOME="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
export PAIR_HOME

# Put pair's bin/ on PATH so zellij can resolve our helper scripts by bare
# name (clipboard-to-pane.sh, copy-on-select.sh) without sh-c env-var hacks
# in zellij/config.kdl. Avoid double-prepending across re-launches.
case ":$PATH:" in
    *":$PAIR_HOME/bin:"*) ;;
    *) export PATH="$PAIR_HOME/bin:$PATH" ;;
esac

# Parse argv. First positional is the agent name (default `claude`).
# Anything after `--` is forwarded to the agent on create. The `--`
# separator is required to disambiguate "agent name" from "flag for the
# agent" — without it, `pair --dangerously-skip-permissions` is ambiguous
# (is `--dangerously-skip-permissions` the agent or a flag?).
#
#   pair                                  → claude
#   pair claude                           → claude
#   pair claude -- --resume               → claude --resume
#   pair -- --resume                      → claude --resume
#   pair codex -- -p "hi"                 → codex -p hi   (word-split caveat)
AGENT=""
agent_extra=""
forced_tag=""
agent_explicit=false  # true if AGENT was set from a positional CLI arg

# `pair resume <tag>` is the documented restart path: skip both the picker
# and the name prompt, attach if pair-<tag> exists, otherwise create with
# that tag. We claim `resume` as a subcommand verb — it can't be a real
# agent binary (too generic a name), and we already special-case `list`
# and `help` similarly above.
if [ "${1:-}" = "resume" ]; then
    if [ -z "${2:-}" ]; then
        echo "pair: 'resume' requires a tag (e.g. pair resume bugfix)" >&2
        exit 1
    fi
    forced_tag="$2"
    case "$forced_tag" in
        pair-*) forced_tag="${forced_tag#pair-}" ;;
    esac
    case "$forced_tag" in
        ""|*[!A-Za-z0-9_-]*)
            echo "pair: invalid tag '$2'." >&2
            echo "      allowed: letters, digits, dash, underscore." >&2
            exit 1
            ;;
    esac
    shift 2
fi

seen_dd=false
for arg in "$@"; do
    if $seen_dd; then
        if [ -z "$agent_extra" ]; then
            agent_extra="$arg"
        else
            agent_extra="$agent_extra $arg"
        fi
    elif [ "$arg" = "--" ]; then
        seen_dd=true
    elif [ -z "$AGENT" ] && [ -z "$forced_tag" ]; then
        AGENT="$arg"
        agent_explicit=true
    else
        echo "pair: unexpected positional arg '$arg' (use '--' to forward args to the agent)" >&2
        echo "      e.g. pair claude -- --resume" >&2
        exit 1
    fi
done
# Defer the [-z AGENT] default to after DATA_DIR is set: when `resume <tag>`
# is used we infer the agent from saved state on disk so a single tag is
# enough to fully restart, regardless of which agent was originally paired
# with it.

# default_tag drives the auto-suggestion in the create-flow name prompt
# and the picker's "+ new <tag> session" sentinel. The interactive prompt
# and `resume <tag>` both override this.
#
# When the user explicitly named an agent on the CLI (`pair gemini`,
# `pair codex`, ...), use the agent name — that's the most likely
# intent ("a gemini session here"). When agent was implicit (just
# `pair`, defaults to claude), use the cwd basename so multiple repos
# don't collapse onto the same default.
if $agent_explicit; then
    default_tag="$AGENT"
else
    default_tag="$(basename "$PWD")"
fi
default_tag="${default_tag//[^A-Za-z0-9_-]/_}"
[ -z "$default_tag" ] && default_tag="pair"

if ! command -v zellij >/dev/null 2>&1; then
    echo "pair: zellij not found on PATH." >&2
    echo "      brew install zellij  (or your package manager equivalent)" >&2
    exit 1
fi

# Refuse to launch from inside an existing zellij session. Nested sessions
# don't compose — `--session NAME` from inside zellij triggers attach, not
# create, which fails confusingly when the named session doesn't exist yet.
if [ -n "${ZELLIJ:-}" ]; then
    echo "pair: already running inside a zellij session." >&2
    echo "      detach first (Alt+d) or run pair from a fresh terminal." >&2
    exit 1
fi

# Resolve XDG data dir for pair's drafts and per-tag prompt logs.
# Honors $XDG_DATA_HOME with the spec-defined fallback.
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/pair"
mkdir -p "$DATA_DIR"
export PAIR_DATA_DIR="$DATA_DIR"

# Agent inference for `pair resume <tag>`: look up what was paired with
# this tag last time. agent-<tag> covers live (or recently detached)
# sessions — written at create-flow start, cleared on Alt+x.
# config-<tag>-<agent>.json (issue #000016) covers the case where the
# session was Alt+x'd: that file persists across quit and the filename
# encodes the agent. Either source is authoritative.
if [ -n "$forced_tag" ] && [ -z "$AGENT" ]; then
    if [ -f "$DATA_DIR/agent-${forced_tag}" ]; then
        AGENT=$(cat "$DATA_DIR/agent-${forced_tag}")
    else
        for cfg in "$DATA_DIR"/config-"${forced_tag}"-*.json; do
            [ -f "$cfg" ] || continue
            inferred=$(jq -r '.agent // empty' "$cfg" 2>/dev/null)
            if [ -n "$inferred" ]; then
                AGENT="$inferred"
                break
            fi
        done
    fi
fi
[ -z "$AGENT" ] && AGENT="claude"

# PAIR_AGENT is the command to exec in the agent pane on create.
# PAIR_AGENT_ARGS is appended on the agent pane's command line at create.
#   It applies only on create; reattaching to an existing session uses
#   whatever args the agent was originally launched with.
export PAIR_AGENT="$AGENT"
export PAIR_AGENT_ARGS="$agent_extra"

# PAIR_TAG is the namespace identifier — used to name the zellij session
# and the per-instance draft/log files. The create flow's interactive
# prompt and `resume <tag>` override this.
export PAIR_TAG="$default_tag"

# One-time migration: if old ~/scratch/pair-{draft,log}-*.md files exist,
# move them to the new XDG location with the redundant `pair-` prefix
# stripped (since they're already inside the pair/ dir). Idempotent.
if [ -d "$HOME/scratch" ]; then
    moved=0
    for old in "$HOME/scratch"/pair-draft-*.md "$HOME/scratch"/pair-log-*.md; do
        [ -e "$old" ] || continue
        base="$(basename "$old")"
        new="$DATA_DIR/${base#pair-}"
        if [ ! -e "$new" ]; then
            mv "$old" "$new" && moved=$((moved + 1))
        fi
    done
    if [ "$moved" -gt 0 ]; then
        echo "pair: migrated $moved file(s) from ~/scratch/ to $DATA_DIR" >&2
    fi
fi

BASE_TAG="$PAIR_TAG"

# Find ALL detached pair-* sessions, regardless of agent. The agent argument
# (and BASE_TAG) is only used for the create path's defaults; the picker
# itself shows everything you might want to reattach to, including custom-
# named sessions like pair-blogging that don't follow any agent prefix.
# `zellij list-sessions` exits 1 when there are no sessions, and with
# `set -euo pipefail` that would silently kill the whole script. Wrap the
# zellij call in `|| true` and use awk (returns 0 even on no matches)
# instead of grep (returns 1 on no matches).
all_pair=$( { zellij list-sessions --short 2>/dev/null || true; } \
            | awk '/^pair-/' \
            | sort )

detached_list=()
while IFS= read -r sess; do
    [ -z "$sess" ] && continue
    if zellij list-sessions --no-formatting 2>/dev/null \
        | grep -E "^${sess}[[:space:]].*EXITED" >/dev/null 2>&1; then
        continue   # exited, skip
    fi
    clients=$(zellij --session "$sess" action list-clients 2>/dev/null \
              | tail -n +2 | wc -l | tr -d ' ')
    if [ "${clients:-0}" -eq 0 ]; then
        detached_list+=("$sess")
    fi
done <<< "$all_pair"

# Compute the next-free numeric slot in the agent's family — pair-<base>,
# then pair-<base>-2, ... — used as the prompt's default name on create. This
# checks against ALL existing sessions (not just family) to avoid clobbering
# anything that happens to share the slot's name.
free_slot_tag=""
i=1
while [ "$i" -le 100 ]; do
    if [ "$i" -eq 1 ]; then
        cand="pair-${BASE_TAG}"
    else
        cand="pair-${BASE_TAG}-${i}"
    fi
    if ! zellij list-sessions --short 2>/dev/null | grep -qx "$cand"; then
        free_slot_tag="${cand#pair-}"
        break
    fi
    i=$((i + 1))
done

# Decide. Picker for any ≥1 detached; create directly only when none exist.
chosen_session=""
chosen_tag=""
action=""   # "attach" | "create"

# `pair resume <tag>` short-circuits both the picker and the name prompt:
# attach if pair-<tag> already exists in any state, otherwise create with
# that tag. This is the "resume by name" path — pair off the hint printed
# at Alt+x.
if [ -n "$forced_tag" ]; then
    if zellij list-sessions --short 2>/dev/null | grep -qx "pair-${forced_tag}"; then
        chosen_session="pair-${forced_tag}"
        chosen_tag="$forced_tag"
        action=attach
    else
        chosen_tag="$forced_tag"
        action=create
    fi
elif [ ${#detached_list[@]} -eq 0 ]; then
    chosen_tag="$free_slot_tag"
    action=create
else
    new_label="+ new ${BASE_TAG} session"
    options=$(printf '%s\n' "${detached_list[@]}"; printf '%s\n' "$new_label")
    if command -v fzf >/dev/null 2>&1; then
        picked=$(printf '%s' "$options" | fzf --prompt='pair> ' --height=10 --reverse) || exit 0
    else
        echo "Detached pair sessions:"
        printf '%s' "$options" | nl
        printf 'Pick: '
        read -r idx
        picked=$(printf '%s' "$options" | sed -n "${idx}p")
    fi
    [ -z "$picked" ] && exit 0

    if [ "$picked" = "$new_label" ]; then
        chosen_tag="$free_slot_tag"
        action=create
    else
        chosen_session="$picked"
        chosen_tag="${chosen_session#pair-}"
        action=attach
    fi
fi

if [ -z "$chosen_tag" ]; then
    echo "pair: couldn't determine a session to use; bailing." >&2
    exit 1
fi

# Helper: after zellij returns, check for the Alt+x marker. If present, the
# user asked for a full quit — delete the session entry from the resurrect
# list. (Ctrl+q is unbound in pair, so Alt+x is the only quit path; Alt+d
# is detach, which keeps the session alive and leaves no marker.)
cleanup_quit_marker() {
    local marker="$HOME/.cache/pair/quit-$SESSION"
    if [ -f "$marker" ]; then
        rm -f "$marker"
        # Capture the agent BEFORE the file is cleared below, so the resume
        # hint can name the right binary.
        local quit_agent
        quit_agent=$(cat "$DATA_DIR/agent-${PAIR_TAG}" 2>/dev/null || echo "$AGENT")
        zellij delete-session "$SESSION" --force >/dev/null 2>&1 || true
        # Defensive belt-and-suspenders: if a zellij --server process for this
        # session is still alive after delete-session (rare but seen — e.g.
        # the server lingered in a no-clients state and re-registered the
        # session record on its next heartbeat), SIGKILL it. Pattern matches
        # the socket path component, scoped to this session only.
        pkill -9 -f "zellij --server .*/${SESSION}\$" >/dev/null 2>&1 || true
        rm -f "$DATA_DIR/outer-tty-${PAIR_TAG}" "$DATA_DIR/agent-${PAIR_TAG}" \
              "$DATA_DIR/agent-output-${PAIR_TAG}"

        # If the watcher captured a session config for this (tag, agent),
        # show the user the one-liner that resumes it. config-<tag>-<agent>
        # is what the create-flow prompt reads — its presence here is the
        # signal that the resume path will work next time.
        #
        # Display SESSION (e.g. pair-2) rather than PAIR_TAG ("2") to match
        # what the user saw in the UI tab; the `resume` subcommand accepts
        # both forms (it strips a leading `pair-`). Agent is omitted from
        # the resume command — pair infers it from the saved state.
        if [ -f "$DATA_DIR/config-${PAIR_TAG}-${quit_agent}.json" ]; then
            printf 'pair: saved session config for tag "%s" (%s).\n' \
                "$SESSION" "$quit_agent"
            printf '      resume with: pair resume %s\n' "$SESSION"
        fi
    fi
}

# Capture pair's controlling TTY before zellij takes over — this IS the path
# of the outer terminal/wrapper's PTY. Writing OSC sequences to it bypasses
# zellij's escape filtering, letting outer wrappers (e.g. cmux, which watches
# OSC 9/777 to surface attention indicators) see notifications emitted from
# inside a pane. Refreshed on every attach because the outer PTY changes
# across detach/reattach; pane-shell env doesn't (env is frozen at zellij
# session-creation time). #000011
record_outer_tty() {
    local outer
    outer="$(tty 2>/dev/null || true)"
    case "$outer" in
        /dev/*) printf '%s\n' "$outer" > "$DATA_DIR/outer-tty-${PAIR_TAG}" ;;
        *)      rm -f "$DATA_DIR/outer-tty-${PAIR_TAG}" ;;
    esac
}

if [ "$action" = "attach" ]; then
    export PAIR_TAG="$chosen_tag"
    SESSION="pair-${PAIR_TAG}"
    DRAFT="$DATA_DIR/draft-${PAIR_TAG}.md"
    [ -f "$DRAFT" ] || : > "$DRAFT"
    # Set terminal title — zellij sets this on new-session creation but not
    # on attach, so without this the title stays as whatever the shell's
    # preexec hook set (typically "bin/pair").
    printf '\033]0;%s\007' "$SESSION"
    record_outer_tty
    zellij --config-dir "$PAIR_HOME/zellij" attach "$SESSION"
    cleanup_quit_marker
    exit $?
fi

# Create branch. Validate the agent here (deferred past the picker so attach
# paths work even when AGENT isn't a real binary on PATH — e.g. attaching
# to a custom-named session whose tag happens to match a non-command).
if ! command -v "$AGENT" >/dev/null 2>&1; then
    echo "pair: agent '$AGENT' not found on PATH." >&2
    echo "      install it first, then re-run." >&2
    exit 1
fi

# Surface any existing sessions in this tag's family (pair-<base> and
# pair-<base>-*) before prompting, so the user can see what's already
# there — and why the auto-suggested prefill may include a numeric
# suffix.
family_prefix="pair-${BASE_TAG}"
family_existing=$( { zellij list-sessions --no-formatting 2>/dev/null || true; } \
    | awk -v p="$family_prefix" '$1 == p || index($1, p "-") == 1' )
if [ -n "$family_existing" ]; then
    {
        printf 'Existing %s* sessions:\n' "$family_prefix"
        printf '%s\n' "$family_existing" | sed 's/^/  /'
    } >/dev/tty
fi

# Prompt for a session name. The input line is pre-filled with the auto-
# suggested next-free tag (the `pair-` prefix is implicit and added back
# below) so the user can edit/extend it inline — e.g. with the default
# pre-filled as "pair", typing "1" yields "pair1". Empty input falls back
# to the suggested default.
#
# bash 3.2 (system bash on macOS) lacks `read -i`, so we delegate the
# editable prompt to zsh's `vared`, which is universally available on
# macOS and Linux. The vared editor UI runs on /dev/tty; the captured
# stdout is just the final value.
#
# Skipped when `resume <tag>` is given: forced_tag has already been
# validated and the picker landed us in `create` straight from there.
if [ -z "$forced_tag" ]; then
    if command -v zsh >/dev/null 2>&1; then
        # `zsh -c` boots without sourcing .zshrc, so the line editor's
        # keymap defaults to a raw state where Ctrl-A through Ctrl-F are
        # all `self-insert` — meaning the user couldn't navigate left to
        # edit the prefix of the prefilled tag (only append). `bindkey
        # -e` selects the emacs keymap explicitly, giving the expected
        # arrows / backspace / Ctrl-A / Ctrl-E bindings inside vared.
        if user_input=$(
            zsh -c '
                bindkey -e
                v=$1
                vared -p "Session name: " v
                print -r -- "$v"
            ' _ "$chosen_tag" </dev/tty 2>/dev/tty
        ); then :; else
            echo >/dev/tty
            exit 0
        fi
    else
        # No zsh — fall back to a non-editable [default]-style prompt.
        printf 'Session name [%s]: ' "$chosen_tag" >/dev/tty
        if ! read -r user_input </dev/tty; then
            echo >/dev/tty
            exit 0
        fi
    fi
    user_input="${user_input:-$chosen_tag}"
    case "$user_input" in
        pair-*) typed_tag="${user_input#pair-}" ;;
        *)      typed_tag="$user_input" ;;
    esac
    case "$typed_tag" in
        ""|*[!A-Za-z0-9_-]*)
            echo "pair: invalid name '$user_input'." >&2
            echo "      allowed: letters, digits, dash, underscore." >&2
            exit 1
            ;;
    esac
    if zellij list-sessions --short 2>/dev/null | grep -qx "pair-${typed_tag}"; then
        echo "pair: session 'pair-${typed_tag}' already exists." >&2
        exit 1
    fi
    chosen_tag="$typed_tag"
fi

# ---------------------------------------------------------------------------
# Tag-restart prompt (issue #000016)
# ---------------------------------------------------------------------------
# If we have a saved config for (tag, agent) from a prior launch, ask the
# user whether to reuse the saved args (and resume the agent's session if
# the agent's transcript is still on disk). This is the place: the tag has
# just been committed; agent + agent_extra are known; the watcher and
# zellij launch happen below.
#
# fzf is already a hard dep (used for the session picker). Each option line
# spells out the values it will apply so the user can pick without flipping
# context. ESC aborts the create flow — same posture as the name prompt.
config_file="$DATA_DIR/config-${chosen_tag}-${AGENT}.json"
if [ -f "$config_file" ]; then
    # Read saved args as a properly-delimited stream; mapfile would be
    # cleaner but is bash 4+ and macOS still ships 3.2.
    saved_args=()
    while IFS= read -r line; do saved_args+=("$line"); done \
        < <(jq -r '.args[]?' "$config_file" 2>/dev/null)
    saved_session=$(jq -r '.session_id // empty' "$config_file" 2>/dev/null)

    # Stale-id check: only offer "resume" if the agent's transcript file
    # for this session id still exists. Per-agent surface:
    #   claude — direct path lookup (filename = session id)
    #   codex  — recursive scan; id is in the filename
    #   gemini — recursive scan; id is in the JSON body, not the filename
    has_resumable=false
    if [ -n "$saved_session" ]; then
        case "$AGENT" in
            claude)
                encoded_cwd=$(printf '%s' "$PWD" | tr / -)
                [ -f "$HOME/.claude/projects/$encoded_cwd/$saved_session.jsonl" ] && has_resumable=true
                ;;
            codex)
                if [ -d "$HOME/.codex/sessions" ] && \
                   find "$HOME/.codex/sessions" -type f -name "*${saved_session}*" 2>/dev/null \
                       | head -1 | grep -q .; then
                    has_resumable=true
                fi
                ;;
            gemini)
                if [ -d "$HOME/.gemini/tmp" ] && \
                   grep -rl "\"sessionId\"[[:space:]]*:[[:space:]]*\"${saved_session}\"" \
                        "$HOME/.gemini/tmp" 2>/dev/null \
                       | head -1 | grep -q .; then
                    has_resumable=true
                fi
                ;;
        esac
    fi

    saved_display="${saved_args[*]:-<none>}"
    current_display="${agent_extra:-<none>}"

    # Multi-line options so long args / full session ids are visible without
    # truncation. NUL-separated items + `--read0` is fzf's multi-line-render
    # mode (added in 0.46, broadly available in homebrew fzf). Each item
    # spans three lines: label, indented args, indented resume/freshness.
    options=()
    if $has_resumable; then
        options+=("$(printf '1) use saved params + session\n     args=[%s]\n     resume=%s' \
                          "$saved_display" "$saved_session")")
    fi
    options+=("$(printf '2) use saved params\n     args=[%s]\n     fresh session' "$saved_display")")
    options+=("$(printf '3) use new params passed in\n     args=[%s]\n     fresh session' "$current_display")")

    # Height: roughly 3 lines per option + 2 for header/status/border.
    fzf_height=$(( ${#options[@]} * 3 + 4 ))

    sel=$(
        for opt in "${options[@]}"; do
            printf '%s\0' "$opt"
        done | fzf --read0 \
                   --header "saved config for tag '$chosen_tag' ($AGENT)" \
                   --height "$fzf_height" \
                   --no-info --layout reverse --no-multi \
        || true
    )
    [ -z "$sel" ] && { echo "pair: aborted." >&2; exit 1; }

    case "$sel" in
        "1)"*)
            # Strip any pre-existing resume tokens from saved args so the
            # composed line never duplicates them. Two surfaces:
            #   --resume <X>   (claude, gemini — flag style; anywhere in args)
            #   resume <X>     (codex — subcommand; only valid as args[0..1])
            stripped=()
            n=${#saved_args[@]}
            i=0
            if [ "$AGENT" = "codex" ] && [ $n -ge 2 ] \
                && [ "${saved_args[0]}" = "resume" ]; then
                i=2
            fi
            while [ $i -lt $n ]; do
                if [ "${saved_args[$i]}" = "--resume" ]; then
                    i=$((i+2))
                else
                    stripped+=("${saved_args[$i]}")
                    i=$((i+1))
                fi
            done

            case "$AGENT" in
                codex)
                    # Codex resume is `codex resume <id> [other args]` —
                    # subcommand first, then any flags.
                    agent_extra="resume $saved_session${stripped[*]:+ ${stripped[*]}}"
                    ;;
                *)
                    # Flag-style: claude, gemini, anything else with a
                    # `--resume <id>` style.
                    agent_extra="${stripped[*]:+${stripped[*]} }--resume $saved_session"
                    ;;
            esac
            ;;
        "2)"*)
            # `:-` guards bash 3.2's `set -u` when saved_args is empty.
            agent_extra="${saved_args[*]:-}"
            ;;
        "3)"*)
            # Clean overwrite — drop the stale config; the watcher we
            # spawn below will write a fresh one once the new session
            # boots. agent_extra stays as whatever was passed on this
            # command line.
            rm -f "$config_file"
            ;;
    esac
    export PAIR_AGENT_ARGS="$agent_extra"
fi

export PAIR_TAG="$chosen_tag"
SESSION="pair-${PAIR_TAG}"
DRAFT="$DATA_DIR/draft-${PAIR_TAG}.md"
[ -f "$DRAFT" ] || : > "$DRAFT"

# Record the agent that's about to be launched in this session, so `pair list`
# can show which binary is paired with each session. The agent is otherwise not
# recoverable post-create — env vars are frozen in pane shells, and the session
# name (e.g. `pair-bugfix`) doesn't always carry the agent. Persists across
# detach/reattach; cleared on Alt+x quit alongside outer-tty.
printf '%s\n' "$AGENT" > "$DATA_DIR/agent-${PAIR_TAG}"

# Spawn the session-id watcher (issue #000016). It polls the agent's
# session dir for the file that appears once the agent boots, then writes
# $DATA_DIR/config-<tag>-<agent>.json with the captured agent + args +
# session_id. Backgrounded so it doesn't block the zellij launch; the
# watcher self-times-out after 60s if no file appears (agent crashed
# pre-startup, etc). Output redirected so any noise doesn't bleed into
# pair's create-flow output. agent_extra is intentionally word-split here,
# matching the existing $PAIR_AGENT_ARGS convention.
"$PAIR_HOME/bin/pair-session-watch.sh" "$AGENT" "$PAIR_TAG" "$PWD" $agent_extra \
    </dev/null >/dev/null 2>&1 &

# Set terminal title — harmless duplicate for new sessions (zellij sets it
# itself), useful as a uniform path for both create and attach branches.
printf '\033]0;%s\007' "$SESSION"
record_outer_tty

# Note on the create invocation: zellij's `--layout PATH --session NAME` does
# NOT create-with-layout; per its help text, when --session is set, --layout
# is treated as "add a tab to the session named NAME" and errors if the
# session doesn't exist. The right flag is --new-session-with-layout (-n).
zellij \
    --config-dir              "$PAIR_HOME/zellij" \
    --new-session-with-layout "$PAIR_HOME/zellij/layouts/main.kdl" \
    --session                 "$SESSION"
cleanup_quit_marker
