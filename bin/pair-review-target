#!/usr/bin/env bash
# bin/pair-review-target — write the review-target seam (#6) stamped with the
# current PAIR_SESSION_ID, so the target is CONVERSATION-scoped: the draft nvim's
# Alt+c ignores a target from a different session (a fresh pair session prompts),
# while an Alt+n restart that resumes the same conversation keeps its in-progress
# review. The agent runs this to mark a target `ready` (or `proposed`) instead of
# hand-writing the JSON — pair-side stamping keeps the session reliable. (#66 #6.)
#
#   pair-review-target <file> <proposed|ready>
set -euo pipefail
file="${1:?usage: pair-review-target <file> <proposed|ready>}"
status="${2:?usage: pair-review-target <file> <proposed|ready>}"
case "$status" in proposed | ready) ;; *) echo "pair-review-target: status must be proposed|ready" >&2; exit 2 ;; esac
: "${PAIR_DATA_DIR:?pair-review-target: PAIR_DATA_DIR not set}"
tag="${PAIR_TAG:-default}"
agent="${PAIR_AGENT:-claude}"

session_id="${PAIR_SESSION_ID:-}"
if [ -z "$session_id" ]; then
  cfg="$PAIR_DATA_DIR/config-$tag-$agent.json"
  if [ -f "$cfg" ]; then
    session_id="$(jq -r '.session_id // empty' "$cfg" 2>/dev/null || true)"
  fi
fi
if [ -z "$session_id" ] && [ "$agent" = "codex" ]; then
  pid_file="$PAIR_DATA_DIR/agent-pid-$tag"
  if [ -s "$pid_file" ]; then
    root_pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [ -n "$root_pid" ]; then
      session_id="$(
        ps -axo pid=,ppid= 2>/dev/null | awk -v root="$root_pid" '
          { children[$2] = children[$2] " " $1 }
          END {
            queue[1] = root; seen[root] = 1; head = 1; tail = 1
            while (head <= tail) {
              p = queue[head++]; print p
              n = split(children[p], kids, " ")
              for (i = 1; i <= n; i++) {
                k = kids[i]
                if (k != "" && !seen[k]) { seen[k] = 1; queue[++tail] = k }
              }
            }
          }' | while IFS= read -r p; do
            [ -n "$p" ] || continue
            lsof -p "$p" -Fn 2>/dev/null | sed -n 's/^n//p'
          done | sed -nE 's|^.*/\.codex/sessions/.*/rollout-.*([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})\.jsonl$|\1|p' | head -n 1
      )"
    fi
  fi
fi

# normalize to an absolute path (the dir must exist — it's the doc under review)
if [ -d "$(dirname "$file")" ]; then
  file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"
fi

out="$PAIR_DATA_DIR/review-target-$tag.json"
jq -n --arg file "$file" --arg status "$status" --arg session "$session_id" \
  '{file: $file, status: $status, session: $session}' > "$out"
echo "review target $status: $file (session ${session_id:-none})"
