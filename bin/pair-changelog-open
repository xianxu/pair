#!/bin/sh
# pair-changelog-open — open the session's distilled change log in a read-only
# nvim viewer; build/refresh it with a DETACHED background distiller.
#
# Bound to Alt+l in zellij/config.kdl (Run with floating=true, close_on_exit=true).
# The distilled counterpart to Alt+/ (pair-scrollback-open). Filed as #53.
#
# Architecture (#58): the render+distill runs as a **detached** background process
# (nohup), NOT as a child of nvim — so a long batched build keeps running even if
# the operator closes the viewer mid-build. nvim is a pure WATCHER: it tails the
# log file (reloading per batch) and shows a spinner while the distiller is alive.
# Two locks:
#   - openlock  → viewer singleton (a second Alt+l while a viewer is up refocuses)
#   - distill.lock (PID) → distiller singleton; a press won't start a second
#     distiller while one is running (it just opens a viewer to watch it).
#
# Inputs from pair's env (exported by bin/pair before zellij starts):
#   $PAIR_DATA_DIR  $PAIR_TAG  $PAIR_AGENT  $PAIR_HOME
set -eu

if [ -z "${PAIR_DATA_DIR:-}" ] || [ -z "${PAIR_TAG:-}" ] || [ -z "${PAIR_AGENT:-}" ]; then
    printf 'pair-changelog-open: missing PAIR_DATA_DIR / PAIR_TAG / PAIR_AGENT\n' >&2
    printf '  This script is meant to run inside a pair session.\n' >&2
    sleep 3
    exit 1
fi

base="$PAIR_DATA_DIR/changelog-$PAIR_TAG-$PAIR_AGENT"
RAW="$PAIR_DATA_DIR/scrollback-$PAIR_TAG-$PAIR_AGENT.raw"
EVENTS="$PAIR_DATA_DIR/scrollback-$PAIR_TAG-$PAIR_AGENT.events.jsonl"
LOG="$base.md"
ANCHOR="$base.anchor"
CLEANED="$base.cleaned"
OPENLOCK="$base.openlock"      # viewer singleton
DLOCK="$base.distill.lock"     # distiller singleton (holds the distiller PID)
STATUS="$base.status"          # distiller stderr (batch progress) for the spinner

# Viewer re-entrancy: a second Alt+l while a viewer is already up just exits
# (its pane self-dismisses), leaving the existing viewer focused.
if [ -f "$OPENLOCK" ]; then
    other=$(cat "$OPENLOCK" 2>/dev/null || true)
    if [ -n "${other:-}" ] && kill -0 "$other" 2>/dev/null; then
        exit 0
    fi
fi
printf '%s\n' "$$" > "$OPENLOCK"
trap 'rm -f "$OPENLOCK"' EXIT INT TERM

[ -f "$LOG" ] || : > "$LOG"

# Is a distiller already running (from a prior press whose viewer may be closed)?
distiller_running() {
    [ -f "$DLOCK" ] || return 1
    _p=$(cat "$DLOCK" 2>/dev/null || true)
    [ -n "${_p:-}" ] && kill -0 "$_p" 2>/dev/null
}

# Launch the render+distill in its OWN SESSION so it survives the viewer closing.
# nohup alone is not enough: closing the zellij floating pane tears down the
# pane's process group/session, which still reaches a plain background child
# (only its already-written batches survive on disk, and reopening restarts from
# batch 1 — #58). setsid puts the build in a new session the pane teardown can't
# reach; macOS has no setsid, so fall back to a perl POSIX::setsid shim. The
# distiller writes the log per batch + the anchor at the end; PID → DLOCK; stderr
# (batch progress) → STATUS.
if ! distiller_running && [ -s "$RAW" ] \
   && [ -x "$PAIR_HOME/bin/pair-scrollback-render" ] && [ -x "$PAIR_HOME/bin/pair-changelog" ]; then
    : > "$STATUS"
    export PCL_RENDER="$PAIR_HOME/bin/pair-scrollback-render"
    export PCL_DISTILL="$PAIR_HOME/bin/pair-changelog"
    export PCL_RAW="$RAW" PCL_EVENTS="$EVENTS" PCL_CLEANED="$CLEANED"
    export PCL_LOG="$LOG" PCL_ANCHOR="$ANCHOR" PCL_AGENT="$PAIR_AGENT"
    INNER='"$PCL_RENDER" --plain --max-lines 0 "$PCL_RAW" "$PCL_EVENTS" "$PCL_CLEANED" && "$PCL_DISTILL" --cleaned "$PCL_CLEANED" --log "$PCL_LOG" --anchor "$PCL_ANCHOR" --agent "$PCL_AGENT"'
    if command -v setsid >/dev/null 2>&1; then
        setsid sh -c "$INNER" </dev/null >/dev/null 2>"$STATUS" &
    else
        perl -e 'use POSIX qw(setsid); setsid() or die "setsid: $!"; exec @ARGV or die "exec: $!";' \
            sh -c "$INNER" </dev/null >/dev/null 2>"$STATUS" &
    fi
    printf '%s\n' "$!" > "$DLOCK"
fi

# Viewer (foreground). On close, the EXIT trap clears OPENLOCK; the detached
# distiller (DLOCK) keeps running. The viewer watches LOG / DLOCK / STATUS.
export PAIR_CHANGELOG_LOG="$LOG"
export PAIR_CHANGELOG_DLOCK="$DLOCK"
export PAIR_CHANGELOG_STATUS="$STATUS"
nvim -u "$PAIR_HOME/nvim/changelog.lua" "$LOG"
