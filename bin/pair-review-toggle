#!/bin/sh
# pair-review-toggle — the mode-aware Alt+r brain (issue #66 M3). Bound to Alt+r
# (zellij/config.kdl) in a transient floating pane:
#   • no live review open → file-select: focus the draft pane and open its
#     `:PairReview ` command line (the user tab-completes the file).
#   • a live review open   → flip its visibility (show/hide), so Alt+r switches
#     between the agent+draft view and the review view.
#
# Visibility is tracked on line 2 of the state file (written by nvim/review.lua),
# NOT via `are-floating-panes-visible` — this toggle runs in its own floating
# pane, which would confound that query. We use EXPLICIT show/hide and NEVER
# `toggle-floating-panes` (it toggles all floating panes and spawns a stray one
# if none exist).
#
# Env: $PAIR_DATA_DIR $PAIR_TAG
set -eu

if [ -z "${PAIR_DATA_DIR:-}" ] || [ -z "${PAIR_TAG:-}" ]; then
    printf 'pair-review-toggle: missing PAIR_DATA_DIR / PAIR_TAG\n' >&2
    exit 1
fi

STATE="$PAIR_DATA_DIR/review-$PAIR_TAG.open"

alive=no
pid=""
vis="visible"
if [ -f "$STATE" ]; then
    pid=$(sed -n 1p "$STATE" 2>/dev/null || true)
    vis=$(sed -n 2p "$STATE" 2>/dev/null || true)
    if [ -n "${pid:-}" ] && kill -0 "$pid" 2>/dev/null; then
        alive=yes
    fi
fi

if [ "$alive" = no ]; then
    # File-select: focus the draft pane by id, drop into `:PairReview `.
    rm -f "$STATE"   # reap a dead/stale state file
    draft=$(zellij action list-panes --json 2>/dev/null \
        | jq -r '[.. | objects | select(.is_floating == false and .title == "draft")][0].id // empty' 2>/dev/null || true)
    if [ -z "${draft:-}" ]; then
        printf 'pair-review-toggle: could not find the draft pane\n' >&2
        exit 1
    fi
    zellij action focus-pane-id "$draft"
    zellij action write 27                       # ESC → normal mode
    zellij action write-chars ':PairReview '     # open the cmdline (no submit)
else
    # Flip visibility with explicit show/hide (never toggle-floating-panes).
    if [ "$vis" = hidden ]; then
        zellij action show-floating-panes
        printf '%s\nvisible\n' "$pid" > "$STATE"
    else
        zellij action hide-floating-panes
        printf '%s\nhidden\n' "$pid" > "$STATE"
    fi
fi
