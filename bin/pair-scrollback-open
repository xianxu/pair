#!/bin/sh
# pair-scrollback-open — render the agent pane's captured scrollback
# and open it in a read-only ANSI-aware nvim viewer.
#
# Bound to Alt+/ in zellij/config.kdl (Run with floating=true,
# close_on_exit=true), so this script runs in a floating pane, executes
# nvim in place, and the pane self-dismisses when the user :q's.
#
# Inputs come from pair's env (exported by bin/pair before zellij starts):
#   $PAIR_DATA_DIR  — where pair stores per-session state files
#   $PAIR_TAG       — session identity
#   $PAIR_AGENT     — agent basename (claude / codex / gemini)
#   $PAIR_HOME      — pair install root (for nvim/scrollback.lua)
#
# Filed as #000017 M5.
set -eu

if [ -z "${PAIR_DATA_DIR:-}" ] || [ -z "${PAIR_TAG:-}" ] || [ -z "${PAIR_AGENT:-}" ]; then
    printf 'pair-scrollback-open: missing PAIR_DATA_DIR / PAIR_TAG / PAIR_AGENT\n' >&2
    printf '  This script is meant to run inside a pair session.\n' >&2
    sleep 3
    exit 1
fi

RAW="$PAIR_DATA_DIR/scrollback-$PAIR_TAG-$PAIR_AGENT.raw"
EVENTS="$PAIR_DATA_DIR/scrollback-$PAIR_TAG-$PAIR_AGENT.events.jsonl"
ANSI="$PAIR_DATA_DIR/scrollback-$PAIR_TAG-$PAIR_AGENT.ansi"

if [ ! -s "$RAW" ]; then
    printf 'pair-scrollback-open: no scrollback yet for %s/%s\n' "$PAIR_TAG" "$PAIR_AGENT" >&2
    printf '  (capture starts when the agent pane begins emitting output.)\n' >&2
    sleep 3
    exit 0
fi

if [ ! -x "$PAIR_HOME/bin/pair-scrollback-render" ]; then
    printf 'pair-scrollback-open: bin/pair-scrollback-render not built.\n' >&2
    printf '  Build it:  make pair-scrollback-render\n' >&2
    sleep 5
    exit 1
fi
if ! "$PAIR_HOME/bin/pair-scrollback-render" "$RAW" "$EVENTS" "$ANSI"; then
    printf 'pair-scrollback-open: pair-scrollback-render failed; see above.\n' >&2
    sleep 5
    exit 1
fi

# Overlay zellij's scroll position onto the .viewport sidecar. The
# renderer emits the *emulator's* visible-buffer top (the agent's
# notion of "current screen"), which doesn't reflect where the user
# has scrolled in zellij. dump-screen gives us the actual visible
# content of the agent pane *including* any zellij scroll offset;
# matching it back into the rendered .ansi yields the line number
# the user is currently looking at.
#
# Best-effort: any failure (jq missing, zellij IPC unavailable,
# no high-confidence match) leaves the renderer's .viewport in place.
VIEWPORT="$PAIR_DATA_DIR/scrollback-$PAIR_TAG-$PAIR_AGENT.viewport"
if command -v jq >/dev/null 2>&1; then
    agent_id=$(zellij action list-panes --json 2>/dev/null \
        | jq -r '[.. | objects
                   | select(.is_plugin == false
                            and .is_floating == false
                            and .title != "draft"
                            and .title != "")][0].id // empty' 2>/dev/null)
    if [ -n "${agent_id:-}" ]; then
        dump=$(mktemp -t pair-sb-dump.XXXXXX)
        astrip=$(mktemp -t pair-sb-astrip.XXXXXX)
        trap 'rm -f "$dump" "$astrip"' EXIT
        if zellij action dump-screen --pane-id "terminal_$agent_id" >"$dump" 2>/dev/null \
           && [ -s "$dump" ]; then
            # Strip ANSI SGR escapes from .ansi so dump's plain-text
            # lines match line-for-line.
            esc=$(printf '\033')
            sed -E "s/${esc}\\[[0-9;]*[a-zA-Z]//g" "$ANSI" > "$astrip"
            # Multi-line consecutive match: for each non-blank dump
            # line, every .ansi line it matches implies a "dump-line-1
            # lands at .ansi line S" hypothesis. Score each hypothesis
            # by how many dump lines match consecutively starting at S.
            # Require >= 50% of non-blank dump lines to match (handily
            # separates the true position from short-line false
            # positives, which scored 1/27 vs 24/27 in dev probe).
            best=$(awk -v dump="$dump" -v ansi="$astrip" '
            BEGIN {
                dn = 0
                while ((getline l < dump) > 0) D[dn++] = l
                close(dump)
                an = 0
                while ((getline l < ansi) > 0) A[an++] = l
                close(ansi)
                for (j = 0; j < an; j++)
                    if (A[j] != "" && length(A[j]) >= 8)
                        idx[A[j]] = idx[A[j]] " " (j + 1)
                for (i = 0; i < dn; i++) {
                    if (D[i] == "" || length(D[i]) < 8) continue
                    if (!(D[i] in idx)) continue
                    n = split(idx[D[i]], pos, " ")
                    for (p = 1; p <= n; p++) {
                        if (pos[p] == "") continue
                        s = pos[p] - i
                        if (s < -an) continue
                        seen[s] = 1
                    }
                }
                nb = 0
                for (i = 0; i < dn; i++) if (D[i] != "") nb++
                best_score = 0
                best_start = 0
                for (s in seen) {
                    score = 0
                    for (i = 0; i < dn; i++) {
                        if (D[i] == "") continue
                        j = s - 1 + i
                        if (j < 0 || j >= an) continue
                        if (A[j] == D[i]) score++
                    }
                    if (score > best_score) {
                        best_score = score
                        best_start = s
                    }
                }
                if (best_score * 2 >= nb && nb > 0) {
                    s = best_start
                    if (s < 1) s = 1     # dump starts before .ansi line 1
                                         # → user is at the very top
                    print s
                }
            }
            ')
            if [ -n "$best" ]; then
                printf '%s\n' "$best" > "$VIEWPORT.tmp" \
                    && mv -f "$VIEWPORT.tmp" "$VIEWPORT"
            fi
        fi
        rm -f "$dump" "$astrip"
        trap - EXIT
    fi
fi

# exec nvim — when the user :q's, the script (and its containing
# floating pane) exits. close_on_exit=true on the zellij Run binding
# tears the pane down.
#
# PAIR_NVIM_PID_FILE: nvim/scrollback.lua's VimEnter autocmd writes the
# embed pid here so cleanup_quit_marker in bin/pair can reap it on Alt+x.
# Without this, the embed nvim (forked off the TUI) can survive zellij's
# kill-session and accumulate as a PPID=1 orphan — same shape as the draft
# pane leak, but reachable via Alt+/ leaving the scrollback viewer open.
export PAIR_NVIM_PID_FILE="$PAIR_DATA_DIR/nvim-pid-$PAIR_TAG-scrollback"
exec nvim -u "$PAIR_HOME/nvim/scrollback.lua" "$ANSI"
