#!/usr/bin/env python3
"""pair-wrap — transparent PTY proxy around a TUI coding agent.

Spawns the agent in a fresh pseudo-terminal so the wrapper sees the agent's
raw output stream. When the agent emits a terminal bell (BEL, 0x07) or an
OSC 9 / OSC 777 notification escape, the wrapper writes an OSC 9 sequence
directly to pair's recorded outer-TTY path — bypassing zellij, which would
otherwise eat the OSC on the way out. Use case: outer wrappers like cmux
that watch the host PTY stream for attention markers.

Failure mode: if anything in the detection/emission path errors, the wrapper
swallows the exception and keeps proxying. Never block the agent on a notify.

Filed as #000011.
"""

import collections
import errno
import fcntl
import json
import os
import pty
import re
import select
import signal
import struct
import sys
import termios
import time
import tty


RATE_LIMIT_S = 0.5  # collapse bursts (e.g. multiple BELs) into one notification
OUTER_TTY_FILE = None
LAST_EMIT = 0.0
DEBUG_LOG = os.environ.get("PAIR_WRAP_LOG")  # opt-in path; if set, log detections

# Bare-BEL fallback: off by default. The fallback was intended to catch
# unfamiliar agents that signal attention via lone BEL, but in practice
# it fires on the trailing \x07 of OSC sequences (notably OSC 8 hyperlinks
# and OSC 0 title sets) whose openers got trimmed out of the rolling buffer
# after a prior match — producing an order-of-magnitude more noise than
# real signal. Modern TUI agents use OSC 9 / OSC 777 explicitly. Set
# PAIR_WRAP_BELL_FALLBACK=1 to re-enable for the discovery workflow.
# See workshop/issues/000014.
BELL_FALLBACK = os.environ.get("PAIR_WRAP_BELL_FALLBACK") not in (None, "", "0")

# Idle-output timeout: if the agent produces no bytes for this long, treat it
# as idle and emit a notification. Catches agents that don't bell on idle.
# Set to 0 to disable. Fires once per idle period; resets on any output.
try:
    IDLE_S = float(os.environ.get("PAIR_WRAP_IDLE_S", "60"))
except ValueError:
    IDLE_S = 60.0

# Per-agent notification source. Exactly one path fires emit_outer() for
# any given agent run; the other two become explicit *-swallow log
# entries so double-notifications are impossible.
#   "native" — forward agent's own OSC 9/777 (and bare BEL if enabled)
#   "idle"   — fire after IDLE_S of output silence
#   "marker" — fire on first capture of agent-specific end-of-turn span
# Matched against basename of the wrapped command. Agents not listed
# fall back to NOTIFY_MODE_DEFAULT.
NOTIFY_MODE = {
    "claude": "marker",
}
NOTIFY_MODE_DEFAULT = "native"

# Per-agent end-of-turn span pattern, used only when NOTIFY_MODE is
# "marker" for that agent. Each agent's TUI leaves a distinct frozen
# status line at turn completion; the regex matches against finalized
# colored spans (so colors and per-line accumulation are already handled
# by update_agent_output) and fires emit_outer on first sighting (LRU
# dedupes redraws). Set by main() once agent_basename is known.
END_OF_TURN_BY_AGENT = {
    # Claude Code: "✻ <PastTenseVerb> for <duration>" in gray, where
    # duration is one or more `<digits><h|m|s>` components separated by
    # whitespace — `21s`, `1m 52s`, `2h 13m 4s`. The original regex only
    # matched the single-seconds form and missed every multi-component
    # case (which is most non-trivial turns). Anchored ^✻ so the
    # quoted-history form ("> ✻ Churned for 21s", different color)
    # doesn't double-emit. ✻ = U+273B = 0xE2 0x9C 0xBB in UTF-8.
    "claude": re.compile(rb"^\xe2\x9c\xbb\s*[A-Za-z]+\s+for\s+\d+[hms](?:\s+\d+[hms])*"),
}

# Agents whose colored-span extraction we trust. Powers nvim autocomplete
# *and* "marker" notification mode (the marker check piggybacks on span
# finalization). Each agent paints with a different palette and uses
# different cursor-positioning idioms, so capture is calibrated per-agent.
# Outside this set, pair-wrap skips span capture entirely — autocomplete
# in nvim falls back to the draft buffer alone, and "marker" mode is a
# no-op (caller's NOTIFY_MODE configuration error).
SPAN_EXTRACTION_AGENTS = frozenset({"claude"})

# Resolved at startup by main(). Module-global so _finalize_span() can
# consult END_OF_TURN_RE without threading agent state through.
NOTIFY_MODE_ACTIVE = NOTIFY_MODE_DEFAULT
END_OF_TURN_RE = None

# Scrollback capture (#000017). When --scrollback-log <path> is set,
# every byte read from the agent's PTY (master) is teed to SCROLLBACK_FD
# (truncated on open), and a sidecar .events.jsonl gets one record per
# resize keyed by byte offset. Downstream pair-scrollback-render reads
# both files and replays through pyte at each segment's correct width
# to recover line-numbered, ANSI-colored scrollback.
#
# Failure mode mirrors the rest of pair-wrap: any tee error is swallowed
# so the proxy never blocks the agent on a logging hiccup.
SCROLLBACK_FD = -1
SCROLLBACK_EVENTS_FD = -1
SCROLLBACK_BYTES = 0  # bytes written to SCROLLBACK_FD so far; offset key for events


def debug(label, context):
    """Append a one-line forensic record. Safe to call when DEBUG_LOG unset."""
    if not DEBUG_LOG:
        return
    try:
        ts = time.strftime("%H:%M:%S")
        # repr() gives a printable form with \x.. escapes for control bytes
        snippet = repr(context)[:240]
        with open(DEBUG_LOG, "a") as f:
            f.write(f"[{ts}] {label}: {snippet}\n")
    except OSError:
        pass


# Rolling tail of *colored* spans the agent emits — text painted with a
# specific non-default foreground via SGR. Claude's renderer paints code
# spans, paths, commands, and inline tokens in a distinct color; we capture
# each colored run together with its color so nvim can filter by color
# (e.g. accept only the blue-cyan code-span color, reject the gray header).
#
# File format: `<color_id>\t<span>\n`, one entry per line. `<color_id>` is
# a small string identifying the FG: standard 16-color codes ("34", "96"),
# 256-color ("5;75"), or RGB ("2;100;200;255"). nvim is the side that
# decides which color_ids to admit.
#
# Storage uses OrderedDict as a fixed-size LRU: re-emissions of the same
# span (Claude redraws constantly) move-to-end rather than displacing
# older distinct spans, so the slots hold the last N *unique* spans.
# The value is an emission count — bumped on every re-emission. nvim uses
# count + recency (line position in flushed file) to rank candidates.
AGENT_OUTPUT_SPANS = 1000
AGENT_OUTPUT_FILE = None
AGENT_SPANS = collections.OrderedDict()  # key=b"<color>\t<text>" -> int count
AGENT_FG = None              # current FG color id (None = default fg)
AGENT_SPAN_BUF = b""         # accumulator for the in-progress colored run
AGENT_SPAN_FG = None         # color id that started AGENT_SPAN_BUF
AGENT_PENDING = b""          # tail of last chunk if it ended mid-escape
AGENT_SPAN_MAX = 512         # safety cap; auto-finalize past this length

# Match an SGR (CSI ... m) sequence and capture its parameter list.
SGR_RE = re.compile(rb"\x1b\[([0-9;]*)m")

# Match any complete ANSI escape sequence we want to *skip* (i.e. not
# include in the captured span). SGR is a special case handled separately;
# everything else is just noise from a span perspective.
OTHER_ESC_RE = re.compile(
    rb"\x1b\[[0-?]*[ -/]*[@-~]"           # any CSI (covers non-SGR too)
    rb"|\x1b\][^\x07\x1b]*(?:\x07|\x1b\\)"  # OSC
    rb"|\x1b[()*+][@-~]"                    # charset designators
    rb"|\x1b[@-Z\\-_]"                      # 2-byte ESC sequences
)


def resolve_agent_output_file():
    tag = os.environ.get("PAIR_TAG")
    if not tag:
        return None
    data_dir = os.environ.get("PAIR_DATA_DIR")
    if not data_dir:
        xdg = os.environ.get("XDG_DATA_HOME") or os.path.expanduser("~/.local/share")
        data_dir = os.path.join(xdg, "pair")
    return os.path.join(data_dir, f"agent-output-{tag}")


def _sgr_extract_fg(params, current_fg):
    """Apply an SGR parameter list and return the new FG color id.

    Returns None for default FG, otherwise a bytes identifier:
      - "34", "36", ..., "94", ..., "97" for 16-color
      - "5;N" for 256-color (CSI 38;5;N)
      - "2;R;G;B" for RGB (CSI 38;2;R;G;B)

    Bg, bold/underline, and other attributes are ignored — they don't
    affect span extraction.
    """
    if not params:
        return None  # \x1b[m == full reset
    codes = params.split(b";")
    fg = current_fg
    i = 0
    while i < len(codes):
        try:
            n = int(codes[i]) if codes[i] else 0
        except ValueError:
            i += 1
            continue
        if n == 0 or n == 39:
            fg = None
        elif (30 <= n <= 37) or (90 <= n <= 97):
            fg = str(n).encode()
        elif n == 38 and i + 1 < len(codes):
            if codes[i + 1] == b"5" and i + 2 < len(codes):
                fg = b"5;" + codes[i + 2]
                i += 2
            elif codes[i + 1] == b"2" and i + 4 < len(codes):
                fg = (b"2;" + codes[i + 2] + b";"
                      + codes[i + 3] + b";" + codes[i + 4])
                i += 4
        i += 1
    return fg


def _finalize_span():
    """Trim and push the current span onto the LRU dict if non-empty."""
    global AGENT_SPAN_BUF, AGENT_SPAN_FG
    s = AGENT_SPAN_BUF.strip()
    color = AGENT_SPAN_FG
    AGENT_SPAN_BUF = b""
    AGENT_SPAN_FG = None
    if not s or color is None:
        return False
    key = color + b"\t" + s
    if key in AGENT_SPANS:
        AGENT_SPANS[key] += 1
        AGENT_SPANS.move_to_end(key)
        return False
    AGENT_SPANS[key] = 1
    while len(AGENT_SPANS) > AGENT_OUTPUT_SPANS:
        AGENT_SPANS.popitem(last=False)
    if END_OF_TURN_RE is not None and END_OF_TURN_RE.match(s):
        try:
            msg = s.decode("utf-8", "replace")
        except Exception:
            msg = "agent done"
        debug("END-OF-TURN", msg)
        emit_outer(msg)
    return True


def _flush_agent_file():
    if not AGENT_OUTPUT_FILE:
        return
    try:
        tmp = AGENT_OUTPUT_FILE + ".tmp"
        with open(tmp, "wb") as f:
            for k, count in AGENT_SPANS.items():
                color, text = k.split(b"\t", 1)
                f.write(color + b"\t" + str(count).encode() + b"\t" + text + b"\n")
        os.rename(tmp, AGENT_OUTPUT_FILE)
    except OSError:
        pass


def update_agent_output(data):
    """Walk a chunk byte-by-byte, capturing per-color FG runs as spans.

    State machine:
      * \x1b → try to consume an SGR (updates AGENT_FG) or any other
        complete escape (skipped). On FG change while a span is open,
        finalize that span (preserving its original color id).
      * \n / \r → finalize current span (line breaks shouldn't span runs).
      * any other byte → append to span buffer iff a color is active.

    Incomplete escapes at chunk end carry over via AGENT_PENDING.
    """
    global AGENT_FG, AGENT_SPAN_BUF, AGENT_SPAN_FG, AGENT_PENDING
    if not AGENT_OUTPUT_FILE:
        return
    data = AGENT_PENDING + data
    AGENT_PENDING = b""
    i, n = 0, len(data)
    new_span_count = 0
    while i < n:
        b = data[i:i + 1]
        if b == b"\x1b":
            m = SGR_RE.match(data, i)
            if m:
                new_fg = _sgr_extract_fg(m.group(1), AGENT_FG)
                if new_fg != AGENT_FG and AGENT_SPAN_BUF:
                    if _finalize_span():
                        new_span_count += 1
                AGENT_FG = new_fg
                i = m.end()
                continue
            m = OTHER_ESC_RE.match(data, i)
            if m:
                i = m.end()
                continue
            # Possibly an escape that hasn't fully arrived yet. Carry
            # the rest of the chunk and wait for more bytes. Cap so a
            # malformed stream can't grow it unbounded.
            if n - i < 64:
                AGENT_PENDING = data[i:]
                break
            # Malformed/unknown escape — drop the lone ESC byte and move on.
            i += 1
            continue
        if b == b"\n" or b == b"\r":
            if AGENT_SPAN_BUF:
                if _finalize_span():
                    new_span_count += 1
            i += 1
            continue
        if AGENT_FG is not None:
            if not AGENT_SPAN_BUF:
                AGENT_SPAN_FG = AGENT_FG
            AGENT_SPAN_BUF += b
            if len(AGENT_SPAN_BUF) > AGENT_SPAN_MAX:
                if _finalize_span():
                    new_span_count += 1
        i += 1
    if new_span_count > 0:
        _flush_agent_file()


def resolve_outer_tty_file():
    tag = os.environ.get("PAIR_TAG")
    if not tag:
        return None
    data_dir = os.environ.get("PAIR_DATA_DIR")
    if not data_dir:
        xdg = os.environ.get("XDG_DATA_HOME") or os.path.expanduser("~/.local/share")
        data_dir = os.path.join(xdg, "pair")
    return os.path.join(data_dir, f"outer-tty-{tag}")


def emit_outer(msg="agent attention"):
    """Write OSC 9 to the recorded outer TTY. No-op on any error."""
    global LAST_EMIT
    now = time.monotonic()
    if now - LAST_EMIT < RATE_LIMIT_S:
        debug("EMIT-skip", f"rate-limited ({now - LAST_EMIT:.2f}s since last)")
        return
    if not OUTER_TTY_FILE:
        debug("EMIT-skip", "no outer-tty file resolved")
        return
    try:
        with open(OUTER_TTY_FILE) as f:
            path = f.readline().strip()
        if not path:
            debug("EMIT-skip", "outer-tty file empty")
            return
        fd = os.open(path, os.O_WRONLY | os.O_NONBLOCK)
        try:
            os.write(fd, f"\x1b]9;{msg}\x07".encode())
            LAST_EMIT = now
            debug("EMIT", f"wrote OSC 9 to {path}")
        finally:
            os.close(fd)
    except OSError as e:
        debug("EMIT-fail", f"{path!r}: {e}")


def write_startup_banner():
    """Paint a one-line inverse-video banner above the agent's first output.

    Most TUI agents will either clear the screen or enter the alt-screen
    buffer on startup, so the banner only persists for a beat — long
    enough to flag to a new user that they're inside pair-wrap and tell
    them where to start. We write it before pty.fork so it's the first
    byte the pane sees.
    """
    try:
        sz = fcntl.ioctl(1, termios.TIOCGWINSZ, b"\0" * 8)
        _, cols, _, _ = struct.unpack("hhhh", sz)
    except OSError:
        cols = 80
    text = " ⚙  pair-wrapped · Alt+h for help · Happy coding! "
    if len(text) > cols:
        text = text[:cols]
    padded = (text + " " * max(0, cols - len(text))).encode()
    try:
        # Trailing CRLF puts cursor on row 2; the second CRLF leaves row 2
        # blank in default colors, so the agent's output starts on row 3.
        os.write(1, b"\x1b[7m" + padded + b"\x1b[27m\r\n\r\n")
    except OSError:
        pass


def log_scrollback_event(type_, **fields):
    """Append a JSON event line keyed by current SCROLLBACK_BYTES offset.

    No-op when --scrollback-log isn't enabled. Errors swallowed so a
    write failure can't take down the proxy. Called both at startup
    (initial resize) and from the SIGWINCH handler.
    """
    if SCROLLBACK_EVENTS_FD < 0:
        return
    payload = {"type": type_, "offset": SCROLLBACK_BYTES, **fields}
    line = (json.dumps(payload, separators=(",", ":")) + "\n").encode()
    try:
        os.write(SCROLLBACK_EVENTS_FD, line)
    except OSError as e:
        debug("EVENT-write-fail", str(e))


def set_winsize(master_fd):
    try:
        sz = fcntl.ioctl(0, termios.TIOCGWINSZ, b"\0" * 8)
        rows, cols, _, _ = struct.unpack("hhhh", sz)
        fcntl.ioctl(master_fd, termios.TIOCSWINSZ, sz)
    except OSError:
        return
    log_scrollback_event("resize", cols=cols, rows=rows)


# Match ANY OSC sequence: ESC ] <Ps> ; <body> (BEL | ESC \). We parse all of
# them so claude's frequent title updates (OSC 0/1/2) don't have their BEL
# terminator misread as a "lone bell" by the fallback below. From the parsed
# matches we then filter to ones that mean "agent wants attention" — see
# is_actionable_osc(). Detection runs over a small rolling buffer to catch
# sequences that span read boundaries.
OSC_RE = re.compile(rb"\x1b\](\d+);([^\x07\x1b]*)(?:\x07|\x1b\\)")


def is_actionable_osc(ps: bytes, body: bytes) -> bool:
    """Decide whether an OSC <ps>;<body> is a notification we should forward.

    Skip:
      - OSC 0/1/2: window/icon title sets (claude updates every second with a
        spinner — would spam the outer wrapper).
      - OSC 9;4;...: iTerm progress codes (state 0/3 fire on every tool call).
      - OSC 1337;...: iTerm proprietary extensions (file transfer, etc.).
    Forward:
      - OSC 777;...: standard urxvt-style notification.
      - OSC 9;<text>: iTerm-style notification with text body.
    """
    if ps == b"777":
        return True
    if ps == b"9" and not body.startswith(b"4;"):
        return True
    return False


def main():
    global OUTER_TTY_FILE, AGENT_OUTPUT_FILE
    global SCROLLBACK_FD, SCROLLBACK_EVENTS_FD, SCROLLBACK_BYTES
    global IDLE_S, NOTIFY_MODE_ACTIVE, END_OF_TURN_RE
    OUTER_TTY_FILE = resolve_outer_tty_file()

    # Strip pair-wrap's own flags from argv before resolving the agent
    # command. argparse would be heavier than needed; a tiny loop keeps
    # the dependency surface and behavior obvious. `--` ends flag parsing.
    argv = sys.argv[1:]
    scrollback_log = None
    while argv and argv[0].startswith("-"):
        if argv[0] == "--scrollback-log" and len(argv) > 1:
            scrollback_log = argv[1]
            argv = argv[2:]
        elif argv[0] == "--":
            argv = argv[1:]
            break
        else:
            print(f"pair-wrap: unknown flag {argv[0]!r}", file=sys.stderr)
            return 2

    if not argv:
        print("usage: pair-wrap [--scrollback-log <path>] <command> [args...]",
              file=sys.stderr)
        return 2

    agent_basename = os.path.basename(argv[0])

    if scrollback_log:
        # Derive the events sidecar path from --scrollback-log: trim
        # `.raw` if present, append `.events.jsonl`. Both files are
        # truncated together so a fresh launch starts a clean capture.
        if scrollback_log.endswith(".raw"):
            events_path = scrollback_log[:-4] + ".events.jsonl"
        else:
            events_path = scrollback_log + ".events.jsonl"
        try:
            SCROLLBACK_FD = os.open(
                scrollback_log,
                os.O_WRONLY | os.O_CREAT | os.O_TRUNC,
                0o644,
            )
            debug("SCROLLBACK-open", scrollback_log)
        except OSError as e:
            debug("SCROLLBACK-open-fail", f"{scrollback_log!r}: {e}")
            SCROLLBACK_FD = -1
        if SCROLLBACK_FD >= 0:
            try:
                SCROLLBACK_EVENTS_FD = os.open(
                    events_path,
                    os.O_WRONLY | os.O_CREAT | os.O_TRUNC,
                    0o644,
                )
                debug("EVENTS-open", events_path)
            except OSError as e:
                debug("EVENTS-open-fail", f"{events_path!r}: {e}")
                SCROLLBACK_EVENTS_FD = -1

    # Span extraction is calibrated per agent; only enable for known ones.
    # update_agent_output() short-circuits when AGENT_OUTPUT_FILE is None.
    if agent_basename in SPAN_EXTRACTION_AGENTS:
        AGENT_OUTPUT_FILE = resolve_agent_output_file()
    else:
        debug("SPAN-disable", f"{agent_basename} not in SPAN_EXTRACTION_AGENTS")

    NOTIFY_MODE_ACTIVE = NOTIFY_MODE.get(agent_basename, NOTIFY_MODE_DEFAULT)
    debug("NOTIFY-mode", f"{agent_basename}={NOTIFY_MODE_ACTIVE}")
    if NOTIFY_MODE_ACTIVE == "marker":
        END_OF_TURN_RE = END_OF_TURN_BY_AGENT.get(agent_basename)
        if END_OF_TURN_RE is None:
            debug("MARKER-missing",
                  f"{agent_basename} has no END_OF_TURN_BY_AGENT entry")
    if NOTIFY_MODE_ACTIVE != "idle":
        IDLE_S = 0

    write_startup_banner()

    pid, master = pty.fork()
    if pid == 0:
        try:
            os.execvp(argv[0], argv)
        except OSError as e:
            sys.stderr.write(f"pair-wrap: cannot exec {argv[0]}: {e}\n")
            os._exit(127)

    set_winsize(master)
    signal.signal(signal.SIGWINCH, lambda *_: set_winsize(master))

    # Switch our stdin into raw mode for the duration. Without this, the
    # kernel's terminal driver does line discipline on the bytes flowing
    # in (canonical mode + echo + signal interpretation), which double-
    # echoes keystrokes and corrupts terminal escape responses bound for
    # the wrapped child. The child's own slave PTY has its own (raw) mode
    # set by the wrapped TUI; this only affects OUR view of stdin.
    saved_termios = None
    try:
        saved_termios = termios.tcgetattr(0)
        tty.setraw(0)
    except (termios.error, OSError):
        pass

    rolling = b""
    fds = [0, master]  # drop fd 0 from the watch list once stdin EOFs
    last_master_activity = time.monotonic()
    idle_fired = False

    try:
        while master in fds:
            if IDLE_S > 0 and not idle_fired:
                remaining = IDLE_S - (time.monotonic() - last_master_activity)
                timeout = max(0.0, remaining)
            else:
                timeout = None
            try:
                r, _, _ = select.select(fds, [], [], timeout)
            except OSError as e:
                if e.errno == errno.EINTR:
                    continue
                break

            if not r and IDLE_S > 0 and not idle_fired:
                if time.monotonic() - last_master_activity >= IDLE_S:
                    debug("IDLE", f"no agent output for {IDLE_S:.0f}s")
                    emit_outer("agent idle")
                    idle_fired = True
                continue

            if 0 in r:
                try:
                    data = os.read(0, 4096)
                except OSError:
                    data = b""
                if not data:
                    # stdin EOF (e.g. non-interactive parent). Stop watching
                    # stdin but keep draining the child's output until it
                    # exits.
                    fds = [master]
                else:
                    try:
                        os.write(master, data)
                    except OSError:
                        fds = [master]

            if master in r:
                try:
                    data = os.read(master, 4096)
                except OSError:
                    data = b""
                if not data:
                    break
                last_master_activity = time.monotonic()
                idle_fired = False
                try:
                    os.write(1, data)
                except OSError:
                    pass
                if SCROLLBACK_FD >= 0:
                    try:
                        n = os.write(SCROLLBACK_FD, data)
                        SCROLLBACK_BYTES += n
                    except OSError as e:
                        debug("SCROLLBACK-write-fail", str(e))
                try:
                    update_agent_output(data)
                except Exception as e:
                    debug("AGENT-OUT-fail", str(e))  # never block the proxy
                try:
                    rolling = (rolling + data)[-512:]
                    matches = list(OSC_RE.finditer(rolling))
                    if matches:
                        # Drop everything up to the end of the last matched
                        # OSC so we don't re-process it on the next read.
                        rolling = rolling[matches[-1].end():]
                        actioned = False
                        for m in matches:
                            ps, body = m.group(1), m.group(2)
                            if is_actionable_osc(ps, body):
                                if NOTIFY_MODE_ACTIVE == "native":
                                    debug(f"OSC{ps.decode()}",
                                          body[:80] + (b"..." if len(body) > 80 else b""))
                                    if not actioned:
                                        emit_outer()
                                        actioned = True
                                else:
                                    # Mode owns notification; native OSC is
                                    # logged but not forwarded so the chosen
                                    # source is the only one that fires.
                                    debug(f"OSC{ps.decode()}-swallow", body[:80])
                            else:
                                debug(f"OSC{ps.decode()}-skip", body[:80])
                    elif b"\x07" in data:
                        idx = data.index(b"\x07")
                        snippet = data[max(0, idx - 16):idx + 16]
                        if BELL_FALLBACK and NOTIFY_MODE_ACTIVE == "native":
                            debug("BEL", snippet)
                            emit_outer()
                        else:
                            # Detection still logged so PAIR_WRAP_LOG remains a
                            # complete forensic record — useful for spotting an
                            # agent that genuinely uses bare BEL.
                            debug("BEL-skip", snippet)
                except Exception as e:
                    debug("DETECT-fail", str(e))  # never block the proxy
    finally:
        if saved_termios is not None:
            try:
                termios.tcsetattr(0, termios.TCSAFLUSH, saved_termios)
            except (termios.error, OSError):
                pass
        if SCROLLBACK_FD >= 0:
            try:
                os.close(SCROLLBACK_FD)
            except OSError:
                pass
        if SCROLLBACK_EVENTS_FD >= 0:
            try:
                os.close(SCROLLBACK_EVENTS_FD)
            except OSError:
                pass

    try:
        _, status = os.waitpid(pid, 0)
    except OSError:
        return 1
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    return 1


if __name__ == "__main__":
    sys.exit(main())
