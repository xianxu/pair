// pair main layout — top: TUI agent, bottom: nvim drafting pane.
//
// Agent, tag, and pair home resolved from environment at exec time:
//   $PAIR_AGENT       — agent command to exec (claude, codex, agy, ...)
//   $PAIR_AGENT_ARGS  — extra args after `--` on the pair command line
//   $PAIR_TAG         — namespace ID for files (e.g. "claude" or "bugfix")
//   $PAIR_HOME        — pair install location (for nvim init)
// All four are exported by bin/pair before invoking zellij.
//
// We wrap the commands in `sh -c` so the shell does the env interpolation.
// zellij itself does not expand env vars in `command`/`args` fields.
//
// The agent runs under pair-wrap, a transparent PTY proxy that translates
// the agent's BEL/OSC notifications into an OSC 9 written directly to pair's
// outer TTY, so outer wrappers (e.g. cmux) see attention markers despite
// zellij's escape filtering. #000011
//
// LAYOUT RUNGS — the draft pane has three sizes: minimized (1 row,
// statusline only) ↔ small (fixed 12 rows, initial) ↔ third (1/3). Alt+Up /
// Alt+Down step the ladder via zellij's swap layouts (defined below).
// Swap layouts re-tile existing panes — the agent and nvim processes are
// preserved across rung changes; zellij maps existing panes onto the new
// layout positionally.

layout {
    pane split_direction="horizontal" {
        pane name="agent" {
            command "sh"
            // --scrollback-log captures the raw PTY stream + a resize
            // sidecar so Alt+/ can render an ANSI-colored, line-numbered
            // view of scrollback on demand (#000017). DATA_DIR/PAIR_*
            // are exported by bin/pair before zellij launches, so the
            // sh -c form below resolves them at exec time.
            //
            // The leading `zellij action rename-pane` overrides the
            // layout's literal pane name ("agent") with the agent's
            // binary name (PAIR_PANE_TITLE — claude / codex / agy),
            // so the pane frame reads as that instead of the generic
            // "agent". `--pane-id $ZELLIJ_PANE_ID` is required because
            // `rename-pane` defaults to the focused pane, and the
            // layout focuses the draft pane (focus=true) — without
            // explicit targeting, this would silently rename draft.
            // Errors swallowed: if the IPC call fails we still launch
            // the agent.
            args "-c" "_pdd=\"${PAIR_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/pair}\"; printf '{\"pane_id\":\"%s\",\"cwd\":\"%s\",\"cwd_display\":\"%s\"}\\n' \"$ZELLIJ_PANE_ID\" \"$PWD\" \"${PAIR_PANE_CWD:-$PWD}\" > \"$_pdd/pane-${PAIR_TAG:-${PAIR_AGENT:-claude}}-${PAIR_AGENT:-claude}.json\" 2>/dev/null; zellij action rename-pane --pane-id \"$ZELLIJ_PANE_ID\" \"${PAIR_PANE_TITLE:-agent}\" 2>/dev/null; exec pair wrap --scrollback-log \"${PAIR_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/pair}/scrollback-${PAIR_TAG:-${PAIR_AGENT:-claude}}-${PAIR_AGENT:-claude}.raw\" ${PAIR_AGENT:-claude} ${PAIR_AGENT_ARGS:-}"
        }
        // Pane name "draft" appears in zellij's OSC 0 terminal title
        // ("<session>: draft") and propagates to the user's terminal /
        // multiplexer tab title. The draft is borderless (the agent
        // pane is framed for the scroll indicator; the draft must stay
        // borderless so the `minimized` rung can collapse to 1 row),
        // so it has no frame title slot — the name exists only for OSC
        // 0 propagation.
        //
        // size=12 (integer) is the middle rung ("small") — a fixed
        // 12-row draft pane is enough for ~9-10 lines of prompt with
        // the statusline. zellij tags integer sizes as FIXED (refusing
        // `resize` actions), but pair drives all rung changes through
        // swap layouts, not resize, so FIXED is harmless here.
        pane size=12 name="draft" borderless=true focus=true {
            command "sh"
            // PAIR_NVIM_PID_FILE: nvim/init.lua's VimEnter autocmd writes the
            // embed pid here so cleanup_quit_marker in bin/pair can reap
            // deterministically on Alt+x. Without this, the embed nvim
            // (forked off the TUI) can survive zellij's kill-session and
            // accumulate as PPID=1 orphans across quits.
            args "-c" "DATA_DIR=\"${XDG_DATA_HOME:-$HOME/.local/share}/pair\" && mkdir -p \"$DATA_DIR\" && export PAIR_NVIM_PID_FILE=\"$DATA_DIR/nvim-pid-${PAIR_TAG:-${PAIR_AGENT:-claude}}-draft\" && exec nvim -u \"$PAIR_HOME/nvim/init.lua\" \"$DATA_DIR/draft-${PAIR_TAG:-${PAIR_AGENT:-claude}}.md\""
        }
    }

    // Swap layouts: zellij's `next-swap-layout` / `previous-swap-layout`
    // actions cycle through these alongside the default layout above,
    // re-tiling existing panes positionally. Pane processes (pair-wrap,
    // nvim) survive each swap.
    //
    // Cycle from default(small) — assuming swap order [minimized, third]:
    //   default → next → minimized → next → third → next → default
    //   default → prev → third → prev → minimized → prev → default
    //
    // nvim/init.lua maps Alt+Down → next-swap-layout (smaller rung) and
    // Alt+Up → prev-swap-layout (bigger rung), with a state-machine clamp
    // at each end so we never call past the rung extremes.
    //
    // exact_panes=2 constrains the swap layout to apply only when the
    // current pane count matches what we built (agent + draft). pair
    // never has any other pane shape, so this is always satisfied.
    //
    // Leaf panes carry only structural attributes (name, size,
    // borderless) — no `command` block. zellij maps existing panes onto
    // these leaf positions; if we repeated the command, there's a risk
    // zellij would treat that as a request to spawn a new pane rather
    // than match an existing one.
    //
    // The draft pane carries `borderless=true` in every rung so it can
    // collapse to size=1 in `minimized`; the agent pane stays framed so
    // its scroll indicator (top-right) is visible.

    swap_tiled_layout name="minimized" {
        tab exact_panes=2 {
            pane split_direction="horizontal" {
                pane name="agent"
                pane size=1 name="draft" borderless=true
            }
        }
    }

    swap_tiled_layout name="third" {
        tab exact_panes=2 {
            pane split_direction="horizontal" {
                pane name="agent"
                pane size="33%" name="draft" borderless=true
            }
        }
    }
}
