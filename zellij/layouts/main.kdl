// pair main layout — top: TUI agent, bottom: nvim drafting pane.
//
// Agent, tag, and pair home resolved from environment at exec time:
//   $PAIR_AGENT       — agent command to exec (claude, codex, gemini, ...)
//   $PAIR_AGENT_ARGS  — extra args after `--` on the pair command line
//   $PAIR_TAG         — namespace ID for files (e.g. "claude" or "bugfix")
//   $PAIR_HOME        — pair install location (for nvim init)
// All four are exported by bin/pair before invoking zellij.
//
// We wrap the commands in `sh -c` so the shell does the env interpolation.
// zellij itself does not expand env vars in `command`/`args` fields.
//
// The agent runs under pair-wrap, a transparent PTY proxy that translates
// the agent's BEL/OSC notifications into an OSC 9 written directly to pair's
// outer TTY, so outer wrappers (e.g. cmux) see attention markers despite
// zellij's escape filtering. #000011

layout {
    pane split_direction="horizontal" {
        pane name="agent" {
            command "sh"
            args "-c" "exec pair-wrap ${PAIR_AGENT:-claude} ${PAIR_AGENT_ARGS:-}"
        }
        // Initial pane name is just "draft" so the OSC 0 terminal title
        // ("session: pane-name") stays compact. nvim widens the name on
        // startup via `zellij action rename-pane` to embed the keybind
        // cheatsheet right-aligned in the frame — terminal title truncates
        // before the cheatsheet so it stays clean. See pair_update_pane_name
        // in nvim/init.lua.
        pane size=11 name="draft" focus=true {
            command "sh"
            args "-c" "DATA_DIR=\"${XDG_DATA_HOME:-$HOME/.local/share}/pair\" && mkdir -p \"$DATA_DIR\" && exec nvim -u \"$PAIR_HOME/nvim/init.lua\" \"$DATA_DIR/draft-${PAIR_TAG:-${PAIR_AGENT:-claude}}.md\""
        }
    }
}
