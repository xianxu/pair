# Repo-specific Makefile targets.
# This file is included by Makefile — add your own targets here.

.PHONY: pair-bootstrap tart tart-gui tart-mount tart-stop tart-clean \
        build install pair-scribe pair-scrollback-render pair-wrap

# Cross-cutting Go-binary targets. Every Go binary lives under cmd/<name>/
# and ships with the `pair-` prefix so it doesn't collide with anything
# else on PATH (pair-scribe replaced an earlier bare-named `scribe`).
#
# Adding a new binary: drop main.go under cmd/<name>/, append <name>
# to GO_BINS, add the per-binary recipe stanza. `make build` and
# `make install` pick it up automatically.
#
#   make build      → compile every binary in GO_BINS into ./bin/
#   make install    → also copy each into ~/.local/bin/
#   make <name>     → build just that one (e.g., `make pair-scribe`)
#
# Why ./bin/ for the in-tree build: keeps Go output next to the shell
# scripts pair already ships from bin/, and pair-scrollback-open looks
# at $PAIR_HOME/bin/pair-scrollback-render to pick up the Go renderer
# in both dev (source tree) and brew-install layouts.
#
# Why ~/.local/bin/ for install: XDG convention, on PATH per the user's
# zshrc. Each binary the user wires into their shell (e.g. pair-scribe
# in zshrc) should reference $HOME/.local/bin/<name>.

BIN_DIR     := bin
INSTALL_DIR := $(HOME)/.local/bin
GO_BINS     := pair-scribe pair-scrollback-render pair-wrap

build: $(addprefix $(BIN_DIR)/,$(GO_BINS))

install: build
	@mkdir -p $(INSTALL_DIR)
	@for b in $(GO_BINS); do \
	    install -m 755 $(BIN_DIR)/$$b $(INSTALL_DIR)/$$b && \
	    echo "installed: $(INSTALL_DIR)/$$b"; \
	done

# Per-binary aliases — `make pair-scribe`, etc.
pair-scribe:            $(BIN_DIR)/pair-scribe
pair-scrollback-render: $(BIN_DIR)/pair-scrollback-render
pair-wrap:              $(BIN_DIR)/pair-wrap

# pair-scribe — Go-based pty wrapper with SIGUSR1/SIGUSR2 pause/resume
# of the typescript log. Replaces script(1) at the top of the user's
# shell, so preexec can stop the log from filling with TUI redraw bytes
# (claude, nvim, etc). See cmd/pair-scribe/README.md for the full why.
$(BIN_DIR)/pair-scribe: cmd/pair-scribe/main.go go.mod
	go build -o $@ ./cmd/pair-scribe

# pair-scrollback-render — Go reimplementation of the pyte-based
# bin/pair-scrollback-render.py using charmbracelet/x/vt. Replays a
# pair-wrap raw PTY capture and emits one ANSI-styled output line per
# logical scrollback row, for the Alt+/ viewer to display through nvim.
# ~10× faster than the Python version, no Python runtime dependency,
# single static binary.
#
# pair-scrollback-open prefers this binary when present; otherwise it
# falls back to the .py renderer. After confidence builds, drop the
# Python script + brew formula pyte vendoring in a follow-up (#19).
$(BIN_DIR)/pair-scrollback-render: cmd/pair-scrollback-render/main.go go.mod
	go build -o $@ ./cmd/pair-scrollback-render

# pair-wrap — Go port of bin/pair-wrap.py (filed #000011). Transparent
# PTY proxy around a TUI coding agent: forwards stdio, tees scrollback
# log, extracts colored spans for nvim autocomplete, detects OSC/BEL and
# forwards as OSC 9 to the recorded outer-TTY, handles SIGUSR1 image-
# paste capture window. Python fallback at bin/pair-wrap.py (kept until
# the Go binary has soaked in a session).
$(BIN_DIR)/pair-wrap: cmd/pair-wrap/main.go go.mod
	go build -o $@ ./cmd/pair-wrap


# pair-bootstrap — install pair's runtime Python dependencies.
#
# Distinct from `make bootstrap` (.openshell/Makefile), which sets up
# the OpenShell sandbox tooling. This target is for pair end-users:
# brew install pair handles the binary deps (zellij, nvim, fzf, jq, par);
# this fills in the pip-managed extras that the brew formula can't
# easily own.
#
# Currently:
#   - pyte: required by `Alt+/` (bin/pair-scrollback-render). Without
#     it, capture still happens but the viewer prints an install hint
#     and exits.
#
# `--break-system-packages` is needed on Python 3.11+ on systems with
# PEP 668 marker files (Homebrew Python sets one). Falls back to a plain
# install on systems without the flag — older pip rejects the unknown flag.
pair-bootstrap:
	@echo "==> Installing pair runtime dependencies..."
	@if python3 -c 'import pyte' 2>/dev/null; then \
		echo "  [ok] pyte already installed"; \
	else \
		echo "  [..] Installing pyte..."; \
		pip3 install --user --break-system-packages pyte 2>/dev/null \
			|| pip3 install --user pyte; \
	fi
	@echo ""
	@echo "Done. Try Alt+/ in a pair session to see the colored scrollback viewer."

# ----------------------------------------------------------------------------
# Tart integration — test pair on a clean macOS VM.
#
# Apple Silicon only (Tart uses Apple Virtualization framework). One-time
# `tart pull` of the base image is ~30 GB; subsequent `tart clone` is
# copy-on-write, so per-VM cost is small.
#
# Workflow:
#   make tart            # boots a fresh VM, ssh's in (admin / admin)
#   (inside) install brew + clone pair + run, e.g.:
#     /bin/bash -c "$$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
#     eval "$$(/opt/homebrew/bin/brew shellenv)"
#     brew tap xianxu/pair && brew install pair && pair        # released
#     # — or for testing main —
#     git clone https://github.com/xianxu/pair.git && cd pair && bin/pair
#   exit                 # leave ssh; VM keeps running
#   make tart-stop       # stop VM, state preserved
#   make tart-clean      # stop + delete VM
#
#   make tart-mount      # same as `make tart` but mounts the local
#                        # repo into the VM at
#                        # /Volumes/My\ Shared\ Files/pair
#                        # so you can edit on the host and run inside.
#
# All four targets are idempotent: if the VM already exists / is running,
# they reuse it instead of erroring.
# ----------------------------------------------------------------------------

TART_BASE      ?= ghcr.io/cirruslabs/macos-tahoe-base:latest
TART_VM        ?= pair-test
# --no-graphics by default; tart-gui overrides to empty to bring up
# the macOS Virtualization window. Graphics mode is a cold-boot
# setting, so tart-gui force-restarts a running headless VM (parallel
# to tart-mount's --dir handling).
GRAPHICS_FLAG  ?= --no-graphics

# Detect other tart VMs running on the host. Each VM costs 4-8 GB of
# resident RAM; running several in parallel is rarely intended. List
# them, ask y/N, stop them on yes. Bare Enter or anything not-yes
# leaves them alone and proceeds.
#
# Filter: source=local (skip OCI images), name != $(TART_VM) (skip
# ourself), last field == "running". Tart's `Accessed` column has
# spaces ("3 days ago") but state is always a single word at $NF.
define _tart_check_others
	@others=$$(tart list 2>/dev/null | awk -v me=$(TART_VM) \
	    'NR>1 && $$1=="local" && $$2!=me && $$NF=="running" {print $$2}'); \
	if [ -n "$$others" ]; then \
	    echo "==> Other tart VMs currently running:"; \
	    echo "$$others" | sed 's/^/    /'; \
	    printf "Stop them before continuing? [y/N] "; \
	    read -r answer; \
	    case "$$answer" in \
	        [yY]|[yY][eE][sS]) \
	            for vm in $$others; do \
	                echo "    stopping $$vm..."; \
	                tart stop "$$vm" 2>/dev/null || true; \
	            done ;; \
	    esac; \
	fi
endef

# Common preamble: tart present, base pulled, VM cloned (idempotent).
define _tart_ensure_vm
	@command -v tart >/dev/null || \
	    { echo "Install tart: brew install cirruslabs/cli/tart"; exit 1; }
	@if ! tart list --source local -q 2>/dev/null | grep -qx $(TART_VM); then \
	    echo "==> Pulling $(TART_BASE)..."; \
	    tart pull $(TART_BASE); \
	    echo "==> Cloning to $(TART_VM)..."; \
	    tart clone $(TART_BASE) $(TART_VM); \
	fi
endef

# Boot in background (no-op if already running), poll for SSH, then
# exec ssh -t for an interactive shell. RUN_FLAGS lets `tart-mount`
# inject --dir without duplicating the rest of the recipe.
#
# Gate the boot decision on `tart list`'s State column, not on
# `tart ip`. Tart caches the last-known IP for a stopped VM, so
# `tart ip` succeeds even when the VM isn't running — which was
# silently skipping the boot branch and leaving the loop polling a
# dead address until ssh inevitably failed with "Host is down".
define _tart_boot_and_ssh
	@state=$$(tart list 2>/dev/null | awk -v vm=$(TART_VM) '$$2==vm {print $$NF}'); \
	if [ "$$state" != "running" ]; then \
	    echo "==> Booting VM..."; \
	    nohup tart run $(GRAPHICS_FLAG) $(RUN_FLAGS) $(TART_VM) >/tmp/tart-$(TART_VM).log 2>&1 & \
	fi
	@echo "==> Waiting for SSH..."
	@for i in $$(seq 1 60); do \
	    ip=$$(tart ip $(TART_VM) 2>/dev/null); \
	    if [ -n "$$ip" ] && nc -z -G 2 "$$ip" 22 2>/dev/null; then break; fi; \
	    sleep 2; \
	done
	@ip=$$(tart ip $(TART_VM)); \
	    if ! nc -z -G 2 "$$ip" 22 2>/dev/null; then \
	        echo "==> SSH never came up at $$ip (boot log: /tmp/tart-$(TART_VM).log)"; \
	        exit 1; \
	    fi; \
	    pubkey=$$(ls ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub 2>/dev/null | head -1); \
	    if [ -n "$$pubkey" ] && ! ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
	            -o BatchMode=yes -o ConnectTimeout=3 admin@$$ip true 2>/dev/null; then \
	        echo "==> Installing $$pubkey for passwordless ssh (one-time per VM)..."; \
	        if command -v sshpass >/dev/null; then \
	            sshpass -p admin ssh-copy-id -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
	                -i "$$pubkey" admin@$$ip >/dev/null 2>&1; \
	        else \
	            echo "    (sshpass not installed → interactive prompt; install with"; \
	            echo "     'brew install hudochenkov/sshpass/sshpass' to make this silent)"; \
	            ssh-copy-id -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
	                -i "$$pubkey" admin@$$ip; \
	        fi; \
	    fi; \
	    if [ -f "$(CURDIR)/scripts/tart-vm-rc.zsh" ] && [ -f "$(CURDIR)/scripts/tart-vm-setup.sh" ]; then \
	        scp -q -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
	            "$(CURDIR)/scripts/tart-vm-rc.zsh"    admin@$$ip:.tart-vm-rc.zsh; \
	        scp -q -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
	            "$(CURDIR)/scripts/tart-vm-setup.sh" admin@$$ip:.tart-vm-setup.sh; \
	        ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null admin@$$ip \
	            'bash ~/.tart-vm-setup.sh'; \
	    fi; \
	    echo "==> ssh admin@$$ip"; \
	    ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
	        -t admin@$$ip \
	        'export TERM=xterm-256color; stty erase "^?"; M="/Volumes/My Shared Files/pair"; if [ -d "$$M" ]; then ln -sfn "$$M" "$$HOME/repo"; elif [ -L "$$HOME/repo" ]; then rm "$$HOME/repo"; fi; exec $$SHELL -l' \
	        || true
endef
# `|| true` on the ssh: ssh propagates the remote shell's exit status.
# When the VM user types `exit`, zsh returns $? from its last automatic
# command (commonly non-zero from compinit / /etc/zshrc on fresh macOS).
# That's a normal session-ended event, not a make failure — swallow it.

tart:
	$(call _tart_check_others)
	$(call _tart_ensure_vm)
	$(call _tart_boot_and_ssh)

tart-gui: GRAPHICS_FLAG :=
tart-gui:
	$(call _tart_check_others)
	$(call _tart_ensure_vm)
	@# Graphics mode is a cold-boot setting; can't be hot-attached
	@# to a running VM. If the VM is up headless (e.g., from a prior
	@# `make tart`), stop it so the next boot brings up the window.
	@if tart list 2>/dev/null | awk -v vm=$(TART_VM) '$$2==vm {print $$NF}' | grep -qx running; then \
	    echo "==> Stopping VM to switch to GUI mode (cold-boot only setting)..."; \
	    tart stop $(TART_VM); \
	fi
	@echo "==> Booting with macOS Virtualization window (close window or 'make tart-stop' to stop)"
	$(call _tart_boot_and_ssh)

tart-mount: RUN_FLAGS = --dir=pair:$(CURDIR):ro
tart-mount:
	$(call _tart_check_others)
	$(call _tart_ensure_vm)
	@# `tart run --dir=...` is a cold-boot setting; can't be hot-attached
	@# to a running VM. If the VM is already up (e.g., from a prior
	@# `make tart`), stop it so the next boot applies the share.
	@if tart list 2>/dev/null | awk -v vm=$(TART_VM) '$$2==vm {print $$NF}' | grep -qx running; then \
	    echo "==> Stopping VM to apply --dir mount (cold-boot only setting)..."; \
	    tart stop $(TART_VM); \
	fi
	@echo "==> Local tree will be mounted at /Volumes/My Shared Files/pair (read-only)"
	$(call _tart_boot_and_ssh)

tart-stop:
	@if tart ip $(TART_VM) >/dev/null 2>&1; then tart stop $(TART_VM); fi

tart-clean: tart-stop
	@if tart list --source local -q 2>/dev/null | grep -qx $(TART_VM); then \
	    tart delete $(TART_VM); \
	fi
