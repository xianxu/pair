# Repo-specific Makefile targets.
# This file is included by Makefile — add your own targets here.

.PHONY: build install pair pair-scribe pair-scrollback-render pair-wrap pair-slug pair-changelog pair-context pair-session-watch pair-title pair-scrollback-open pair-changelog-open pair-review-target pair-review-open pair-review-readiness pair-go copy-on-select clipboard-to-pane flash-pane runtimebundle-generate runtimebundle-drift-check test-runtimebundle test test-race test-run-headless test-lua test-queue test-autopair test-cr test-statusline test-doctor test-adapt-schema test-dev-rebuild test-pair-go-install-layout test-pair-embedded-runtime test-pair-restart-quit test-emitter-health test-session-watch test-changelog test-copy-on-select test-pair-title test-zellij-trace

# Cross-cutting Go-binary targets. Every Go binary lives under cmd/<name>/
# and ships with the `pair-` prefix so it doesn't collide with anything
# else on PATH (pair-scribe replaced an earlier bare-named `scribe`).
#
# Adding a new binary: drop main.go under cmd/<name>/, append <name>
# to GO_BINS, add the per-binary recipe stanza. `make build` and
# `make install` pick it up automatically.
#
#   make build      → compile every binary in GO_BINS into ./bin/
#   make install    → also copy each into ~/.local/bin/
#   make <name>     → build just that one (e.g., `make pair-scribe`)
#
# Why ./bin/ for the in-tree build: keeps Go output next to the shell
# scripts pair already ships from bin/, and pair-scrollback-open looks
# at $PAIR_HOME/bin/pair-scrollback-render to pick up the Go renderer
# in both dev (source tree) and brew-install layouts.
#
# Why ~/.local/bin/ for install: XDG convention, on PATH per the user's
# zshrc. Each binary the user wires into their shell (e.g. pair-scribe
# in zshrc) should reference $HOME/.local/bin/<name>.

BIN_DIR     := bin
INSTALL_DIR := $(HOME)/.local/bin
GO_BINS     := pair pair-scribe pair-scrollback-render pair-wrap pair-slug pair-continuation pair-changelog pair-context pair-session-watch pair-title pair-scrollback-open pair-changelog-open pair-review-target pair-review-open pair-review-readiness pair-go copy-on-select clipboard-to-pane flash-pane
SHELL_BINS  := pair-dev
PAIR_HOME_LDFLAGS := -X main.defaultPairHome=$(CURDIR)
RUNTIMEBUNDLE_HELPERS := pair-scrollback-render pair-wrap pair-slug pair-continuation pair-changelog pair-context pair-session-watch pair-title pair-scrollback-open pair-changelog-open pair-review-target pair-review-open pair-review-readiness copy-on-select clipboard-to-pane flash-pane
RUNTIMEBUNDLE_ASSETS := cmd/internal/runtimebundle/assets/runtime/manifest.json

build: $(addprefix $(BIN_DIR)/,$(GO_BINS))

install: build
	@mkdir -p $(INSTALL_DIR)
	@for b in $(GO_BINS); do \
	    install -m 755 $(BIN_DIR)/$$b $(INSTALL_DIR)/$$b && \
	    echo "installed: $(INSTALL_DIR)/$$b"; \
	done
	@for b in $(SHELL_BINS); do \
	    ln -sf "$(CURDIR)/$(BIN_DIR)/$$b" "$(INSTALL_DIR)/$$b" && \
	    echo "linked: $(INSTALL_DIR)/$$b -> $(CURDIR)/$(BIN_DIR)/$$b"; \
	done

# Per-binary aliases — `make pair-scribe`, etc.
pair:                   $(BIN_DIR)/pair
pair-scribe:            $(BIN_DIR)/pair-scribe
pair-scrollback-render: $(BIN_DIR)/pair-scrollback-render
pair-wrap:              $(BIN_DIR)/pair-wrap
pair-slug:              $(BIN_DIR)/pair-slug
pair-continuation:      $(BIN_DIR)/pair-continuation
pair-changelog:         $(BIN_DIR)/pair-changelog
pair-context:           $(BIN_DIR)/pair-context
pair-session-watch:     $(BIN_DIR)/pair-session-watch
pair-title:             $(BIN_DIR)/pair-title
pair-scrollback-open:   $(BIN_DIR)/pair-scrollback-open
pair-changelog-open:    $(BIN_DIR)/pair-changelog-open
pair-review-target:     $(BIN_DIR)/pair-review-target
pair-review-open:       $(BIN_DIR)/pair-review-open
pair-review-readiness:  $(BIN_DIR)/pair-review-readiness
pair-go:                $(BIN_DIR)/pair-go
copy-on-select:         $(BIN_DIR)/copy-on-select
clipboard-to-pane:      $(BIN_DIR)/clipboard-to-pane
flash-pane:             $(BIN_DIR)/flash-pane

# Tests
#   make test       → go test ./... (cache disabled so reruns actually run)
#   make test-race  → race-detector run, scoped to packages where the
#                     suite has actual concurrent code worth checking.
#                     pair-wrap has translateStdin's goroutine + timer +
#                     channels; pair-scrollback-render's render() spawns
#                     a goroutine drainer that races with em.Close()
#                     inside the vt.Emulator library API itself, which is
#                     outside our scope to fix — exclude that package
#                     here rather than chase a library-level race.
test: test-run-headless test-lua test-queue test-autopair test-cr test-statusline test-doctor test-adapt-schema test-dev-rebuild test-pair-go-install-layout test-pair-embedded-runtime test-pair-restart-quit test-emitter-health test-session-watch test-changelog test-copy-on-select test-pair-title test-zellij-trace test-review
	go test ./... -count=1

# pair-title poller (#93 M1, now Go): single-instance guard (identity-checked
# liveness so a recycled PID can't suppress the respawn) + the #71 frame meter
# (renames each agent pane to "<agent> (<count>) [<cwd>]", with unchanged-skip)
# + the cmux heat-ramp. The old shell harness (PAIR_TITLE_TEST_CALL hook) retired
# with the port; its coverage moved to Go unit tests over the Runtime seam.
test-pair-title:
	go test ./cmd/internal/titlepoller ./cmd/internal/procutil -count=1

# Session id watcher must ignore stale pidfiles from prior launches and wait
# for pair-wrap to publish the current agent PID.
test-session-watch: $(BIN_DIR)/pair-session-watch
	bash tests/pair-session-watch-test.sh

runtimebundle-generate: $(addprefix $(BIN_DIR)/,$(RUNTIMEBUNDLE_HELPERS))
	go run ./cmd/internal/runtimebundle/generatecmd --repo . --out cmd/internal/runtimebundle/assets/runtime

$(RUNTIMEBUNDLE_ASSETS): runtimebundle-generate

runtimebundle-drift-check: $(addprefix $(BIN_DIR)/,$(RUNTIMEBUNDLE_HELPERS))
	@d1="$$(mktemp -d)"; d2="$$(mktemp -d)"; \
	trap 'rm -rf "$$d1" "$$d2"' EXIT; \
	go run ./cmd/internal/runtimebundle/generatecmd --repo . --out "$$d1/runtime" && \
	go run ./cmd/internal/runtimebundle/generatecmd --repo . --out "$$d2/runtime" && \
	diff -qr "$$d1/runtime" "$$d2/runtime" >/dev/null && \
	find "$$d1/runtime/files" -type f -exec stat -f '%N %OLp' {} + | sed "s#$$d1/runtime/files/##" | sort > "$$d1/modes" && \
	find "$$d2/runtime/files" -type f -exec stat -f '%N %OLp' {} + | sed "s#$$d2/runtime/files/##" | sort > "$$d2/modes" && \
	diff -u "$$d1/modes" "$$d2/modes" >/dev/null

test-runtimebundle: runtimebundle-generate
	go test ./cmd/internal/runtimebundle -count=1

# Review workbench (#66): the integration shell tests. The pure modules
# (record, reconstruct) run under `make test-lua`.
# The review helpers are now built Go binaries (#93 M3), not committed shell
# scripts — declare them as prereqs so a fresh-tree `make test` builds them
# before the review suite execs `$ROOT/bin/pair-review-*`.
test-review: $(BIN_DIR)/pair-review-target $(BIN_DIR)/pair-review-open $(BIN_DIR)/pair-review-readiness
	bash tests/review-docflow-test.sh
	bash tests/review-apply-test.sh
	bash tests/review-handoff-test.sh
	bash tests/review-loop-test.sh
	bash tests/review-projection-test.sh
	bash tests/review-poke-test.sh
	bash tests/review-window-test.sh
	bash tests/review-toggle-test.sh
	bash tests/pair-review-target-test.sh
	bash tests/review-readiness-cli-test.sh
	bash tests/review-indicator-test.sh
	bash tests/review-resume-test.sh

test-race:
	go test -count=1 -race ./cmd/pair-wrap/

# Self-test for the headless-nvim timeout watchdog (tests/lib/run-headless.sh,
# #60). Runs FIRST in `test` so the safety net every headless-nvim sub-target
# now relies on is proven before those targets run — without it, a driver that
# fails to quit (bare `qall` on a modified buffer → E37) hangs the whole suite.
test-run-headless:
	bash tests/run-headless-test.sh

# Headless Lua tests for nvim/*.lua decision modules (issue #000027). nvim -l
# runs a Lua script in nvim's interpreter with the full vim.api available, so
# pure logic AND buffer-manipulation can be asserted without a UI.
test-lua:
	nvim -l nvim/slug_test.lua
	nvim -l nvim/scrollback_test.lua
	nvim -l nvim/annotate_test.lua
	nvim -l nvim/changelog_test.lua
	nvim -l nvim/adapt_test.lua
	nvim -l nvim/doctor_test.lua
	nvim -l nvim/review/record_test.lua
	nvim -l nvim/review/reconstruct_test.lua
	nvim -l nvim/review/markers_test.lua
	nvim -l nvim/review/seam_test.lua
	nvim -l nvim/review/mode_test.lua
	nvim -l nvim/review/poke_bodies_test.lua
	nvim -l nvim/review/wrap_test.lua
	nvim -l nvim/review/readiness_test.lua
	nvim -l nvim/review/spinner_test.lua
	nvim -l nvim/review/resolve_test.lua
	nvim -l nvim/review/menu_test.lua

# Integration test for nvim/init.lua's send/queue/history state machine.
# Drives the real init.lua under headless nvim (it can't be unit-tested —
# monolithic config, all-local fns). Guards the send-from-queue duplication
# regression. See tests/queue-send-test.sh.
test-queue:
	bash tests/queue-send-test.sh

# Diagnostic trace for pair-originated zellij action calls (#68).
test-zellij-trace:
	bash tests/zellij-trace-test.sh

# Regression test for the autopair next-char gate (nvim/init.lua,
# pair_insert_open). Drives the real init.lua headlessly and asserts each
# opener's expr output. See tests/autopair-test.sh.
test-autopair:
	bash tests/autopair-test.sh

# Regression test for the insert-mode <CR> decision (nvim/init.lua, cr_keys /
# _G.PairCRKeys, #65): Return must always insert a newline when no completion
# is selected, dismissing the popup. Asserts the expr output for all three
# popup states. See tests/cr-newline-test.sh.
test-cr:
	bash tests/cr-newline-test.sh

# Regression tests for the draft statusline (nvim/init.lua, _G.PairStatusline).
# Drive the real init.lua headlessly: statusline-pos asserts the *, -N, +N nav
# marker; changelog-notify asserts the ephemeral "change log ready" flash + its
# fs_event marker watcher (#58).
test-statusline:
	bash tests/statusline-pos-test.sh
	bash tests/changelog-notify-test.sh

# Regression test for doctor/doctor.sh (the adaptation flight-recorder reader):
# a malformed line must not abort the diagnostic. See doctor/doctor_test.sh.
test-doctor:
	bash doctor/doctor_test.sh

# copy-on-select in_nvim detection: the agent overwrites its pane title with
# "claude [<cwd>]", so a repo path containing "nvim" (e.g. parley.nvim) must not
# be mistaken for the nvim draft pane (which would skip the paste). Keys on
# terminal_command, not the cwd-polluted title. See tests/copy-on-select-test.sh.
# copy-on-select is the Go binary (#93 M4; zellij's copy_command invokes it
# directly since #94 M2), so a fresh-tree run must build it before the test copies
# it into the sandboxed $PAIR_HOME/bin (same missing-prereq lesson as M2/M3).
test-copy-on-select: $(BIN_DIR)/copy-on-select
	bash tests/copy-on-select-test.sh

# Cross-emitter contract for the flight recorder: Go == shell == Lua schema,
# plus concurrent-append line-atomicity. See tests/adapt-schema-test.sh.
test-adapt-schema:
	bash tests/adapt-schema-test.sh

# pair-dev rebuild hook (#000046): deployed mode (PAIR_DEV unset) must invoke
# no toolchain; dev mode builds; build failure is errexit-safe. See
# tests/dev-rebuild-test.sh.
test-dev-rebuild:
	bash tests/dev-rebuild-test.sh

# Go public entrypoint install layout (#79): installed pair is a regular Go
# binary, pair-go launch shares its pair-shell handoff, and copied local
# installs fall back to the build-time source root for adjacent assets.
test-pair-go-install-layout:
	bash tests/pair-go-install-layout-test.sh

test-pair-embedded-runtime:
	bash tests/pair-embedded-runtime-test.sh

# pair restart/quit Go subcommands (#94 M1, ported from bin/pair-{restart,quit}.sh):
# markers land in ~/.cache/pair with PAIR_KILL_CMD stubbing the terminal kill.
test-pair-restart-quit: $(BIN_DIR)/pair
	bash tests/pair-restart-quit-test.sh

# pair-doctor emitter-health probe (#000047): marker check + binary selection
# (running-via-pidfile vs PATH). See tests/emitter-health-test.sh.
test-emitter-health:
	bash tests/emitter-health-test.sh

# changelog + scrollback openers — end-to-end smokes for the #93 M2 Go binaries
# (bin/pair-changelog-open, bin/pair-scrollback-open): fake the scrollback capture
# + model + nvim and assert clean → distill → write → open (changelog) and render
# → open (scrollback). Depend on the binaries so `make test` builds + runs them
# (the scripts SKIP if absent, which would silently no-op in CI without these).
test-changelog: $(BIN_DIR)/pair $(BIN_DIR)/pair-changelog $(BIN_DIR)/pair-scrollback-render $(BIN_DIR)/pair-changelog-open $(BIN_DIR)/pair-scrollback-open
	sh tests/changelog-open-test.sh
	sh tests/changelog-session-key-test.sh
	sh tests/scrollback-open-test.sh

# pair-scribe — Go-based pty wrapper with SIGUSR1/SIGUSR2 pause/resume
# of the typescript log. Replaces script(1) at the top of the user's
# shell, so preexec can stop the log from filling with TUI redraw bytes
# (claude, nvim, etc). Thin shim over cmd/internal/scribecmd (shared with
# the `pair scribe` route, #96). See cmd/pair-scribe/README.md for the why.
$(BIN_DIR)/pair-scribe: cmd/pair-scribe/main.go cmd/internal/scribecmd/scribecmd.go go.mod
	go build -o $@ ./cmd/pair-scribe

# pair-scrollback-render — replays a pair-wrap raw PTY capture through
# charmbracelet/x/vt and emits one ANSI-styled line per logical scrollback
# row, for the Alt+/ viewer to display through nvim.
$(BIN_DIR)/pair-scrollback-render: cmd/pair-scrollback-render/main.go cmd/internal/scrollbackcmd/scrollbackcmd.go go.mod
	go build -o $@ ./cmd/pair-scrollback-render

# pair-wrap — transparent PTY proxy around a TUI coding agent: forwards
# stdio, tees scrollback log, extracts colored spans for nvim autocomplete,
# detects OSC/BEL and forwards as OSC 9 to the recorded outer-TTY, handles
# SIGUSR1 image-paste capture window. Thin shim over cmd/internal/wrapcmd
# (shared with the `pair wrap` streaming route, #96).
$(BIN_DIR)/pair-wrap: cmd/pair-wrap/main.go cmd/internal/wrapcmd/wrap.go cmd/internal/adapt/adapt.go go.mod
	go build -o $@ ./cmd/pair-wrap

$(BIN_DIR)/pair-slug: cmd/pair-slug/main.go cmd/internal/slugcmd/slugcmd.go cmd/internal/slugcmd/slug.go cmd/internal/model/model.go cmd/internal/transcript/transcript.go cmd/internal/adapt/adapt.go go.mod
	go build -o $@ ./cmd/pair-slug

# pair-context — one-shot: print a pane's current context size (token count)
# for the pair-title poller. Pure ctxmeter reader + shared transcript resolver.
$(BIN_DIR)/pair-context: cmd/pair-context/main.go cmd/internal/contextcmd/contextcmd.go cmd/internal/ctxmeter/ctxmeter.go cmd/internal/transcript/transcript.go go.mod
	go build -o $@ ./cmd/pair-context

# pair-session-watch — async codex/agy session-id discovery. The launcher spawns
# this Go binary directly (the bin/pair-session-watch.sh shim was retired #94 M2).
$(BIN_DIR)/pair-session-watch: cmd/pair-session-watch/main.go cmd/internal/sessionwatch/sessionwatch.go cmd/internal/sessionwatch/run.go cmd/internal/sessionwatch/runcli.go cmd/internal/sessionwatch/runtime.go cmd/internal/procutil/procutil.go cmd/internal/adapt/adapt.go go.mod
	go build -o $@ ./cmd/pair-session-watch

# pair-title — the per-tag title poller (#93 M1, ported from bin/pair-title.sh):
# zellij frame meter (#71) + cmux workspace heat-ramp. Pure decisions in
# cmd/internal/titlepoller; zellij/cmux/ps/fs behind the OSRuntime seam. Reuses
# contextcmd (in-process context count) + procutil (kill-0/ps). The launcher
# spawns bin/pair-title directly (the .sh re-exec shim was retired #94 M2).
$(BIN_DIR)/pair-title: cmd/pair-title/main.go cmd/internal/titlepoller/titlepoller.go cmd/internal/titlepoller/run.go cmd/internal/titlepoller/runcli.go cmd/internal/titlepoller/runtime.go cmd/internal/procutil/procutil.go cmd/internal/contextcmd/contextcmd.go cmd/internal/ctxmeter/ctxmeter.go cmd/internal/transcript/transcript.go cmd/internal/adapt/adapt.go go.mod
	go build -o $@ ./cmd/pair-title

# pair-scrollback-open / pair-changelog-open — the Alt+/ and Alt+l floating-pane
# viewer launchers (#93 M2, ported from the same-named shell scripts). Pure
# viewport scorer + session keying in cmd/internal/opener; zellij/nvim/setsid/fs
# behind the OSRuntime seam. Reuse scrollbackcmd (in-process render) + procutil.
# The Go binaries replace the shell scripts at the same PATH names (zellij invokes
# them by name), so no .sh shim is kept.
OPENER_SRCS := cmd/internal/opener/opener.go cmd/internal/opener/run.go cmd/internal/opener/runcli.go cmd/internal/opener/runtime.go cmd/internal/procutil/procutil.go cmd/internal/scrollbackcmd/scrollbackcmd.go go.mod
$(BIN_DIR)/pair-scrollback-open: cmd/pair-scrollback-open/main.go $(OPENER_SRCS)
	go build -o $@ ./cmd/pair-scrollback-open
$(BIN_DIR)/pair-changelog-open: cmd/pair-changelog-open/main.go $(OPENER_SRCS)
	go build -o $@ ./cmd/pair-changelog-open

# pair-review-{target,open,readiness} — the review-start orchestrators (#93 M3,
# ported from the same-named shell scripts). Pure slugify/JSON/action-mapping in
# cmd/internal/reviewcmd; git/nvim-classify/zellij-spawn/codex-sid behind the
# OSRuntime seam (embeds osfs.FS). nvim/review/readiness.lua stays the single
# source of the 4-case decision (invoked via nvim --headless). The Go binaries
# replace the shell scripts at the same PATH names (no shim).
REVIEW_SRCS := cmd/internal/reviewcmd/reviewcmd.go cmd/internal/reviewcmd/run.go cmd/internal/reviewcmd/runcli.go cmd/internal/reviewcmd/runtime.go cmd/internal/osfs/osfs.go cmd/internal/codexsid/codexsid.go cmd/internal/procutil/procutil.go go.mod
$(BIN_DIR)/pair-review-target: cmd/pair-review-target/main.go $(REVIEW_SRCS)
	go build -o $@ ./cmd/pair-review-target
$(BIN_DIR)/pair-review-open: cmd/pair-review-open/main.go $(REVIEW_SRCS)
	go build -o $@ ./cmd/pair-review-open
$(BIN_DIR)/pair-review-readiness: cmd/pair-review-readiness/main.go $(REVIEW_SRCS)
	go build -o $@ ./cmd/pair-review-readiness

# copy-on-select / clipboard-to-pane / flash-pane — the copy-on-select clipboard
# pipeline (#93 M4, ported from the same-named shell scripts). Pure in_nvim
# classify + pane selection + quote/flash resolution in cmd/internal/clipcmd;
# clipboard/zellij-IPC/spawn/exec behind the OSRuntime seam (embeds osfs.FS).
# The zellij list-panes walk is shared via cmd/internal/zellijpane. Unlike M2/M3,
# these keep tracked bin/*.sh re-exec shims (see .gitignore's !bin/*.sh + the
# by-path stubs in tests/copy-on-select-test.sh); copy-on-select still execs the
# flash/clipboard .sh shims, preserving that chain.
CLIP_SRCS := cmd/internal/clipcmd/clipcmd.go cmd/internal/clipcmd/run.go cmd/internal/clipcmd/runcli.go cmd/internal/clipcmd/runtime.go cmd/internal/zellijpane/zellijpane.go cmd/internal/osfs/osfs.go go.mod
$(BIN_DIR)/copy-on-select: cmd/copy-on-select/main.go $(CLIP_SRCS)
	go build -o $@ ./cmd/copy-on-select
$(BIN_DIR)/clipboard-to-pane: cmd/clipboard-to-pane/main.go $(CLIP_SRCS)
	go build -o $@ ./cmd/clipboard-to-pane
$(BIN_DIR)/flash-pane: cmd/flash-pane/main.go $(CLIP_SRCS)
	go build -o $@ ./cmd/flash-pane

# pair-changelog — distills the pair TTY into the Alt+l change log (#53);
# shares cmd/internal/model with pair-slug.
$(BIN_DIR)/pair-changelog: cmd/pair-changelog/main.go cmd/internal/changelogcmd/changelogcmd.go cmd/internal/changelogcmd/distill.go cmd/internal/changelogcmd/prompt.go cmd/internal/model/model.go go.mod
	go build -o $@ ./cmd/pair-changelog

# pair-continuation — the deterministic writer for the `continuation` datatype
# (ariadne#91): renders frontmatter, allocates a collision-safe timestamped
# name under workshop/continuation/, writes, then commits + pushes (recovery).
$(BIN_DIR)/pair-continuation: cmd/pair-continuation/main.go cmd/internal/continuationcmd/continuationcmd.go cmd/internal/continuationcmd/continuation.go cmd/internal/continuationcmd/git.go go.mod
	go build -o $@ ./cmd/pair-continuation

PAIR_GO_SRCS := cmd/pair-go/main.go cmd/internal/entrypoint/asset_root.go cmd/internal/entrypoint/mode.go cmd/internal/dispatcher/dispatcher.go cmd/internal/launcher/args.go cmd/internal/launcher/datadir.go cmd/internal/launcher/decision.go cmd/internal/launcher/history.go cmd/internal/launcher/run.go cmd/internal/launcher/session.go cmd/internal/launcher/tag.go cmd/internal/launcher/zellij.go cmd/internal/contextcmd/contextcmd.go cmd/internal/scrollbackcmd/scrollbackcmd.go cmd/internal/slugcmd/slugcmd.go cmd/internal/slugcmd/slug.go cmd/internal/wrapcmd/wrap.go cmd/internal/scribecmd/scribecmd.go cmd/internal/changelogcmd/changelogcmd.go cmd/internal/changelogcmd/distill.go cmd/internal/changelogcmd/prompt.go cmd/internal/continuationcmd/continuationcmd.go cmd/internal/continuationcmd/continuation.go cmd/internal/continuationcmd/git.go cmd/internal/sessionwatch/sessionwatch.go cmd/internal/sessionwatch/run.go cmd/internal/sessionwatch/runcli.go cmd/internal/sessionwatch/runtime.go cmd/internal/procutil/procutil.go cmd/internal/model/model.go cmd/internal/transcript/transcript.go cmd/internal/adapt/adapt.go cmd/internal/runtimebundle/manifest.go cmd/internal/runtimebundle/plan.go cmd/internal/runtimebundle/cleanup.go cmd/internal/runtimebundle/store.go cmd/internal/runtimebundle/embed.go $(RUNTIMEBUNDLE_ASSETS) go.mod

# pair — the Go-owned entrypoint. It drives the native launcher in-process (#99
# M5c — bin/pair-shell retired); source/Homebrew builds can inject defaultPairHome,
# while copied binaries without adjacent assets use the embedded runtime fallback.
# (PAIR_GO_SRCS is a staleness hint, not the compile set — `go build` pulls every
# dep; it needn't list every cmd/internal/launcher file.)
$(BIN_DIR)/pair: $(PAIR_GO_SRCS)
	go build -ldflags "$(PAIR_HOME_LDFLAGS)" -o $@ ./cmd/pair-go

# pair-go — development dispatcher and explicit migration surface.
# `pair-go launch ...` shares the same bin/pair-shell handoff as public pair;
# helper routes stay in the dispatcher.
$(BIN_DIR)/pair-go: $(PAIR_GO_SRCS)
	go build -ldflags "$(PAIR_HOME_LDFLAGS)" -o $@ ./cmd/pair-go


# Tart VM targets (tart, tart-gui, tart-mount, tart-stop, tart-clean)
# live in .tart/Makefile, vendored from ariadne and auto-included by
# Makefile.workflow. `make help-tart` for usage.
